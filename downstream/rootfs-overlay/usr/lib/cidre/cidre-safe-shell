#!/bin/sh
set -eu

reason="unknown"
print_env=false

usage() {
  cat <<EOF
Usage: cidre-safe-shell [options]

Options:
  --reason <reason>
  --print-env
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --reason) reason="$2"; shift 2 ;;
    --print-env) print_env=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

export CIDRE_SAFE_MODE=1
export CIDRE_RECOVERY_REASON="$reason"
export CIDRE_NO_DESKTOP=1

if [ "$print_env" = "true" ]; then
  printf 'CIDRE_SAFE_MODE=%s\n' "$CIDRE_SAFE_MODE"
  printf 'CIDRE_RECOVERY_REASON=%s\n' "$CIDRE_RECOVERY_REASON"
  printf 'CIDRE_NO_DESKTOP=%s\n' "$CIDRE_NO_DESKTOP"
  exit 0
fi

cat <<EOF
Cidre Safe Shell

Normal desktop startup has been skipped.
Useful commands:

  cidre-doctor --daily
  cidre-doctor --uninstall
  cidre-recovery status
  cidre-state-export
  cidre-exit-plan
  cidre-goodbye
EOF
