#!/bin/bash
# cidre-recovery: Cidre emergency system recovery command
set -euo pipefail

CIDRE_SYSTEM_ROOT="${CIDRE_SYSTEM_ROOT:-/var/lib/cidre}"
SYSTEM_SEED_ENV="${CIDRE_SYSTEM_ROOT}/seed/resume.env"
SYSTEM_RESUME_ENV="${CIDRE_SYSTEM_ROOT}/resume/resume.env"

show_help() {
  echo "Usage: cidre-recovery <command> [options]"
  echo "Commands:"
  echo "  help                 Show this help message"
  echo "  status               Show status of critical login, session, and keyboard services"
  echo "  doctor               Run diagnostic health checks on key desktop services"
  echo "  list                 List available legacy niri configurations and backups"
  echo "  snapshots            List available configuration snapshots (cidre-snapshot list)"
  echo "  restore <id|latest>  Restore files from a snapshot (delegates to cidre-snapshot)"
  echo "  seed-status          Show imported seed status"
  echo "  resume-status        Show imported resume status"
  echo "  downstream-status    Show downstream foundation prototype status"
  echo "  image-status         Show prototype image artifact status"
  echo "  disable-greetd       Disable greetd system service and restore fallback console"
  echo "  enable-greetd        Enable greetd system service to launch the graphical desktop"
  echo "  reset-niri           Restore default config.kdl to ~/.config/niri/"
  echo "  reset-waybar         Restore default waybar configuration to ~/.config/waybar/"
  echo "  reset-shell          Restore default fish shell configuration to ~/.config/fish/"
  echo "  reset-user-config    Re-run cidre-user-setup with --force option"
  echo "  collect-logs         Collect system logs for debugging and save to ~/cidre-recovery-report-*.tar.gz"
  echo "  safe-mode            Back up config, disable greetd, and set up safe defaults"
}

if [ $# -lt 1 ]; then
  show_help
  exit 1
fi

CMD="$1"
shift

case "$CMD" in
  help)
    show_help
    ;;
  status)
    echo "=== Cidre System Status ==="
    if systemctl is-active --quiet greetd; then
      echo "greetd service:    Active (Graphical Login)"
    else
      echo "greetd service:    Inactive (Console Login)"
    fi
    if systemctl --user is-active --quiet pipewire 2>/dev/null; then
      echo "PipeWire:          Active"
    else
      echo "PipeWire:          Inactive"
    fi
    if command -v localectl >/dev/null 2>&1; then
      echo "Locale keymap:"
      localectl status | grep "Keymap" || echo "  Unknown"
    fi
    ;;
  doctor)
    echo "=== Running Cidre Recovery Doctor ==="
    if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
      echo "[OK] Session is running Wayland."
    else
      echo "[WARN] Session is not running Wayland (XDG_SESSION_TYPE='${XDG_SESSION_TYPE:-}')."
    fi
    if [ -f "$HOME/.config/niri/config.kdl" ]; then
      echo "[OK] Niri configuration found."
    else
      echo "[FAIL] Niri configuration is missing at ~/.config/niri/config.kdl."
    fi
    if systemctl --user is-active --quiet fcitx5 2>/dev/null; then
      echo "[OK] fcitx5.service systemd user unit is running."
    else
      echo "[WARN] fcitx5.service is not active."
    fi
    if pgrep waybar >/dev/null; then
      echo "[OK] Waybar is running."
    else
      echo "[WARN] Waybar is not running."
    fi
    
    echo ""
    echo "Rollback Suggestion:"
    echo "  If things broke after a config change, run: 'cidre-recovery restore latest'"
    ;;
  list)
    echo "=== Available Niri Config Backups ==="
    if [ -d "$HOME/.config/niri" ]; then
      find "$HOME/.config/niri" -name "config.kdl.bak.*" -type f | sort -r || echo "No backups found."
    else
      echo "Niri config directory does not exist."
    fi
    ;;
  snapshots)
    if command -v cidre-snapshot >/dev/null 2>&1; then
      cidre-snapshot list
    elif [ -f "./cidre-snapshot" ]; then
      ./cidre-snapshot list
    elif [ -f "/usr/bin/cidre-snapshot" ]; then
      /usr/bin/cidre-snapshot list
    elif [ -f "$(dirname "$0")/cidre-snapshot" ]; then
      "$(dirname "$0")/cidre-snapshot" list
    else
      echo "Error: cidre-snapshot command not found." >&2
      exit 1
    fi
    ;;
  restore)
    if [ $# -lt 1 ]; then
      echo "Error: Please specify a snapshot ID or 'latest'." >&2
      exit 1
    fi
    TARGET="$1"
    # Delegate directly to cidre-snapshot
    if command -v cidre-snapshot >/dev/null 2>&1; then
      cidre-snapshot restore "$TARGET"
    elif [ -f "./cidre-snapshot" ]; then
      ./cidre-snapshot restore "$TARGET"
    elif [ -f "/usr/bin/cidre-snapshot" ]; then
      /usr/bin/cidre-snapshot restore "$TARGET"
    elif [ -f "$(dirname "$0")/cidre-snapshot" ]; then
      "$(dirname "$0")/cidre-snapshot" restore "$TARGET"
    else
      echo "Error: cidre-snapshot command not found." >&2
      exit 1
    fi
    ;;
  seed-status)
    echo "Cidre seed:"
    if [ -f "$SYSTEM_SEED_ENV" ]; then
      # shellcheck disable=SC1090
      . "$SYSTEM_SEED_ENV"
      echo "  imported: yes"
      echo "  profile: ${CIDRE_SEED_PROFILE:-unknown}"
      echo "  source commit: ${CIDRE_SEED_SOURCE_COMMIT:-unknown}"
    else
      echo "  imported: no"
    fi
    ;;
  resume-status)
    echo "Cidre resume:"
    if [ -f "$SYSTEM_RESUME_ENV" ]; then
      # shellcheck disable=SC1090
      . "$SYSTEM_RESUME_ENV"
      echo "  available: yes"
      echo "  profile: ${CIDRE_RESUME_PROFILE:-unknown}"
      if [ -f "$HOME/.local/state/cidre/resume/applied-profile" ]; then
        echo "  applied by user: yes"
      else
        echo "  applied by user: no"
      fi
    else
      echo "  available: no"
    fi
    ;;
  downstream-status)
    echo "Cidre downstream foundation:"
    echo "  image prototype: not built"
    if [ -f "systemd/cidre-firstboot-root.service" ] || [ -f "/usr/lib/cidre/cidre-firstboot-root" ]; then
      echo "  firstboot-root service: available"
    else
      echo "  firstboot-root service: missing"
    fi
    if [ -f "downstream/installer-entry.example.json" ]; then
      echo "  installer entry example: available"
    else
      echo "  installer entry example: missing"
    fi
    echo "  public image: not available"
    ;;
  image-status)
    SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
    IMAGE_OUTPUT_DIR="${REPO_ROOT}/.local/state/cidre/image-build"
    echo "Cidre image prototype:"
    echo "  output dir: $IMAGE_OUTPUT_DIR"
    if [ -f "$IMAGE_OUTPUT_DIR/cidre-rootfs-overlay.tar.gz" ]; then
      echo "  overlay artifact: present"
    else
      echo "  overlay artifact: missing"
    fi
    if [ -f "$IMAGE_OUTPUT_DIR/cidre-image-manifest.json" ]; then
      echo "  manifest: present"
    else
      echo "  manifest: missing"
    fi
    echo "  boot tested: no"
    echo "  public image: no"
    ;;
  disable-greetd)
    if [ "$EUID" -ne 0 ]; then
      echo "Error: Please run as root (sudo)." >&2
      exit 1
    fi
    echo "Disabling greetd..."
    systemctl disable greetd
    systemctl stop greetd || true
    echo "greetd disabled. Fallback to TTY is now active."
    ;;
  enable-greetd)
    if [ "$EUID" -ne 0 ]; then
      echo "Error: Please run as root (sudo)." >&2
      exit 1
    fi
    echo "Enabling greetd..."
    systemctl enable greetd
    systemctl start greetd || true
    echo "greetd enabled and started."
    ;;
  reset-niri)
    read -p "Are you sure you want to reset Niri configuration to system defaults? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    # Make backup snapshot first
    if command -v cidre-snapshot >/dev/null 2>&1; then
      cidre-snapshot create --label "pre-reset-niri"
    elif [ -f "./cidre-snapshot" ]; then
      ./cidre-snapshot create --label "pre-reset-niri"
    elif [ -f "/usr/bin/cidre-snapshot" ]; then
      /usr/bin/cidre-snapshot create --label "pre-reset-niri"
    elif [ -f "$(dirname "$0")/cidre-snapshot" ]; then
      "$(dirname "$0")/cidre-snapshot" create --label "pre-reset-niri"
    fi
    mkdir -p "$HOME/.config/niri"
    if [ -f "/usr/share/cidre/defaults/niri/config.kdl" ]; then
      cp /usr/share/cidre/defaults/niri/config.kdl "$HOME/.config/niri/config.kdl"
      echo "Niri config reset from system defaults."
    else
      echo "Error: System defaults not found." >&2
      exit 1
    fi
    ;;
  reset-waybar)
    read -p "Are you sure you want to reset Waybar configuration to system defaults? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    if command -v cidre-snapshot >/dev/null 2>&1; then
      cidre-snapshot create --label "pre-reset-waybar"
    elif [ -f "./cidre-snapshot" ]; then
      ./cidre-snapshot create --label "pre-reset-waybar"
    elif [ -f "/usr/bin/cidre-snapshot" ]; then
      /usr/bin/cidre-snapshot create --label "pre-reset-waybar"
    elif [ -f "$(dirname "$0")/cidre-snapshot" ]; then
      "$(dirname "$0")/cidre-snapshot" create --label "pre-reset-waybar"
    fi
    mkdir -p "$HOME/.config/waybar"
    if [ -f "/usr/share/cidre/defaults/waybar/config" ]; then
      cp /usr/share/cidre/defaults/waybar/config "$HOME/.config/waybar/config"
      cp /usr/share/cidre/defaults/waybar/style.css "$HOME/.config/waybar/style.css"
      echo "Waybar config reset from system defaults."
    else
      echo "Error: System defaults not found." >&2
      exit 1
    fi
    ;;
  reset-shell)
    read -p "Are you sure you want to reset Fish configuration to system defaults? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    if command -v cidre-snapshot >/dev/null 2>&1; then
      cidre-snapshot create --label "pre-reset-shell"
    elif [ -f "./cidre-snapshot" ]; then
      ./cidre-snapshot create --label "pre-reset-shell"
    elif [ -f "/usr/bin/cidre-snapshot" ]; then
      /usr/bin/cidre-snapshot create --label "pre-reset-shell"
    elif [ -f "$(dirname "$0")/cidre-snapshot" ]; then
      "$(dirname "$0")/cidre-snapshot" create --label "pre-reset-shell"
    fi
    mkdir -p "$HOME/.config/fish"
    if [ -f "/usr/share/cidre/defaults/fish/config.fish" ]; then
      cp /usr/share/cidre/defaults/fish/config.fish "$HOME/.config/fish/config.fish"
      echo "Fish config reset from system defaults."
    else
      echo "Error: System defaults not found." >&2
      exit 1
    fi
    ;;
  reset-niri-config)
    echo "Note: reset-niri-config is deprecated, redirecting to reset-niri..."
    $0 reset-niri
    ;;
  reset-user-config)
    read -p "Are you sure you want to re-run cidre-user-setup --force? [y/N]: " conf
    if [[ ! "$conf" =~ ^[yY] ]]; then
      echo "Reset cancelled."
      exit 0
    fi
    echo "Resetting user config..."
    if command -v cidre-user-setup >/dev/null 2>&1; then
      cidre-user-setup --force
    elif [ -f "./cidre-user-setup" ]; then
      ./cidre-user-setup --force
    elif [ -f "/usr/bin/cidre-user-setup" ]; then
      /usr/bin/cidre-user-setup --force
    else
      echo "Error: cidre-user-setup command not found." >&2
      exit 1
    fi
    ;;
  collect-logs)
    echo "Collecting logs..."
    TS=$(date +%Y%m%d-%H%M%S)
    REPORT_DIR="/tmp/cidre-recovery-report-${TS}"
    mkdir -p "$REPORT_DIR"
    
    journalctl -b -n 200 > "${REPORT_DIR}/journal.log" || true
    journalctl --user -b -n 200 > "${REPORT_DIR}/journal-user.log" || true
    systemctl status greetd > "${REPORT_DIR}/greetd-status.log" || true
    wpctl status > "${REPORT_DIR}/wireplumber.log" || true
    localectl status > "${REPORT_DIR}/locale.log" || true
    
    mkdir -p "${REPORT_DIR}/configs"
    cp -r "$HOME/.config/niri" "${REPORT_DIR}/configs/niri" || true
    cp -r "$HOME/.config/fcitx5" "${REPORT_DIR}/configs/fcitx5" || true
    cp -r "$HOME/.config/environment.d" "${REPORT_DIR}/configs/environment.d" || true
    
    REPORT_FILE="${HOME}/cidre-recovery-report-${TS}.tar.gz"
    tar -czf "$REPORT_FILE" -C /tmp "cidre-recovery-report-${TS}"
    rm -rf "$REPORT_DIR"
    echo "Logs collected at $REPORT_FILE"
    ;;
  safe-mode)
    echo "Activating Safe-Mode..."
    if [ "$EUID" -eq 0 ]; then
      systemctl disable greetd
      systemctl stop greetd || true
    else
      echo "Warning: Not root, cannot disable greetd automatically."
      echo "Please run: sudo cidre-recovery disable-greetd"
    fi
    
    # Save a safety snapshot first
    if command -v cidre-snapshot >/dev/null 2>&1; then
      cidre-snapshot create --label "pre-safemode"
    elif [ -f "./cidre-snapshot" ]; then
      ./cidre-snapshot create --label "pre-safemode"
    elif [ -f "/usr/bin/cidre-snapshot" ]; then
      /usr/bin/cidre-snapshot create --label "pre-safemode"
    elif [ -f "$(dirname "$0")/cidre-snapshot" ]; then
      "$(dirname "$0")/cidre-snapshot" create --label "pre-safemode"
    fi
    
    NIRI_CONF="$HOME/.config/niri/config.kdl"
    if [ -f "$NIRI_CONF" ]; then
      echo "Backing up niri config..."
      mv "$NIRI_CONF" "${NIRI_CONF}.bak.$(date +%Y%m%d-%H%M%S)"
    fi
    
    mkdir -p "$HOME/.config/niri"
    if [ -f "/usr/share/cidre/defaults/niri/config.kdl" ]; then
      cp /usr/share/cidre/defaults/niri/config.kdl "$NIRI_CONF"
      echo "Restored default safe-profile KDL config."
    fi
    echo "Safe-Mode configuration complete."
    ;;
  *)
    show_help
    exit 1
    ;;
esac
