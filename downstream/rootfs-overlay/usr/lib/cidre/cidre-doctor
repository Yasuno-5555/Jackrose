    for doc in README.md CHANGELOG.md docs/commands.md docs/profiles.md docs/packages.md docs/managed-files.md docs/validation-matrix.md docs/known-limitations.md docs/macos-install.md docs/macos-to-cidre-flow.md docs/installer-threat-model.md docs/seed-resume.md docs/downstream-strategy.md docs/alarm-fork-strategy.md docs/cidre-image-plan.md docs/cidre-image-prototype.md docs/installer-integration.md docs/image-build-notes.md docs/image-build-validation.md docs/firstboot-oobe.md docs/firstboot-security.md docs/firstboot-root-login-problem.md docs/image-boot-validation.md docs/rootfs-inspection.md docs/boot-log-collection.md docs/v0.12.0-macos-bootstrap.md docs/v0.13.0-seed-resume.md docs/v0.14.0-downstream-foundation.md docs/v0.15.0-cidre-image-prototype.md docs/v0.16.0-firstboot-oobe.md docs/v0.17.0-image-boot-validation.md docs/v0.18.0-builder-integration.md docs/v1.0.0-clean-install-test-plan.md docs/v0.9.0-rc-readiness.md docs/builder-integration.md docs/alarm-builder-notes.md docs/builder-artifacts.md docs/real-image-build.md docs/builder-runbook.md docs/image-register-verify.md docs/build-failure-report.md docs/v0.19.0-real-image-build.md docs/firstboot-fixup.md docs/firstboot-service-ordering.md docs/firstboot-retry-repair.md docs/v0.21.0-firstboot-fixup.md docs/user-phase-handoff.md docs/user-phase-state.md docs/first-login.md docs/install-resume-validation.md docs/uninstall.md docs/exit-path.md docs/state-export.md docs/partition-audit.md docs/macos-restore-guide.md docs/uninstall-threat-model.md docs/macos-restore-assistant.md docs/macos-partition-audit.md docs/macos-startup-disk.md docs/macos-uninstall-guide.md docs/recovery-screen.md docs/safe-mode.md docs/failure-levels.md docs/tty-recovery.md docs/recovery-shortcuts.md docs/rescue-slot.md docs/rescue-profile.md docs/rescue-image.md docs/rescue-mount.md docs/rescue-kernel-repair.md docs/rescue-threat-model.md docs/rescue-boot-integration.md docs/rescue-slot-layout.md docs/rescue-boot-metadata.md docs/rescue-boot-validation.md docs/macos-rescue-slot.md docs/rescue-boot-threat-model.md docs/v0.27.0-rescue-boot-integration.md docs/v0.26.0-rescue-slot-foundation.md docs/v0.25.0-recovery-screen-safe-mode.md docs/v0.24.0-macos-restore-assistant.md docs/v0.23.0-uninstall-exit-path.md docs/v0.22.0-user-phase-handoff.md downstream/image-build/README.md downstream/image-build/build-config.example downstream/image-build/artifact-layout.md; do
      if [ -f "${REPO_ROOT}/${doc}" ]; then
        print_result OK "Documentation file '${doc}' is present."
        # Extra verification for limitations presence
        if [ "$doc" = "docs/known-limitations.md" ]; then
          if grep -qi "real-hardware clean install not yet fully verified" "${REPO_ROOT}/${doc}"; then
            print_result OK "Limitations acknowledge clean install caveat."
          else
            print_result WARN "docs/known-limitations.md does not contain clean-install warning."
          fi
        fi
      else
        print_result FAIL "Documentation file '${doc}' is missing."
      fi
    done

  else
    print_result WARN "Cidre repository tree root not found. Skipping local tree validations."
  fi

  # 2. Check globally installed commands
  for cmd in install cidre-installer cidre-user-setup cidre-doctor cidre-recovery cidre-snapshot cidre-update cidre-maintenance cidre-firstboot cidre-welcome cidre-audio; do
    if command -v "$cmd" >/dev/null 2>&1; then
      print_result OK "Globally installed command '$cmd' is available in PATH."
    else
      print_result WARN "Globally installed command '$cmd' is missing from PATH."
    fi
  done

  # 3. State directory layout checks
  if [ -d "$STATE_DIR" ]; then
    print_result OK "Cidre state directory exists."
    for subdir in snapshots setup doctor update; do
      if [ -d "${STATE_DIR}/${subdir}" ]; then
        print_result OK "State subdirectory '${subdir}' exists."
      else
        print_result WARN "State subdirectory '${subdir}' is missing."
      fi
    done
  else
    print_result FAIL "Cidre state directory is missing."
  fi

  # 4. manifest existence
  if [ -f "${STATE_DIR}/manifest.json" ]; then
    print_result OK "Cidre installation manifest exists."
  else
    print_result WARN "Cidre installation manifest is missing (requires setup apply)."
  fi

elif [ "$MAINTENANCE_MODE" = true ]; then
  # 1. State directory layout checks
  if [ -d "$STATE_DIR" ]; then
    print_result OK "Cidre state directory exists at $STATE_DIR."
    for subdir in snapshots setup doctor update; do
      if [ -d "${STATE_DIR}/${subdir}" ]; then
        print_result OK "State subdirectory '${subdir}' exists."
      else
        print_result WARN "State subdirectory '${subdir}' is missing."
      fi
    done
  else
    print_result FAIL "Cidre state directory is missing at $STATE_DIR."
  fi

  # 2. manifest existence
  if [ -f "${STATE_DIR}/manifest.json" ]; then
    print_result OK "Cidre installation manifest exists."
  else
    print_result FAIL "Cidre installation manifest is missing."
  fi

  # 3. command availability checks
  for cmd in cidre-snapshot cidre-recovery cidre-maintenance cidre-update; do
    if command -v "$cmd" >/dev/null 2>&1 || [ -f "$(dirname "$0")/$cmd" ] || [ -f "./$cmd" ]; then
      print_result OK "Command '$cmd' is available."
    else
      print_result FAIL "Command '$cmd' is missing."
    fi
  done

  # 4. latest doctor result
  if [ -f "$LAST_SUMMARY" ]; then
    print_result OK "Latest doctor summary is available."
  else
    print_result WARN "No previous doctor summary found."
  fi

  # 5. setup history
  if [ -f "$STATE_DIR/setup/history.log" ]; then
    print_result OK "Setup history log is available."
  else
    print_result WARN "Setup history log is missing."
  fi

  # 6. snapshot count and warnings
  if [ -d "$STATE_DIR/snapshots" ]; then
    snap_count=$(find "$STATE_DIR/snapshots" -mindepth 1 -maxdepth 1 -type d | wc -l)
    if [ "$snap_count" -gt 15 ]; then
      print_result WARN "${snap_count} snapshots found; consider running 'cidre-maintenance prune' to clean up."
    else
      print_result OK "${snap_count} snapshots saved."
    fi
  else
    print_result OK "0 snapshots saved."
  fi

  # 7. firstboot status
  if [ -f "$STATE_DIR/firstboot-done" ]; then
    print_result OK "Firstboot configuration has completed."
  else
    print_result WARN "Firstboot configuration is not marked complete."
  fi

  # 8. package metadata sync status
  if [ -d "/var/lib/pacman/sync" ]; then
    db_file=$(find /var/lib/pacman/sync -name "*.db" -print -quit)
    if [ -n "$db_file" ]; then
      db_age=$(( ($(date +%s) - $(stat -c %Y "$db_file")) / 86400 ))
      if [ "$db_age" -gt 7 ]; then
        print_result WARN "Pacman sync database is ${db_age} days old. Run 'cidre-update --check' or 'sudo pacman -Sy'."
      else
        print_result OK "Pacman sync database is up to date (${db_age} days old)."
      fi
    else
      print_result WARN "No pacman sync database found. Package checks may be offline."
    fi
  else
    print_result OK "Not running under pacman package manager or sync database path is different."
  fi

  # 9. Cidre-managed config drift
  DRIFT_FOUND=false
  if command -v cidre-user-setup >/dev/null 2>&1; then
    if ! cidre-user-setup verify >/dev/null 2>&1; then
      DRIFT_FOUND=true
    fi
  elif [ -f "$(dirname "$0")/cidre-user-setup" ]; then
    if ! python3 "$(dirname "$0")/cidre-user-setup" verify >/dev/null 2>&1; then
      DRIFT_FOUND=true
    fi
  elif [ -f "./cidre-user-setup" ]; then
    if ! python3 "./cidre-user-setup" verify >/dev/null 2>&1; then
      DRIFT_FOUND=true
    fi
  fi
  if [ "$DRIFT_FOUND" = true ]; then
    print_result WARN "Cidre-managed config drift detected. Run 'cidre-maintenance drift' to see differences."
  else
    print_result OK "No configuration drift detected."
  fi

  # 10. stale logs warning
  for log in install.log doctor/history.log setup/history.log update/history.log; do
    lpath="${STATE_DIR}/${log}"
    if [ -f "$lpath" ]; then
      lsize=$(stat -c %s "$lpath" 2>/dev/null || echo 0)
      if [ "$lsize" -gt 5242880 ]; then
        print_result WARN "Log file '${log}' is large ($((lsize / 1024 / 1024))MB). Run 'cidre-maintenance prune'."
      fi
    fi
  done
else
  # 1. Session check
  if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
    print_result OK "Graphical session is Wayland."
  else
    print_result WARN "Graphical session is not Wayland (XDG_SESSION_TYPE='${XDG_SESSION_TYPE:-}')."
  fi

  # 2. Config presence checks
  check_file_exists() {
    local filepath="$1"
    local name="$2"
    if [ -f "$filepath" ]; then
      print_result OK "$name is present."
    elif [ -d "$filepath" ]; then
      print_result OK "$name directory is present."
    else
      print_result FAIL "$name is missing at $filepath."
    fi
  }

  check_file_exists "$HOME/.config/niri/config.kdl" "Niri configuration"
  check_file_exists "$HOME/.config/waybar/config" "Waybar configuration"
  check_file_exists "$HOME/.config/ghostty/config" "Ghostty configuration"
  check_file_exists "$HOME/.config/fish/config.fish" "Fish configuration"
  check_file_exists "$HOME/.local/state/cidre/manifest.json" "Cidre setup manifest"

  # 3. Fcitx5 systemd user service check
  if systemctl --user is-active --quiet fcitx5 2>/dev/null; then
    print_result OK "Fcitx5 user service is active."
  elif systemctl --user is-enabled --quiet fcitx5 2>/dev/null; then
    print_result WARN "Fcitx5 user service is enabled but not currently running."
  else
    print_result FAIL "Fcitx5 user service is inactive or not configured."
  fi

  # 4. speakersafetyd system daemon check
  if systemctl is-active --quiet speakersafetyd 2>/dev/null; then
    print_result OK "speakersafetyd service is active."
  else
    print_result WARN "speakersafetyd service is inactive (needed for safe audio output)."
  fi

  # 5. rtkit-daemon check
  if systemctl is-active --quiet rtkit-daemon 2>/dev/null; then
    print_result OK "rtkit-daemon service is active."
  else
    print_result WARN "rtkit-daemon service is inactive (needed for real-time scheduling priority)."
  fi

  # 6. Audio package check
  if command -v pipewire >/dev/null 2>&1; then
    print_result OK "PipeWire command is available."
  else
    print_result FAIL "PipeWire command is missing."
  fi

  # 7. Check expected binaries
  for cmd in ghostty fuzzel waybar starship fcitx5; do
    if command -v "$cmd" >/dev/null 2>&1; then
      print_result OK "Executable '$cmd' is available."
    else
      print_result FAIL "Core executable '$cmd' is missing on the system."
    fi
  done

  # 8. Daily driver specific checks
  if [ "$DAILY_MODE" = true ] || [ "$VERBOSE_MODE" = true ]; then
    # Brightness tool
    if command -v brightnessctl >/dev/null 2>&1; then
      print_result OK "brightnessctl tool is installed."
    else
      print_result WARN "brightnessctl tool is missing. Brightness hotkeys will not function."
    fi

    # Screenshot tools
    if command -v grim >/dev/null 2>&1 && command -v slurp >/dev/null 2>&1; then
      print_result OK "Screenshot utilities (grim, slurp) are available."
    else
      print_result WARN "Screenshot utilities (grim, slurp) are missing. Screenshot flow will be limited."
    fi

    # Battery status availability check (Apple Silicon Macs / laptops)
    if [ -d /sys/class/power_supply ] && ls /sys/class/power_supply/BAT* >/dev/null 2>&1; then
      print_result OK "Battery info is visible in /sys/class/power_supply."
    else
      print_result WARN "No battery interface (BAT*) found in /sys/class/power_supply. Ignore if running on desktop Mac."
    fi

    # Mozc IME check
    if command -v fcitx5-remote >/dev/null 2>&1; then
      print_result OK "fcitx5-remote client is available."
    else
      print_result WARN "fcitx5-remote tool is missing; IME diagnostics cannot be queried."
    fi

    # Network status tool
    if command -v nmcli >/dev/null 2>&1; then
      print_result OK "nmcli network management tool is available."
    else
      print_result WARN "nmcli is missing; network status indicator might be incomplete."
    fi

    # Firstboot completion state check
    if [ -f "$HOME/.local/state/cidre/firstboot-done" ]; then
      print_result OK "Firstboot diagnostic check has run successfully."
    else
      print_result WARN "Firstboot diagnostic is pending or has not completed."
    fi

    # Install logs
    if [ -f "/var/log/cidre/bootstrap.log" ]; then
      print_result OK "Cidre installation log is present."
    else
      print_result WARN "Cidre installation log not found at /var/log/cidre/bootstrap.log."
    fi
  fi
fi

# Save log results
mv "$TMP_SUMMARY" "$LAST_SUMMARY"
ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
echo "[${ts}] OK: ${OK_COUNT}, WARN: ${WARN_COUNT}, FAIL: ${FAIL_COUNT}" >> "$HISTORY_LOG"

if [ "$SUMMARY_MODE" = true ]; then
  echo "Cidre Health: OK=$OK_COUNT, WARN=$WARN_COUNT, FAIL=$FAIL_COUNT"
else
  echo ""
  if [ $STATUS -eq 0 ]; then
    echo "Diagnostics complete: ALL checks passed."
  else
    echo "Diagnostics complete: SOME warnings or critical failures were detected."
    echo "Recommended recovery commands:"
    echo "  * To check detailed recommendations:  cidre-doctor --fix-suggestions"
    echo "  * To restore config from snapshot:    cidre-recovery restore latest"
    echo "  * To reset configs back to default:   cidre-user-setup --force"
  fi
fi

exit $STATUS
