#!/bin/bash
# validate-rootfs: Validates seed rootfs sanity
set -euo pipefail

ROOTFS=""
DRY_RUN=0

usage() {
  echo "Usage: $0 --rootfs <path> [--dry-run]"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --rootfs)
      if [ $# -lt 2 ]; then
        echo "ERROR: --rootfs requires an argument." >&2
        exit 1
      fi
      ROOTFS="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$ROOTFS" ]; then
  echo "ERROR: --rootfs is required." >&2
  usage
fi

# Fatal error if firstboot.done completion marker is already in the target
MARKER_PATH="$ROOTFS/var/lib/cidre/firstboot.done"
if [ -f "$MARKER_PATH" ]; then
  echo "Fatal:" >&2
  echo "  firstboot.done exists inside the rootfs." >&2
  echo "" >&2
  echo "Why this matters:" >&2
  echo "  cidre-firstboot.service will not run if this marker exists." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Remove the marker from the rootfs and re-run validation." >&2
  exit 2
fi

# Fatal error if welcome.done exists in seed rootfs
WELCOME_MARKER_PATH="$ROOTFS/var/lib/cidre/welcome.done"
if [ -f "$WELCOME_MARKER_PATH" ]; then
  echo "Fatal:" >&2
  echo "  welcome.done exists inside the rootfs." >&2
  echo "" >&2
  echo "Why this matters:" >&2
  echo "  A seed image must not be pre-marked as welcome-complete." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Remove the welcome.done marker from the rootfs." >&2
  exit 2
fi

# Fatal error if optimized.done exists in seed rootfs
OPT_MARKER_PATH="$ROOTFS/var/lib/cidre/optimized.done"
if [ -f "$OPT_MARKER_PATH" ]; then
  echo "Fatal:" >&2
  echo "  optimized.done exists inside the rootfs." >&2
  echo "" >&2
  echo "Why this matters:" >&2
  echo "  A seed image must not be pre-marked as optimized-complete." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Remove the optimized.done marker from the rootfs." >&2
  exit 2
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo "  === Rootfs Validation [DRY-RUN SIMULATION] ==="
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-oobe exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-welcome exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-user-setup exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-healthcheck exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/lib/systemd/system/cidre-firstboot.service exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/share/cidre/defaults exists"
  echo "  [DRY-RUN] would verify: NetworkManager service unit is active/enabled"
  echo "  [DRY-RUN] would verify: root password policy is locked"
  echo "  [DRY-RUN] would verify: $ROOTFS/var/lib/cidre directory exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/niri exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/foot exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/fuzzel exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/waybar exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/firefox exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/fcitx5 exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-session exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/share/wayland-sessions/cidre.desktop exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/etc/xdg/autostart/cidre-welcome.desktop exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-experience-upgrade exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-build-ghostty exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-build-niri-cidre exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/usr/bin/cidre-setup-fish exists"
  echo "  [DRY-RUN] would verify: $ROOTFS/var/lib/cidre/firstboot.done does NOT exist (PASSED)"
  echo "  [DRY-RUN] would verify: $ROOTFS/var/lib/cidre/welcome.done does NOT exist (PASSED)"
  echo "  [DRY-RUN] would verify: $ROOTFS/var/lib/cidre/optimized.done does NOT exist (PASSED)"
  echo "  Validation Simulation: PASSED"
  exit 0
fi

# Real build validation (Actual target checks)
echo "Running rootfs validation on $ROOTFS..."
errors=0

_check_file() {
  local file_path="$1"
  local description="$2"
  if [ -f "$file_path" ]; then
    echo "  [OK] File exists: $file_path"
  else
    echo "" >&2
    echo "What happened:" >&2
    echo "  $description is missing from the rootfs at $file_path." >&2
    echo "" >&2
    echo "Why it matters:" >&2
    echo "  It is part of the required baseline graphical Cidre desktop environment." >&2
    echo "" >&2
    echo "Next step:" >&2
    echo "  Install cidre-meta-desktop-baseline into the rootfs and re-run validation." >&2
    errors=$((errors + 1))
  fi
}

_check_dir() {
  local dir_path="$1"
  if [ -d "$dir_path" ]; then
    echo "  [OK] Directory exists: $dir_path"
  else
    echo "  [FAIL] Directory missing: $dir_path" >&2
    errors=$((errors + 1))
  fi
}

_check_file "$ROOTFS/usr/bin/cidre-oobe" "TTY OOBE rescue tool"
_check_file "$ROOTFS/usr/bin/cidre-welcome" "Cidre Welcome dashboard"
_check_file "$ROOTFS/usr/bin/cidre-user-setup" "Cidre User configuration helper"
_check_file "$ROOTFS/usr/bin/cidre-healthcheck" "Cidre Healthcheck diagnostics"
_check_file "$ROOTFS/usr/lib/systemd/system/cidre-firstboot.service" "Firstboot systemd startup service"
_check_dir "$ROOTFS/usr/share/cidre/defaults"
_check_dir "$ROOTFS/var/lib/cidre"

# Baseline graphical desktop binaries validation
_check_file "$ROOTFS/usr/bin/niri" "Niri Wayland compositor"
_check_file "$ROOTFS/usr/bin/foot" "Foot terminal emulator"
_check_file "$ROOTFS/usr/bin/fuzzel" "Fuzzel application launcher"
_check_file "$ROOTFS/usr/bin/waybar" "Waybar status bar"
_check_file "$ROOTFS/usr/bin/firefox" "Firefox web browser"
_check_file "$ROOTFS/usr/bin/fcitx5" "Fcitx5 input method editor"
_check_file "$ROOTFS/usr/bin/cidre-session" "Cidre session launcher wrapper"
_check_file "$ROOTFS/usr/share/wayland-sessions/cidre.desktop" "Wayland session entry file"
_check_file "$ROOTFS/etc/xdg/autostart/cidre-welcome.desktop" "Cidre Welcome autostart configuration entry"
_check_file "$ROOTFS/usr/bin/cidre-experience-upgrade" "Cidre experience upgrade orchestrator"
_check_file "$ROOTFS/usr/bin/cidre-build-ghostty" "Ghostty terminal compilation helper"
_check_file "$ROOTFS/usr/bin/cidre-build-niri-cidre" "niri-cidre compositor compilation helper"
_check_file "$ROOTFS/usr/bin/cidre-setup-fish" "Fish shell configuration helper"

# NetworkManager systemd unit check
if [ -f "$ROOTFS/usr/lib/systemd/system/NetworkManager.service" ] || [ -f "$ROOTFS/lib/systemd/system/NetworkManager.service" ]; then
  echo "  [OK] NetworkManager service unit exists."
else
  echo "" >&2
  echo "What happened:" >&2
  echo "  NetworkManager.service unit is missing." >&2
  echo "" >&2
  echo "Why it matters:" >&2
  echo "  NetworkManager is required to handle connections." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Verify networkmanager is installed in target rootfs." >&2
  errors=$((errors + 1))
fi

# NetworkManager enablement check
if [ -L "$ROOTFS/etc/systemd/system/multi-user.target.wants/NetworkManager.service" ]; then
  echo "  [OK] NetworkManager is enabled."
else
  echo "" >&2
  echo "What happened:" >&2
  echo "  NetworkManager is not enabled." >&2
  echo "" >&2
  echo "Why it matters:" >&2
  echo "  NetworkManager must automatically start on boot." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Run: systemctl --root $ROOTFS enable NetworkManager.service" >&2
  errors=$((errors + 1))
fi

# Greetd (display-manager) enablement check
if [ -L "$ROOTFS/etc/systemd/system/display-manager.service" ]; then
  echo "  [OK] display-manager.service is enabled."
else
  echo "" >&2
  echo "What happened:" >&2
  echo "  display-manager.service (greetd) is not enabled." >&2
  echo "" >&2
  echo "Why it matters:" >&2
  echo "  The graphical desktop session will not launch on boot." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Run: systemctl --root $ROOTFS enable greetd.service" >&2
  errors=$((errors + 1))
fi

# cidre-firstboot-prep enablement check
if [ -L "$ROOTFS/etc/systemd/system/multi-user.target.wants/cidre-firstboot-prep.service" ]; then
  echo "  [OK] cidre-firstboot-prep.service is enabled."
else
  echo "" >&2
  echo "What happened:" >&2
  echo "  cidre-firstboot-prep.service is not enabled." >&2
  echo "" >&2
  echo "Why it matters:" >&2
  echo "  First-boot directory initialization will not occur." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Run: systemctl --root $ROOTFS enable cidre-firstboot-prep.service" >&2
  errors=$((errors + 1))
fi


if [ $errors -gt 0 ]; then
  echo "ERROR: Rootfs integration validation failed with $errors error(s)." >&2
  exit 1
fi

echo "Rootfs validation completed successfully."
