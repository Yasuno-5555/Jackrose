#!/bin/bash
# install-local-packages: Installs built local packages into target rootfs
set -euo pipefail

ROOTFS=""
PACKAGES=""
DRY_RUN=0
APPLY=0
PACMAN_CACHE="/var/cache/pacman/pkg"

usage() {
  echo "Usage: $0 --rootfs <path> --packages <path> [--dry-run | --apply]"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --rootfs)
      if [ $# -lt 2 ]; then
        echo "ERROR: --rootfs requires an argument." >&2
        exit 1
      fi
      ROOTFS="$2"
      shift 2
      ;;
    --packages)
      if [ $# -lt 2 ]; then
        echo "ERROR: --packages requires an argument." >&2
        exit 1
      fi
      PACKAGES="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --apply)
      APPLY=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$ROOTFS" ] || [ -z "$PACKAGES" ]; then
  echo "ERROR: Both --rootfs and --packages are required." >&2
  usage
fi

if [ "$DRY_RUN" -eq 0 ] && [ "$APPLY" -eq 0 ]; then
  echo "ERROR: Use --dry-run or --apply explicitly." >&2
  exit 1
fi

# Safety Rules: Refuse if target is root / or empty
if [ "$ROOTFS" = "/" ] || [ -z "$ROOTFS" ]; then
  echo "ERROR: Refusing to install packages to live host root '/' or empty path." >&2
  exit 1
fi

# Verify cidre-seed presence in apply mode
if [ "$APPLY" -eq 1 ]; then
  seed_check=$(find "$PACKAGES" -name "cidre-seed-*" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$seed_check" -eq 0 ]; then
    echo "ERROR: Refusing installation. cidre-seed package artifact is missing in $PACKAGES." >&2
    exit 1
  fi
fi

if [ "$DRY_RUN" -eq 1 ]; then
  echo "  === Local Packages Installation [DRY-RUN SIMULATION] ==="
  echo "  Target rootfs: $ROOTFS"
  echo "  Packages directory: $PACKAGES"
  echo "  [DRY-RUN] would execute: pacman --root $ROOTFS --cachedir $PACMAN_CACHE -U $PACKAGES/*.pkg.tar.* --noconfirm"
  echo "  Simulation complete. No modifications performed."
  exit 0
fi

# Apply mode (Requires ALARM/Arch host context)
echo "Installing local packages into target rootfs at $ROOTFS..."
if ! command -v pacman >/dev/null 2>&1; then
  echo "ERROR: pacman was not found. Cannot perform target installation." >&2
  exit 1
fi

# Run chroot/rootfs-based pacman install
if ! pacman --root "$ROOTFS" --cachedir "$PACMAN_CACHE" -U "$PACKAGES"/*.pkg.tar.* --noconfirm; then
  echo "" >&2
  echo "What happened:" >&2
  echo "  pacman could not resolve dependencies inside the target rootfs." >&2
  echo "" >&2
  echo "Likely cause:" >&2
  echo "  Base ALARM packages or configured repositories are unavailable." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Ensure the rootfs has usable pacman repositories, or preinstall base dependencies before retrying." >&2
  exit 1
fi
