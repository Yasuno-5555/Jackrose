#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/cidre/mutation/current"

format="json"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) format="json"; shift ;;
    --markdown) format="markdown"; shift ;;
    --help|-h) echo "Usage: cidre-app-mutation-report [--json|--markdown]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

python3 - "$STATE_DIR" "$format" <<'PY'
import json
import os
import sys

state_dir, fmt = sys.argv[1:]

def load(path):
    if not os.path.exists(path):
        return None
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return json.load(handle)
    except Exception:
        return None

files = {
    "mutation_test_mode": os.path.join(state_dir, "test-mode.json"),
    "disposable_target": os.path.join(state_dir, "disposable-target.json"),
    "plan": os.path.join(state_dir, "last-plan.json"),
    "signature": os.path.join(state_dir, "last-signature.json"),
    "confirmation": os.path.join(state_dir, "last-confirmation.json"),
    "execution": os.path.join(state_dir, "last-execution.json"),
    "verification": os.path.join(state_dir, "last-verification.json"),
}
report = {name: load(path) for name, path in files.items()}
final_status = "blocked"
execution_status = (report.get("execution") or {}).get("status")
verification_status = (report.get("verification") or {}).get("status")
disposable_status = (report.get("disposable_target") or {}).get("status")
if execution_status in {"blocked", "failed", "passed"}:
    final_status = execution_status
elif verification_status in {"failed", "passed"}:
    final_status = verification_status
elif disposable_status:
    final_status = disposable_status
payload = {
    "schema_version": 1,
    "command": "cidre-app-mutation-report",
    "status": final_status,
    "summary": "Controlled mutation test report generated.",
    "exit_code": 0,
    "report": report,
    "state_files": files,
}
markdown = "\n".join([
    "# Controlled Mutation Test Report",
    "",
    f"- Final status: {final_status}",
    f"- Mutation test mode: {(report.get('mutation_test_mode') or {}).get('mode', 'unknown')}",
    f"- Selected target: {(report.get('disposable_target') or {}).get('target', 'unknown')}",
    f"- Disposable target check: {(report.get('disposable_target') or {}).get('status', 'unknown')}",
    f"- Plan hash: {(report.get('signature') or {}).get('plan_hash', 'unknown')}",
    f"- Confirmation status: {(report.get('confirmation') or {}).get('status', 'unknown')}",
    f"- Helper gate/execution: {(report.get('execution') or {}).get('status', 'unknown')}",
    f"- Verification: {(report.get('verification') or {}).get('status', 'unknown')}",
    "",
    "This report does not mark the installer flow complete. Normal finish/shutdown gates remain enforced.",
])

if fmt == "markdown":
    print(markdown)
else:
    print(json.dumps(payload, indent=2))
PY
