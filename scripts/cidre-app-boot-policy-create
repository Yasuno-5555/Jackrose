#!/bin/sh
set -eu
# cidre-app-boot-policy-create
# Fully automated: creates Volume Group, restore bundle, and LocalPolicy for Cidre.
# All admin operations use osascript (works from GUI wizard, no sudo/terminal needed).
# After this script succeeds, Cidre appears in Apple Silicon Startup Options.

target=""
owner_user=""
owner_password=""
dry_run=false
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target) target="$2"; shift 2 ;;
    --owner-user) owner_user="$2"; shift 2 ;;
    --owner-password) owner_password="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-boot-policy-create --target <cidre_volume_device> [--owner-user <user>] [--owner-password <pass>] [--dry-run] [--json]"
      echo "Fully automated boot policy creation for Apple Silicon Startup Options."
      echo "  --owner-user      macOS user with Owner permissions (for bless/bputil)"
      echo "  --owner-password  Password for the owner user"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

[ -n "$target" ] || { echo "ERROR: --target is required" >&2; exit 2; }

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

# ── Phase 1: Discovery ──────────────────────────────────────────────
discovery_json="$(python3 - "$target" <<'PY'
import json, os, subprocess, sys
target = sys.argv[1]
result = {
    "target": target, "container": "", "volume_uuid": "",
    "vg_exists": False, "vg_uuid": "",
    "data_volume": "", "system_volume": "",
    "preboot_device": "", "preboot_mount": "",
    "recovery_device": "",
    "system_mount": "", "system_boot_files_ok": False,
    "errors": [], "steps_needed": []
}
if os.uname().sysname != "Darwin":
    result["errors"].append("Requires macOS"); print(json.dumps(result)); sys.exit(0)
try:
    import plistlib
    info = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil","info","-plist",target], capture_output=True, check=True).stdout)
    result["volume_uuid"] = info.get("VolumeUUID","")
    result["container"] = info.get("APFSContainerReference") or info.get("ParentWholeDisk","")
    cref = result["container"]
    if not cref: result["errors"].append("No container found"); print(json.dumps(result)); sys.exit(0)

    # Enumerate volumes and roles
    apfs = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil","apfs","list","-plist"], capture_output=True, check=True).stdout)
    for c in apfs.get("Containers",[]):
        if c.get("ContainerReference") == cref:
            for v in c.get("Volumes",[]):
                roles = v.get("Roles",[]) or []
                name = v.get("Name","")
                dev = v.get("DeviceIdentifier","")
                if "Data" in roles: result["data_volume"] = dev
                if "System" in roles:
                    result["system_volume"] = dev
                    mp = v.get("MountPoint","")
                    result["system_mount"] = mp
                    if mp:
                        sv_plist = os.path.join(mp, "System/Library/CoreServices/SystemVersion.plist")
                        boot_efi = os.path.join(mp, "System/Library/CoreServices/boot.efi")
                        if os.path.exists(sv_plist) and os.path.exists(boot_efi):
                            result["system_boot_files_ok"] = True
                if "Preboot" in roles:
                    result["preboot_device"] = dev
                    result["preboot_mount"] = v.get("MountPoint","")

    # Volume Groups
    vg_data = plistlib.loads(subprocess.run(
        ["/usr/sbin/diskutil","apfs","listVolumeGroups","-plist"],
        capture_output=True, check=True).stdout)
    for c in vg_data.get("Containers",[]):
        if c.get("ContainerReference") == cref:
            vgs = c.get("VolumeGroups",[])
            if vgs:
                result["vg_exists"] = True
                result["vg_uuid"] = vgs[0].get("APFSVolumeGroupUUID","")

    # Determine needed steps
    if not result["vg_exists"]: result["steps_needed"].append("create-volume-group")
    if not result["system_boot_files_ok"]: result["steps_needed"].append("write-boot-files")
    if not result["preboot_mount"]: result["steps_needed"].append("mount-preboot")
    result["steps_needed"].append("restore-bundle")
    result["steps_needed"].append("bless-init")
    result["steps_needed"].append("bputil-create-policy")
    result["steps_needed"].append("bless-restore-macos")

except Exception as e:
    result["errors"].append(f"Discovery: {e}")

print(json.dumps(result))
PY
)"

container="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("container",""))')"
vg_exists="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("vg_exists") else "false")')"
vg_uuid="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("vg_uuid",""))')"
data_volume="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("data_volume",""))')"
system_volume="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("system_volume",""))')"
preboot_device="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("preboot_device",""))')"
preboot_mount="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("preboot_mount",""))')"
system_mount="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("system_mount",""))')"
boot_files_ok="$(printf '%s\n' "$discovery_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("system_boot_files_ok") else "false")')"

steps_done=""
steps_failed=""
one_tr_ready="false"

if [ "$dry_run" = true ]; then
  python3 -c "
import json
print(json.dumps({
    'schema_version': 1,
    'command': 'cidre-app-boot-policy-create',
    'status': 'passed',
    'summary': 'Dry-run completed',
    'exit_code': 0,
    'dry_run': True,
    'ssu_required': True,
    'security_mode': 'full',
    'reduced_security_status': 'manual-recovery-required',
    'reduced_security_guide': 'To enable Reduced Security:\n1. Shut down your Mac\n2. Press and hold the power button until \'Loading startup options\' appears\n3. Click Options (gear icon)\n4. Menu bar → Utilities → Startup Security Utility\n5. Select the Cidre volume\n6. Choose Reduced Security\n7. Restart back to macOS\n8. Reopen Cidre and continue the wizard',
}, indent=2))"
  exit 0
fi

# ── Admin helper ────────────────────────────────────────────────────
run_admin() {
  /usr/bin/osascript \
    -e 'on run argv' \
    -e 'do shell script (item 1 of argv) with administrator privileges' \
    -e 'end run' \
    "$1" 2>&1
}

# ── Phase 2: Volume Group setup ─────────────────────────────────────
if [ "$vg_exists" != "true" ] && [ -n "$container" ]; then
  # Delete any orphaned volumes from previous attempts (but NOT the target if it's the only volume)
  echo "[2/6] Setting up Volume Group..."

  # Step 2a: Ensure Data role on target volume
  current_roles="$(diskutil info -plist "$target" 2>/dev/null | python3 -c 'import plistlib,sys; print(",".join(plistlib.loads(sys.stdin.buffer.read()).get("Roles",[])))' 2>/dev/null || echo "")"
  if ! printf '%s' "$current_roles" | grep -q "Data"; then
    if run_admin "/usr/sbin/diskutil apfs changeVolumeRole ${target} D" >/dev/null 2>&1; then
      data_volume="$target"
      steps_done="${steps_done}data-role-set "
    else
      steps_failed="${steps_failed}data-role "
    fi
  fi

  # Step 2b: Create System volume grouped with Data
  if [ -z "$system_volume" ] && [ -n "$data_volume" ]; then
    sys_output="$(run_admin "/usr/sbin/diskutil apfs addVolume ${container} APFS Cidre -role S -groupWith ${data_volume} -plist" 2>&1)" || true
    system_volume="$(printf '%s\n' "$sys_output" | python3 -c '
import plistlib,sys
try:
    d=plistlib.loads(sys.stdin.buffer.read())
    print(d.get("AddedVolumeDeviceIdentifier",""))
except: print("")
' 2>/dev/null || echo "")"
    if [ -n "$system_volume" ]; then
      steps_done="${steps_done}system-volume($system_volume) "
    else
      steps_failed="${steps_failed}system-volume($sys_output) "
    fi
  fi

  # Step 2c: Create Preboot volume (role B)
  if [ -z "$preboot_device" ]; then
    pb_output="$(run_admin "/usr/sbin/diskutil apfs addVolume ${container} APFS Preboot -role B -plist" 2>&1)" || true
    preboot_device="$(printf '%s\n' "$pb_output" | python3 -c '
import plistlib,sys
try:
    d=plistlib.loads(sys.stdin.buffer.read())
    print(d.get("AddedVolumeDeviceIdentifier",""))
except: print("")
' 2>/dev/null || echo "")"
    [ -n "$preboot_device" ] && steps_done="${steps_done}preboot($preboot_device) " || steps_failed="${steps_failed}preboot "
  fi

  # Step 2d: Create Recovery volume (role R)
  rec_output="$(run_admin "/usr/sbin/diskutil apfs addVolume ${container} APFS Recovery -role R -plist" 2>&1)" || true
  rec_device="$(printf '%s\n' "$rec_output" | python3 -c '
import plistlib,sys
try:
    d=plistlib.loads(sys.stdin.buffer.read())
    print(d.get("AddedVolumeDeviceIdentifier",""))
except: print("")
' 2>/dev/null || echo "")"
  [ -n "$rec_device" ] && steps_done="${steps_done}recovery($rec_device) " || true

  # Refresh state
  vg_info="$(diskutil apfs listVolumeGroups -plist | python3 -c "
import plistlib, sys, json
d = plistlib.loads(sys.stdin.buffer.read())
for c in d.get('Containers',[]):
    if c.get('ContainerReference')=='${container}':
        vgs = c.get('VolumeGroups',[])
        if vgs:
            print(json.dumps({'vg_uuid':vgs[0].get('APFSVolumeGroupUUID','')}))
            sys.exit(0)
print(json.dumps({'vg_uuid':''}))
" 2>/dev/null || echo '{"vg_uuid":""}')"
  vg_uuid="$(printf '%s\n' "$vg_info" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("vg_uuid",""))')"

  # Get mount points
  preboot_mount="$(diskutil info -plist "$preboot_device" 2>/dev/null | python3 -c 'import plistlib,sys; print(plistlib.loads(sys.stdin.buffer.read()).get("MountPoint",""))' 2>/dev/null || echo "")"
  system_mount="$(diskutil info -plist "$system_volume" 2>/dev/null | python3 -c 'import plistlib,sys; print(plistlib.loads(sys.stdin.buffer.read()).get("MountPoint",""))' 2>/dev/null || echo "")"
fi

# ── Phase 3: Locate boot files ───────────────────────────────────────
# Asahi-alarm reference: stub.py install_files() uses Apple kernelcache (IMG4)
# as boot.efi for the initial 1TR boot, NOT m1n1.
#   https://github.com/asahi-alarm/asahi-alarm-installer
#
# REASONING: Apple Silicon firmware WILL load an Apple-signed IMG4 kernelcache
# even with Full Security. This boots into 1TR recoveryOS where bputil -g works.
# After Reduced Security is set (in step2), m1n1 replaces the kernelcache.
#
# m1n1 is saved as boot.efi.m1n1 for step2 restoration after bputil -g.
echo "[3/6] Locating boot files..."

M1N1_SRC=""
KERNELCACHE_SRC=""
M1N1_STAGING_DIR=""

# Search for m1n1 in standard locations
M1N1_CANDIDATES="/Users/yasuno/Projects/Cidre/libexec/m1n1.macho /Users/yasuno/Projects/Cidre/m1n1/build/m1n1.macho /Volumes/Cidre/boot/m1n1.macho"
for candidate in $M1N1_CANDIDATES; do
  if [ -f "$candidate" ] && file "$candidate" 2>/dev/null | grep -q "Mach-O"; then
    M1N1_SRC="$candidate"
    break
  fi
done

# Also check System volume
if [ -z "$M1N1_SRC" ] && [ -n "$system_mount" ]; then
  if [ -f "$system_mount/boot/m1n1.macho" ] && file "$system_mount/boot/m1n1.macho" 2>/dev/null | grep -q "Mach-O"; then
    M1N1_SRC="$system_mount/boot/m1n1.macho"
  fi
fi

# Locate Apple kernelcache from macOS restore bundle (for 1TR boot).
# Dynamically detect macOS VG UUID instead of hardcoding.
# Priority: (1) current boot VG from diskutil, (2) system Preboot scan, (3) fallback list.
MACOS_VGID=""
# Method 1: Get macOS VG UUID from the system volume
if [ -z "$MACOS_VGID" ]; then
  MACOS_VGID="$(diskutil info / 2>/dev/null | grep "APFS Volume Group" | awk -F': ' '{print $2}' | head -1 || echo "")"
fi
# Method 2: Scan system Preboot for any VG UUID with a restore bundle
if [ -z "$MACOS_VGID" ]; then
  MACOS_VGID="$(ls -d /System/Volumes/Preboot/*/restore 2>/dev/null | head -1 | xargs dirname 2>/dev/null | xargs basename 2>/dev/null || echo "")"
fi
# Method 3: Fallback to known common macOS VG UUIDs
if [ -z "$MACOS_VGID" ]; then
  for try_vgid in \
    "08E3B56E-946D-4280-9E3C-1931ED8B8B34" \
    "ECF56469-CD0D-43FF-94F9-B44B0D5E1E5B"; do
    if [ -d "/System/Volumes/Preboot/${try_vgid}/restore" ]; then
      MACOS_VGID="$try_vgid"
      break
    fi
  done
fi

if [ -z "$MACOS_VGID" ]; then
  echo "WARNING: Could not detect macOS Volume Group UUID."
  echo "Kernelcache-based 1TR boot may not work."
  steps_failed="${steps_failed}macos-vgid(undetected) "
else
  echo "macOS VG UUID: $MACOS_VGID"
  steps_done="${steps_done}macos-vgid($MACOS_VGID) "
fi

# ── Kernelcache search (Asahi ALARM reference approach) ────
# Asahi ALARM extracts kernelcache from IPSW; we use the macOS restore bundle.
# The kernelcache is the ONLY file iBoot will load with Full Security.
# Without it, the first 1TR boot cannot happen — iBoot rejects unsigned boot.efi.
# CRITICAL: Never fall back to m1n1 for the first boot. It's unsigned, so
# iBoot will always reject it with Full Security → reboot loop back to macOS.
#
# Search strategy:
# 1. macOS Preboot restore bundle (any kernelcache.release.*, wildcard for macOS ver)
# 2. macOS Preboot boot hash directory
# 3. Cidre Preboot restore bundle
# 4. Any kernelcache on the system Preboot volumes

KC_CANDIDATES=""
if [ -n "$MACOS_VGID" ]; then
  # Wildcard kernelcache.release.* to support any macOS version (mac13g, mac14g, etc.)
  KC_CANDIDATES="
/System/Volumes/Preboot/${MACOS_VGID}/restore/kernelcache.release.*
/System/Volumes/Preboot/${MACOS_VGID}/boot/*/System/Library/Caches/com.apple.kernelcaches/kernelcache
"
fi
KC_CANDIDATES="${KC_CANDIDATES}
/Volumes/Preboot/${vg_uuid}/restore/kernelcache.release.*
/Volumes/Preboot/${vg_uuid}/boot/*/System/Library/Caches/com.apple.kernelcaches/kernelcache
"

# Fallback: search all Preboot directories for any kernelcache
KC_CANDIDATES="${KC_CANDIDATES}
/System/Volumes/Preboot/*/restore/kernelcache.release.*
/Volumes/Preboot/*/restore/kernelcache.release.*
"

echo "Searching for Apple kernelcache..."
for candidate in $KC_CANDIDATES; do
  for expanded in $candidate; do
    if [ -f "$expanded" ] && [ -s "$expanded" ]; then
      KC_SIZE=$(stat -f%z "$expanded" 2>/dev/null || echo "0")
      # Kernelcache is typically 25-40 MB. m1n1 is ~1 MB.
      # Use size to distinguish from m1n1 and other small binaries.
      KC_TYPE=$(file "$expanded" 2>/dev/null || echo "")
      if [ "$KC_SIZE" -gt 10000000 ] 2>/dev/null; then
        # Large file — almost certainly an IMG4 kernelcache
        echo "  found (by size: $KC_SIZE bytes): $expanded"
        KERNELCACHE_SRC="$expanded"
        break 2
      elif echo "$KC_TYPE" | grep -qi "img4\|img4p"; then
        echo "  found (by type: IMG4): $expanded"
        KERNELCACHE_SRC="$expanded"
        break 2
      else
        echo "  skipping (not kernelcache: ${KC_SIZE} bytes, ${KC_TYPE})" >&2
      fi
    fi
  done
done

if [ -n "$KERNELCACHE_SRC" ]; then
  echo "Apple kernelcache found: $KERNELCACHE_SRC ($(du -sh "$KERNELCACHE_SRC" | awk '{print $1}'))"
  steps_done="${steps_done}kernelcache-found "
else
  # CRITICAL: No kernelcache = no 1TR boot. Do NOT fall back to m1n1.
  # m1n1 is unsigned and will be rejected by iBoot with Full Security,
  # causing the exact "select Cidre → reboot to macOS" symptom.
  echo "ERROR: Apple kernelcache not found anywhere."
  echo "Checked paths:"
  for candidate in $KC_CANDIDATES; do
    for expanded in $candidate; do
      echo "  $expanded $( [ -f "$expanded" ] && echo "(EXISTS)" || echo "(missing)")"
    done
  done | sort -u
  echo ""
  echo "The kernelcache (Apple-signed IMG4) is REQUIRED for the first 1TR boot."
  echo "Without it, iBoot will reject any unsigned bootloader with Full Security."
  echo ""
  echo "To fix: ensure the macOS restore bundle is accessible at"
  echo "  /System/Volumes/Preboot/<macOS-VG-UUID>/restore/"
  echo "which contains kernelcache.release.* (an Apple-signed IMG4 file)."
  steps_failed="${steps_failed}kernelcache(missing — CRITICAL: 1TR boot requires Apple-signed IMG4 kernelcache. m1n1 cannot be used for first boot.) "
fi


if [ -n "$M1N1_SRC" ]; then
  echo "m1n1 found: $M1N1_SRC ($(du -sh "$M1N1_SRC" | awk '{print $1}'))"
  steps_done="${steps_done}m1n1-found "
else
  echo "WARNING: m1n1 not found. Linux boot will not be possible after step2."
  steps_failed="${steps_failed}m1n1(missing — needed for Linux boot after Reduced Security) "
fi
steps_done="${steps_done}boot-files-scanned "

# ── Phase 4: Copy restore bundle from macOS ──────────────────────────
echo "[4/6] Copying restore bundle..."
if [ -n "$preboot_mount" ] && [ -n "$vg_uuid" ]; then
  # MACOS_VGID was dynamically detected in Phase 3. Fall back to
  # scanning if detection failed.
  if [ -z "$MACOS_VGID" ]; then
    MACOS_VGID="$(ls -d /System/Volumes/Preboot/*/restore 2>/dev/null | head -1 | xargs dirname 2>/dev/null | xargs basename 2>/dev/null || echo "")"
  fi
  SRC_RESTORE="/System/Volumes/Preboot/${MACOS_VGID}/restore"
  DST_DIR="${preboot_mount}/${vg_uuid}"

  if [ -d "$SRC_RESTORE" ]; then
    mkdir -p "$DST_DIR"
    # Copy restore bundle (rsync needs admin for some files; try direct cp first)
    if cp -R "$SRC_RESTORE" "$DST_DIR/restore" 2>/dev/null; then
      steps_done="${steps_done}restore-bundle-copied "
    else
      # Fall back to admin
      if run_admin "cp -R ${SRC_RESTORE} ${DST_DIR}/restore" >/dev/null 2>&1; then
        steps_done="${steps_done}restore-bundle-copied(admin) "
      else
        steps_failed="${steps_failed}restore-bundle-copy "
      fi
    fi
  else
    steps_failed="${steps_failed}macos-restore-not-found "
  fi

  # Asahi-alarm reference: stub.py install_files()
  # Preboot root-level boot.efi MUST be the Apple-signed kernelcache (IMG4)
  # for the firmware to boot into 1TR with Full Security.
  # m1n1 is saved as boot.efi.m1n1 — step2 restores it after bputil -g.
  mkdir -p "$DST_DIR/System/Library/CoreServices"

  # Copy SystemVersion.plist from restore bundle (Apple's real one)
  if [ -f "$DST_DIR/restore/SystemVersion.plist" ]; then
    cp "$DST_DIR/restore/SystemVersion.plist" "$DST_DIR/System/Library/CoreServices/" 2>/dev/null || true
  elif [ -f "$system_mount/System/Library/CoreServices/SystemVersion.plist" ]; then
    cp "$system_mount/System/Library/CoreServices/SystemVersion.plist" "$DST_DIR/System/Library/CoreServices/" 2>/dev/null || true
  fi

  # Asahi-alarm: boot.efi = Apple kernelcache (IMG4) for 1TR boot
  # This is the ONLY file the firmware will load with Full Security.
  if [ -n "$KERNELCACHE_SRC" ] && [ -f "$KERNELCACHE_SRC" ]; then
    cp "$KERNELCACHE_SRC" "$DST_DIR/System/Library/CoreServices/boot.efi" 2>/dev/null || \
      run_admin "cp ${KERNELCACHE_SRC} ${DST_DIR}/System/Library/CoreServices/boot.efi" >/dev/null 2>&1 || true
    run_admin "chmod 755 ${DST_DIR}/System/Library/CoreServices/boot.efi" >/dev/null 2>&1 || true
    echo "Preboot boot.efi = Apple kernelcache (for 1TR boot)"
    steps_done="${steps_done}preboot-boot.efi(kernelcache) "
    else
      # CRITICAL: NEVER fall back to m1n1 for boot.efi during first boot.
      # m1n1 is unsigned; iBoot will reject it with Full Security → reboot
      # back to macOS (the exact bug being fixed here).
      # If kernelcache is missing, the 1TR boot cannot work. Fail loudly.
      echo "ERROR: Cannot create boot.efi — no Apple kernelcache found."
      echo "  An unsigned bootloader (m1n1) cannot be used for the FIRST boot."
      echo "  iBoot requires an Apple-signed IMG4 kernelcache with Full Security."
      steps_failed="${steps_failed}preboot-boot.efi-no-kernelcache "
    fi

  # Save m1n1 backup for step2 restoration after bputil -g
  if [ -n "$M1N1_SRC" ] && [ -f "$M1N1_SRC" ]; then
    cp "$M1N1_SRC" "$DST_DIR/System/Library/CoreServices/boot.efi.m1n1" 2>/dev/null || \
      run_admin "cp ${M1N1_SRC} ${DST_DIR}/System/Library/CoreServices/boot.efi.m1n1" >/dev/null 2>&1 || true
    steps_done="${steps_done}preboot-m1n1-backup "
  fi

  # ── Copy Bootability directory (required for 1TR boot) ────────────────
  # BootabilityBrain.framework and Bootability.trustcache are REQUIRED
  # for iBoot to complete the 1TR auto-setup flow. Without these,
  # selecting Cidre from the boot picker results in a reboot loop.
  if [ -d "$SRC_RESTORE/Bootability" ]; then
    rm -rf "$DST_DIR/Bootability" 2>/dev/null || true
    if cp -R "$SRC_RESTORE/Bootability" "$DST_DIR/Bootability" 2>/dev/null; then
      steps_done="${steps_done}bootability-copied "
      echo "Bootability: copied (BootabilityBrain.framework + trustcache)"
    else
      run_admin "cp -R ${SRC_RESTORE}/Bootability ${DST_DIR}/Bootability" >/dev/null 2>&1 && {
        steps_done="${steps_done}bootability-copied(admin) "
        echo "Bootability: copied via admin"
      } || steps_failed="${steps_failed}bootability-copy "
    fi
  else
    echo "WARNING: Bootability directory not found in restore bundle."
    echo "1TR auto-setup may fail without BootabilityBrain.framework."
    steps_failed="${steps_failed}bootability(missing) "
  fi

  # ── Copy IM4M manifest files (required for signature verification) ────
  # iBoot uses apticket.*.im4m to verify the kernelcache IMG4 signature.
  for im4m in "$SRC_RESTORE"/apticket.*.im4m; do
    if [ -f "$im4m" ]; then
      cp "$im4m" "$DST_DIR/" 2>/dev/null || \
        run_admin "cp ${im4m} ${DST_DIR}/" >/dev/null 2>&1 || true
      steps_done="${steps_done}im4m-copied "
      echo "IM4M: $(basename "$im4m") copied"
    fi
  done
fi

# ── Copy AdminUserRecoveryInfo.plist (CRITICAL for recoveryOS auth) ─
# Asahi-alarm reference: stub.py copy_admin_users()
#   https://github.com/asahi-alarm/asahi-alarm-installer
#
# RecoveryOS needs AdminUserRecoveryInfo.plist on the boot volume's
# Preboot to authenticate the user when running step2.sh.
# Without this file, bputil and kmutil in recoveryOS will fail
# because they can't verify the admin credentials.
#
# Copy from macOS Preboot → Cidre Preboot, then set schg flag
# to prevent macOS <12.0 bootability code from clobbering it.
ADMIN_USERS_SRC="/System/Volumes/Preboot/${MACOS_VGID}/var/db/AdminUserRecoveryInfo.plist"
ADMIN_USERS_DST="${preboot_mount}/${vg_uuid}/var/db"
if [ -f "$ADMIN_USERS_SRC" ] && [ -d "${preboot_mount}/${vg_uuid}" ]; then
  mkdir -p "$ADMIN_USERS_DST"
  [ -f "$ADMIN_USERS_DST/AdminUserRecoveryInfo.plist" ] && \
    chflags noschg "$ADMIN_USERS_DST/AdminUserRecoveryInfo.plist" 2>/dev/null || true
  if cp "$ADMIN_USERS_SRC" "$ADMIN_USERS_DST/AdminUserRecoveryInfo.plist" 2>/dev/null; then
    chflags schg "$ADMIN_USERS_DST/AdminUserRecoveryInfo.plist" 2>/dev/null || true
    steps_done="${steps_done}admin-users-copied "
    echo "AdminUserRecoveryInfo.plist: copied to Cidre Preboot"
  else
    if run_admin "cp ${ADMIN_USERS_SRC} ${ADMIN_USERS_DST}/AdminUserRecoveryInfo.plist && chflags schg ${ADMIN_USERS_DST}/AdminUserRecoveryInfo.plist" >/dev/null 2>&1; then
      steps_done="${steps_done}admin-users-copied(admin) "
      echo "AdminUserRecoveryInfo.plist: copied via admin"
    else
      echo "WARNING: Could not copy AdminUserRecoveryInfo.plist"
      steps_failed="${steps_failed}admin-users-copy "
    fi
  fi
else
  echo "WARNING: AdminUserRecoveryInfo.plist not found at macOS Preboot."
  echo "RecoveryOS authentication may fail without this file."
  steps_failed="${steps_failed}admin-users(missing) "
fi

# ── Phase 5: Bless (set Cidre as default boot for 1TR flow) ──────────
# Asahi-alarm reference: src/main.py bless() and step2()
#   https://github.com/asahi-alarm/asahi-alarm-installer
#
# The ONLY way to make a custom OS visible on Apple Silicon is the 1TR flow:
#   1. Bless the stub volume as DEFAULT boot (temporarily)
#   2. Reboot → firmware boots the stub's recoveryOS (1TR mode)
#   3. From 1TR, bputil -g WORKS (no "AP boot mode" error!)
#   4. step2 script: bputil → m1n1 → bless macOS back as default → reboot
#
# bputil -g from macOS ALWAYS fails with "AP boot mode (11)" on modern macOS.
# This is by Apple's design. RecoveryOS (1TR) is the only supported path.
echo "[5/6] Setting Cidre as default boot for 1TR setup..."

BLESS_CIDRE="/usr/sbin/bless --setBoot --device /dev/${system_volume}"
BLESS_MACOS="/usr/sbin/bless --setBoot --device /dev/disk4s1"

# Asahi Linux reference implementation approach:
# bless accepts --user and --stdinpass directly (no osascript needed).
# Password is piped via stdin. This is the SAME approach used by
# the official Asahi Linux installer (src/main.py: bless()).
run_bless() {
  local bless_cmd="$1"
  if [ -n "$owner_user" ] && [ -n "$owner_password" ]; then
    printf '%s' "$owner_password" | $bless_cmd --user "$owner_user" --stdinpass 2>&1
    return $?
  else
    $bless_cmd 2>&1
    return $?
  fi
}

if [ -n "$system_volume" ]; then
  if run_bless "$BLESS_CIDRE"; then
    steps_done="${steps_done}bless-cidre-ok "
    # CRITICAL: Do NOT restore macOS as default here.
    # Cidre MUST be the default boot so the firmware boots into its 1TR
    # recoveryOS on next restart. This is the exact same approach as the
    # Asahi Linux installer (see src/main.py step2()).
    #
    # Safety: The Cidre boot.efi is an Apple-signed macOS kernelcache.
    # If step2 fails, the user can still hold the power button and
    # select macOS from the boot picker. macOS is never at risk.
    one_tr_ready="true"
    echo "Cidre set as default boot. 1TR flow will handle Reduced Security."
  else
    steps_failed="${steps_failed}bless-failed(owner-auth-required) "
    # Bless failed — ensure macOS remains default for safety
    run_bless "$BLESS_MACOS" || {
      run_admin "$BLESS_MACOS" >/dev/null 2>&1 || true
    }
    steps_done="${steps_done}bless-macos-restored "
    one_tr_ready="false"
  fi

  # ── Phase 6: bputil — Note: always deferred to 1TR ──
  # Asahi reference: bputil -g from macOS → "AP boot mode (11)".
  # This is expected. bputil only works from recoveryOS (1TR mode).
  # The step2 script handles this during the 1TR boot.
  echo "[6/6] LocalPolicy will be created during 1TR boot (step2)..."
  if [ -n "$vg_uuid" ]; then
    if [ "$one_tr_ready" = "true" ]; then
      steps_done="${steps_done}bputil-deferred-to-1TR "
    else
      steps_done="${steps_done}bputil-deferred(owner-credentials-required) "
    fi
  fi
fi

# ── Phase 7: Set up Auto-Run via IAPhysicalMedia ───────────────────
echo "[7/7] Setting up auto-run step2 (Asahi-style 1TR flow)..."
step2_ready="false"

# Step 7a: FIRST copy recoveryOS from macOS Recovery while it's accessible
# Mount macOS Recovery to get arm64eBaseSystem.dmg
MACOS_REC_MOUNT=""
REC_IMG_SRC=""

# macOS Recovery might already be at /Volumes/Recovery
if [ -f "/Volumes/Recovery/${MACOS_VGID}/usr/standalone/firmware/arm64eBaseSystem.dmg" ]; then
  REC_IMG_SRC="/Volumes/Recovery/${MACOS_VGID}/usr/standalone/firmware/arm64eBaseSystem.dmg"
elif diskutil mount disk4s3 2>/dev/null; then
  REC_IMG_SRC="/Volumes/Recovery/${MACOS_VGID}/usr/standalone/firmware/arm64eBaseSystem.dmg"
fi

# Copy arm64eBaseSystem.dmg to a staging location on Cidre Data volume (writable)
REC_IMG_STAGING=""
if [ -f "$REC_IMG_SRC" ] && [ -d "/Volumes/Cidre" ]; then
  mkdir -p "/Volumes/Cidre/cidre/recovery"
  if cp "$REC_IMG_SRC" "/Volumes/Cidre/cidre/recovery/arm64eBaseSystem.dmg" 2>/dev/null; then
    REC_IMG_STAGING="/Volumes/Cidre/cidre/recovery/arm64eBaseSystem.dmg"
    steps_done="${steps_done}recovery-os-staged "
  fi
fi

# Step 7b: Set up Recovery volume with the recoveryOS image
# Dynamically detect Cidre Recovery volume (role R) from the volume group container.
# Priority: (1) rec_device from Phase 2 VG creation, (2) diskutil apfs list scan,
# (3) fallback scan of common recovery device names.
REC_DEVICE=""
if [ -n "$rec_device" ] && diskutil info "$rec_device" >/dev/null 2>&1; then
  REC_DEVICE="$rec_device"
fi
if [ -z "$REC_DEVICE" ] && [ -n "$container" ]; then
  # Find Recovery role volume (role R) in this container
  REC_DEVICE="$(diskutil apfs list -plist "$container" 2>/dev/null | python3 -c "
import plistlib, sys
d = plistlib.loads(sys.stdin.buffer.read())
for c in d.get('Containers', []):
    for v in c.get('Volumes', []):
        if 'R' in (v.get('Roles', []) or []):
            print(v.get('DeviceIdentifier', ''))
            sys.exit(0)
print('')
" 2>/dev/null || echo "")"
fi
# Last resort: scan common recovery device names
if [ -z "$REC_DEVICE" ]; then
  for dev in disk3s3 disk4s3 disk5s3; do
    if diskutil info "$dev" >/dev/null 2>&1; then
      dev_info="$(diskutil info -plist "$dev" 2>/dev/null | python3 -c 'import plistlib,sys; d=plistlib.loads(sys.stdin.buffer.read()); print(d.get("APFSContainerReference",""))' 2>/dev/null || echo "")"
      if [ "$dev_info" = "$container" ]; then
        REC_DEVICE="$dev"
        break
      fi
    fi
  done
fi

if [ -n "$REC_DEVICE" ]; then
  diskutil unmount /Volumes/Recovery 2>/dev/null || true
  sleep 1
  REC_MOUNT=""
  if diskutil mount "$REC_DEVICE" 2>/dev/null; then
    REC_MOUNT="/Volumes/Recovery"
  fi

  if [ -n "$REC_MOUNT" ] && [ -d "$REC_MOUNT" ]; then
    mkdir -p "$REC_MOUNT/$vg_uuid/usr/standalone/firmware"
    mkdir -p "$REC_MOUNT/$vg_uuid/boot"

    # Copy recoveryOS from staging or source
    if [ -f "$REC_IMG_STAGING" ]; then
      cp "$REC_IMG_STAGING" "$REC_MOUNT/$vg_uuid/usr/standalone/firmware/arm64eBaseSystem.dmg" 2>/dev/null && {
        steps_done="${steps_done}recovery-os-copied "
        step2_ready="true"
      } || steps_done="${steps_done}recovery-os-copy-failed "
    fi

    # Copy boot structure from Cidre Preboot
    if [ -n "$preboot_mount" ] && [ -d "$preboot_mount/$vg_uuid/boot" ]; then
      rm -rf "$REC_MOUNT/$vg_uuid/boot" 2>/dev/null || true
      cp -R "$preboot_mount/$vg_uuid/boot/" "$REC_MOUNT/$vg_uuid/boot/" 2>/dev/null || true
    fi
  fi
fi

# Copy step2 script to Cidre Data volume (writable, accessible from Recovery/step2)
STEP2_SRC="$SCRIPT_DIR/cidre-app-recovery-step2"
if [ -f "$STEP2_SRC" ] && [ -d "/Volumes/Cidre/cidre" ]; then
  cp "$STEP2_SRC" "/Volumes/Cidre/cidre/step2.sh" 2>/dev/null && {
    chmod +x "/Volumes/Cidre/cidre/step2.sh" 2>/dev/null || true
  } || true
fi

# Stage m1n1.bin (raw ARM64 binary) to Cidre Data volume for step2.
# step2 needs the raw binary for kmutil configure-boot --raw.
# Search companion .bin alongside M1N1_SRC, then libexec/, then m1n1/build/.
M1N1_BIN_SRC=""
if [ -n "$M1N1_SRC" ]; then
  M1N1_DIR_SRC="$(dirname "$M1N1_SRC")"
  if [ -f "$M1N1_DIR_SRC/m1n1.bin" ]; then
    M1N1_BIN_SRC="$M1N1_DIR_SRC/m1n1.bin"
  fi
fi
if [ -z "$M1N1_BIN_SRC" ] && [ -f "$REPO_ROOT/libexec/m1n1.bin" ]; then
  M1N1_BIN_SRC="$REPO_ROOT/libexec/m1n1.bin"
fi
if [ -z "$M1N1_BIN_SRC" ] && [ -f "$REPO_ROOT/m1n1/build/m1n1.bin" ]; then
  M1N1_BIN_SRC="$REPO_ROOT/m1n1/build/m1n1.bin"
fi
if [ -z "$M1N1_BIN_SRC" ] && [ -f "/Volumes/Cidre/boot/m1n1.bin" ]; then
  M1N1_BIN_SRC="/Volumes/Cidre/boot/m1n1.bin"
fi
if [ -n "$M1N1_BIN_SRC" ] && [ -d "/Volumes/Cidre/cidre" ]; then
  if cp "$M1N1_BIN_SRC" "/Volumes/Cidre/cidre/m1n1.bin" 2>/dev/null; then
    chmod 755 "/Volumes/Cidre/cidre/m1n1.bin" 2>/dev/null || true
    steps_done="${steps_done}m1n1-bin-staged-to-data "
  fi
fi

# Re-mount macOS Recovery for restore bundle access (if needed later)
diskutil mount disk4s3 2>/dev/null || true

# Step 7c: Write .IAPhysicalMedia + Finish Installation.app to System volume
# System role volumes are read-only; temporarily remove role, write, restore
if [ -n "$system_mount" ] && [ -n "$system_volume" ]; then

  SYS_VOL="$system_volume"
  SYS_MOUNT="$system_mount"
  FINISH_APP_SRC="$REPO_ROOT/resources/Finish Installation.app"
  IAPHYSICAL_MEDIA_PLIST="$SYS_MOUNT/.IAPhysicalMedia"

  # Unmount System volume first
  diskutil unmount "$SYS_VOL" 2>/dev/null || true
  sleep 1

  # Remove System role temporarily (makes volume writable)
  role_removed="false"
  if run_admin "/usr/sbin/diskutil apfs changeVolumeRole ${SYS_VOL} clear" 2>&1; then
    role_removed="true"
  else
    # Older macOS versions may not support 'clear'; try bare invocation
    if run_admin "/usr/sbin/diskutil apfs changeVolumeRole ${SYS_VOL}" 2>&1; then
      role_removed="true"
    fi
  fi

  # Remount (now read-write since System role is removed)
  diskutil mount "$SYS_VOL" 2>/dev/null || true
  sleep 1

  # Refresh mount point
  SYS_MOUNT="$(diskutil info -plist "$SYS_VOL" 2>/dev/null | python3 -c 'import plistlib,sys; print(plistlib.loads(sys.stdin.buffer.read()).get("MountPoint",""))' 2>/dev/null || echo "")"

  if [ -n "$SYS_MOUNT" ] && [ -d "$SYS_MOUNT" ]; then
    # Write .IAPhysicalMedia marker plist (Asahi ALARM reference format)
    # Reference: https://github.com/asahi-alarm/asahi-alarm-installer
    #   src/step2/IAPhysicalMedia.plist
    # Keys: AppName (app to launch in recovery), ProductBuildVersion,
    #        ProductVersion (OS version for compatibility checks)
    # These EXACT keys are required for recoveryOS to recognize and
    # auto-launch Finish Installation.app during the 1TR boot flow.
    cat > "$SYS_MOUNT/.IAPhysicalMedia" << 'IAPEOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>AppName</key>
	<string>Finish Installation.app</string>
	<key>ProductBuildVersion</key>
	<string>00A191</string>
	<key>ProductVersion</key>
	<string>12.1</string>
</dict>
</plist>
IAPEOF
    chmod 644 "$SYS_MOUNT/.IAPhysicalMedia" 2>/dev/null || true

    # Copy Finish Installation.app
    if [ -d "$FINISH_APP_SRC" ]; then
      rm -rf "$SYS_MOUNT/Finish Installation.app" 2>/dev/null || true
      cp -R "$FINISH_APP_SRC" "$SYS_MOUNT/Finish Installation.app" 2>/dev/null && {
        chmod -R 755 "$SYS_MOUNT/Finish Installation.app" 2>/dev/null || true
        steps_done="${steps_done}finish-app-staged "
      } || steps_done="${steps_done}finish-app-copy-failed "
    fi

    # ── Stage boot.bin (raw ARM64 m1n1) for step2 ──────────────────
    # Asahi-alarm reference: step2.sh expects boot.bin in the same
    # directory as step2.sh (Finish Installation.app/Contents/Resources/).
    # kmutil configure-boot -c boot.bin --raw --entry-point 2048 ...
    #   https://github.com/asahi-alarm/asahi-alarm-installer
    FINISH_RESOURCES="$SYS_MOUNT/Finish Installation.app/Contents/Resources"
    mkdir -p "$FINISH_RESOURCES"
    M1N1_BIN_FOR_STEP2=""
    if [ -n "$M1N1_BIN_SRC" ] && [ -f "$M1N1_BIN_SRC" ]; then
      M1N1_BIN_FOR_STEP2="$M1N1_BIN_SRC"
    elif [ -f "$REPO_ROOT/libexec/m1n1.bin" ]; then
      M1N1_BIN_FOR_STEP2="$REPO_ROOT/libexec/m1n1.bin"
    elif [ -f "$REPO_ROOT/m1n1/build/m1n1.bin" ]; then
      M1N1_BIN_FOR_STEP2="$REPO_ROOT/m1n1/build/m1n1.bin"
    fi
    if [ -n "$M1N1_BIN_FOR_STEP2" ] && [ -f "$M1N1_BIN_FOR_STEP2" ]; then
      cp "$M1N1_BIN_FOR_STEP2" "$FINISH_RESOURCES/boot.bin" 2>/dev/null && {
        chmod 755 "$FINISH_RESOURCES/boot.bin" 2>/dev/null || true
        steps_done="${steps_done}boot.bin-staged "
        echo "boot.bin: staged to Finish Installation.app/Contents/Resources/"
      } || steps_done="${steps_done}boot.bin-copy-failed "
    else
      echo "WARNING: m1n1.bin not found. boot.bin will not be staged."
      steps_failed="${steps_failed}boot.bin(missing) "
    fi

    # Also copy step2.sh to Finish Installation.app Resources
    # so it matches Asahi ALARM's layout exactly.
    STEP2_SRC="$SCRIPT_DIR/cidre-app-recovery-step2"
    if [ -f "$STEP2_SRC" ]; then
      cp "$STEP2_SRC" "$FINISH_RESOURCES/step2.sh" 2>/dev/null && {
        chmod +x "$FINISH_RESOURCES/step2.sh" 2>/dev/null || true
        steps_done="${steps_done}step2.sh-in-resources "
      } || true
    fi

    # Copy step2 script to System volume directly (fallback path)
    if [ -f "$STEP2_SRC" ]; then
      cp "$STEP2_SRC" "$SYS_MOUNT/cidre-step2.sh" 2>/dev/null && {
        chmod +x "$SYS_MOUNT/cidre-step2.sh" 2>/dev/null || true
      }
    fi

    # ── Write boot files during this writable window ────────────────────
    # Asahi-alarm reference: stub.py install_files()
    # System volume boot.efi MUST be Apple-signed kernelcache (IMG4) for
    # the firmware to boot into 1TR with Full Security. m1n1 is saved as
    # boot.efi.m1n1 — step2 restores it after bputil -g sets Reduced Security.
    #   https://github.com/asahi-alarm/asahi-alarm-installer
    mkdir -p "$SYS_MOUNT/System/Library/CoreServices"

    # Copy Apple SystemVersion.plist from Preboot restore bundle
    DST_RESTORE="${preboot_mount}/${vg_uuid}/restore"
    if [ -f "$DST_RESTORE/SystemVersion.plist" ]; then
      cp "$DST_RESTORE/SystemVersion.plist" "$SYS_MOUNT/System/Library/CoreServices/SystemVersion.plist" 2>/dev/null || true
    elif [ ! -f "$SYS_MOUNT/System/Library/CoreServices/SystemVersion.plist" ]; then
      cat > "$SYS_MOUNT/System/Library/CoreServices/SystemVersion.plist" << 'SVPEOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>CFBundleIdentifier</key><string>com.apple.SystemVersion</string>
<key>ProductBuildVersion</key><string>00A191</string>
<key>ProductCopyright</key><string>Cidre Project</string>
<key>ProductName</key><string>Cidre</string>
<key>ProductUserVisibleVersion</key><string>12.1 (stub)</string>
<key>ProductVersion</key><string>12.1</string>
</dict></plist>
SVPEOF
    fi

    # Write Apple kernelcache as boot.efi (for 1TR boot with Full Security)
    if [ -n "$KERNELCACHE_SRC" ] && [ -f "$KERNELCACHE_SRC" ]; then
      cp "$KERNELCACHE_SRC" "$SYS_MOUNT/System/Library/CoreServices/boot.efi" 2>/dev/null || true
      chmod 755 "$SYS_MOUNT/System/Library/CoreServices/boot.efi" 2>/dev/null || true
      echo "System volume boot.efi = Apple kernelcache (for 1TR boot)"
      steps_done="${steps_done}boot.efi(kernelcache) "
    else
      # CRITICAL: NEVER fall back to m1n1 for boot.efi during first boot.
      # m1n1 is unsigned; iBoot will reject it with Full Security → reboot
      # back to macOS (the exact bug being fixed here).
      echo "ERROR: Cannot create System boot.efi — no Apple kernelcache found."
      echo "  An unsigned bootloader (m1n1) cannot be used for the FIRST boot."
      echo "  iBoot requires an Apple-signed IMG4 kernelcache with Full Security."
      steps_failed="${steps_failed}boot.efi-no-kernelcache "
    fi

    # Save m1n1 backup for step2 restoration after bputil -g
    if [ -n "$M1N1_SRC" ] && [ -f "$M1N1_SRC" ]; then
      cp "$M1N1_SRC" "$SYS_MOUNT/System/Library/CoreServices/boot.efi.m1n1" 2>/dev/null || true
      chmod 755 "$SYS_MOUNT/System/Library/CoreServices/boot.efi.m1n1" 2>/dev/null || true
      steps_done="${steps_done}m1n1-backup "
    fi

    # ── Copy PlatformSupport.plist (required for iBoot recognition) ──────
    # iBoot checks PlatformSupport.plist to verify this Mac model is
    # supported by the OS. Without it, boot may fail → reboot loop.
    if [ -f "/System/Library/CoreServices/PlatformSupport.plist" ]; then
      cp "/System/Library/CoreServices/PlatformSupport.plist" \
         "$SYS_MOUNT/System/Library/CoreServices/PlatformSupport.plist" 2>/dev/null || true
      steps_done="${steps_done}platform-support "
      echo "PlatformSupport.plist: copied"
    else
      echo "WARNING: macOS PlatformSupport.plist not found."
      steps_failed="${steps_failed}platform-support(missing) "
    fi

    # ── Deploy bootcaches.plist (required for iBoot to find boot.efi) ────
    # Asahi-alarm reference: stub.py install_files() extracts bootcaches.plist
    # from the IPSW to BOTH the System volume AND the Preboot restore bundle.
    # The IPSW version has correct paths; macOS /usr/standalone/bootcaches.plist
    # has paths hardcoded for the macOS VG UUID — copying it to Cidre causes iBoot
    # to look for kernelcache at the wrong path → boot failure.
    #
    # Strategy: use the restore bundle bootcaches.plist (correct for this kernelcache),
    # or skip deployment (iBoot falls back to System/Library/CoreServices/boot.efi).
    DST_RESTORE="${preboot_mount}/${vg_uuid}/restore"
    if [ -f "$DST_RESTORE/bootcaches.plist" ]; then
      mkdir -p "$SYS_MOUNT/usr/standalone"
      cp "$DST_RESTORE/bootcaches.plist" \
         "$SYS_MOUNT/usr/standalone/bootcaches.plist" 2>/dev/null || true
      steps_done="${steps_done}bootcaches-deployed(from-restore-bundle) "
      echo "bootcaches.plist: deployed from restore bundle"
    elif [ -f "$DST_RESTORE/usr/standalone/bootcaches.plist" ]; then
      mkdir -p "$SYS_MOUNT/usr/standalone"
      cp "$DST_RESTORE/usr/standalone/bootcaches.plist" \
         "$SYS_MOUNT/usr/standalone/bootcaches.plist" 2>/dev/null || true
      steps_done="${steps_done}bootcaches-deployed(from-restore-usr) "
      echo "bootcaches.plist: deployed from restore bundle usr/standalone/"
    else
      # NOT copying macOS /usr/standalone/bootcaches.plist — it has wrong VG UUID paths.
      # iBoot will fall back to directly loading System/Library/CoreServices/boot.efi.
      echo "NOTE: bootcaches.plist not in restore bundle — iBoot will use boot.efi directly."
      steps_done="${steps_done}bootcaches-skipped(iBoot-will-use-boot.efi-directly) "
    fi

    # ── Create restore bundle symlink (Asahi ALARM reference) ──────
    # Asahi-alarm stub.py: creates symlink from System volume to Preboot
    # restore bundle. This is REQUIRED for bootability code to find the
    # apticket and other files in the restore bundle.
    # Without this, bootability puts the apticket in the wrong volume.
    DST_RESTORE="${preboot_mount}/${vg_uuid}/restore"
    RESTORE_BUNDLE_PATH=""
    if [ -f "$DST_RESTORE/bootcaches.plist" ]; then
      RESTORE_BUNDLE_PATH="$(python3 -c "
import plistlib
bc = plistlib.load(open('${DST_RESTORE}/bootcaches.plist', 'rb'))
print(bc.get('bless2', {}).get('RestoreBundlePath', ''))
" 2>/dev/null || echo "")"
    fi
    if [ -z "$RESTORE_BUNDLE_PATH" ] && [ -f "$SRC_RESTORE/bootcaches.plist" ]; then
      RESTORE_BUNDLE_PATH="$(python3 -c "
import plistlib
bc = plistlib.load(open('${SRC_RESTORE}/bootcaches.plist', 'rb'))
print(bc.get('bless2', {}).get('RestoreBundlePath', ''))
" 2>/dev/null || echo "")"
    fi
    if [ -n "$RESTORE_BUNDLE_PATH" ]; then
      SYS_RESTORE_LINK="$SYS_MOUNT/$RESTORE_BUNDLE_PATH"
      mkdir -p "$(dirname "$SYS_RESTORE_LINK")" 2>/dev/null || true
      [ -L "$SYS_RESTORE_LINK" ] && rm -f "$SYS_RESTORE_LINK" 2>/dev/null || true
      [ -e "$SYS_RESTORE_LINK" ] && rm -rf "$SYS_RESTORE_LINK" 2>/dev/null || true
      if ln -sf "$DST_RESTORE" "$SYS_RESTORE_LINK" 2>/dev/null; then
        steps_done="${steps_done}restore-symlink "
        echo "Restore symlink: $RESTORE_BUNDLE_PATH -> Preboot restore bundle"
      else
        echo "WARNING: Could not create restore bundle symlink"
      fi
    else
      echo "NOTE: Could not determine RestoreBundlePath from bootcaches.plist"
    fi

    # ── Set APFS bootable flag via fsctl (required for iBoot to boot) ────
    # Without APFS_BOOTABLE_SET, iBoot won't recognize the volume as
    # bootable even with SystemVersion.plist and boot.efi present.
    # This is the #1 cause of "appears in boot picker but reboot loops."
    echo "Setting APFS bootable flag..."
    if /usr/bin/python3 -c "
import ctypes
from ctypes import c_char_p, c_ulong, POINTER, c_int, CDLL, get_errno, byref

sysdll = CDLL('libSystem.B.dylib', use_errno=True)
func = sysdll.fsctl
func.restype = c_int
func.argtypes = (c_char_p, c_ulong, POINTER(c_int), c_uint)

path = '$SYS_MOUNT'

# Query current state
cmd = c_int(0)
err = func(path.encode(), 0xc0044a57, byref(cmd), 0)
print(f'  Current state: bootable={cmd.value}')

# Set bootable (cmd=1 means set bootable)
cmd = c_int(1)
err = func(path.encode(), 0xc0044a57, byref(cmd), 0)
if err == -1:
    errn = get_errno()
    print(f'  WARNING: fsctl SET failed, errno={errn}')
    if errn == 1:
        print(f'  (EPERM: volume may need to be writable)')
    elif errn == 30:
        print(f'  (EROFS: read-only file system)')
    raise SystemExit(1)

# Verify
cmd = c_int(0)
err = func(path.encode(), 0xc0044a57, byref(cmd), 0)
print(f'  Verified: bootable={cmd.value}')
if cmd.value != 1:
    print(f'  WARNING: bootable flag did not stick!')
    raise SystemExit(2)
print(f'  Bootable flag: set')
" 2>&1; then
      steps_done="${steps_done}fsctl-bootable "
      echo "  Bootable flag: OK"
    else
      echo "  WARNING: fsctl bootable flag could not be set"
      steps_failed="${steps_failed}fsctl-bootable "
    fi

    step2_ready="true"
  fi

  # Restore System role
  if [ "$role_removed" = "true" ]; then
    diskutil unmount "$SYS_VOL" 2>/dev/null || true
    sleep 1
    run_admin "/usr/sbin/diskutil apfs changeVolumeRole ${SYS_VOL} S" 2>&1 || true
    diskutil mount "$SYS_VOL" 2>/dev/null || true
    # Refresh system_mount
    system_mount="$(diskutil info -plist "$SYS_VOL" 2>/dev/null | python3 -c 'import plistlib,sys; print(plistlib.loads(sys.stdin.buffer.read()).get("MountPoint",""))' 2>/dev/null || echo "$system_mount")"
  fi
fi

# ── Final report ─────────────────────────────────────────────────────
# Determine 1TR flow status
# one_tr_ready: Cidre is default boot, will boot into 1TR on restart
# step2_ready: step2 script + IAPhysicalMedia + Finish Installation.app staged

if [ -z "$steps_failed" ]; then
  status="passed"; exit_code=0
  if [ "$one_tr_ready" = "true" ] && [ "$step2_ready" = "true" ]; then
    # Happy path: Cidre is default boot, 1TR will auto-complete setup
    security_mode="full"  # Until 1TR sets Reduced Security
    reduced_security_status="one-tr-pending"
    reduced_security_guide="Cidre setup will auto-complete on restart:
1. Save your work and close all apps
2. Restart your Mac (Apple menu → Restart)
3. Mac will automatically boot into Cidre setup (1TR mode)
4. Setup completes in ~1-2 minutes (you'll see progress on screen)
5. Mac restarts back to macOS
6. Done! To boot Cidre: hold power button → select Cidre"
    summary="Boot policy created (Asahi-style 1TR flow). Restart your Mac now — Cidre will auto-complete setup on next boot, then restart back to macOS."
  elif [ "$one_tr_ready" = "true" ]; then
    # Bless succeeded but step2 not fully staged
    security_mode="full"
    reduced_security_status="one-tr-manual-step2"
    reduced_security_guide="Cidre is set as default boot. On restart:
1. Mac will boot into Cidre recovery environment
2. Open Terminal (Utilities → Terminal)
3. Run: /Volumes/Cidre/cidre/step2.sh
4. Follow the prompts to complete setup"
    summary="Boot policy created. Restart your Mac → Cidre boots into recovery → run step2.sh to complete."
  elif [ "$step2_ready" = "true" ]; then
    # Step2 ready but bless didn't set Cidre as default (unusual)
    status="blocked"; exit_code=4
    security_mode="full"
    reduced_security_status="needs-default-boot"
    reduced_security_guide="Cidre must be set as default boot to trigger 1TR setup. Run:
bless --setBoot --device /dev/${system_volume} --user <your_user> --stdinpass
Then restart."
    summary="Boot policy partially created. Cidre must be set as default boot to continue."
  else
    status="blocked"; exit_code=4
    security_mode="unknown"
    reduced_security_status="manual-recovery-required"
    reduced_security_guide="To enable Reduced Security:
1. Shut down your Mac
2. Hold power button until 'Loading startup options' appears
3. Click Options (gear icon) → Utilities → Startup Security Utility
4. Select Cidre → Reduced Security → Restart"
    summary="Boot policy created but 1TR auto-setup not available. Use Startup Security Utility in Recovery to set Reduced Security."
  fi
else
  status="blocked"; exit_code=4
  security_mode="full"
  reduced_security_status="bless-failed"
  reduced_security_guide="Bless failed. To proceed:
1. Open Terminal in macOS
2. Run: bless --setBoot --device /dev/${system_volume} --user <your_user> --stdinpass
3. Enter your macOS password
4. Restart your Mac"
  summary="Boot policy creation incomplete: ${steps_failed}"
fi

python3 - "$json_mode" "$status" "$exit_code" "$summary" "$vg_uuid" "$system_volume" "$steps_done" "$steps_failed" "$one_tr_ready" "$security_mode" "$reduced_security_status" "$reduced_security_guide" "$step2_ready" <<'PY'
import json, sys
(json_mode, status, exit_code, summary, vg_uuid, system_volume,
 steps_done, steps_failed, one_tr_ready, security_mode,
 reduced_security_status, reduced_security_guide, step2_ready) = sys.argv[1:]
exit_code = int(exit_code); json_mode = json_mode == "true"
payload = {
    "schema_version": 1,
    "command": "cidre-app-boot-policy-create",
    "status": status, "summary": summary, "exit_code": exit_code,
    "volume_group_uuid": vg_uuid if vg_uuid else None,
    "system_volume": system_volume if system_volume else None,
    "steps_completed": steps_done.strip() if steps_done else None,
    "steps_failed": steps_failed.strip() if steps_failed else None,
    "one_tr_ready": one_tr_ready == "true",
    "security_mode": security_mode if security_mode else "unknown",
    "reduced_security_status": reduced_security_status if reduced_security_status else "unknown",
    "reduced_security_guide": reduced_security_guide if reduced_security_guide else None,
    "step2_ready": step2_ready == "true",
    "step2_command": "/Volumes/Cidre/cidre/step2.sh" if step2_ready == "true" else None,
}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(exit_code)
PY
