#!/usr/bin/env bash
# cidre-boot-failure-classify: Categories classifier for boot test failures
set -euo pipefail

result_json=""
logs_dir=""
output_file=""

usage() {
  cat <<EOF
Usage: cidre-boot-failure-classify [options]

Classify boot failures based on result codes and logs.

Options:
  --result <file>   Path to result.json
  --logs <dir>      Path to logs directory
  --output <file>   Output markdown file path
  --help            Show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --result) result_json="$2"; shift 2 ;;
    --logs) logs_dir="$2"; shift 2 ;;
    --output) output_file="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if [ -z "$result_json" ] || [ -z "$output_file" ]; then
  echo "ERROR: --result and --output are required" >&2
  exit 1
fi

status="unknown"
stage="unknown"
reason=""

if [ -f "$result_json" ] && command -v python3 >/dev/null 2>&1; then
  status=$(python3 -c "import json; d=json.load(open('$result_json')); print(d.get('status', 'unknown'))")
  stage=$(python3 -c "import json; d=json.load(open('$result_json')); print(d.get('stage', 'unknown'))")
  reason=$(python3 -c "import json; d=json.load(open('$result_json')); print(d.get('reason', ''))")
fi

mkdir -p "$(dirname "$output_file")"

category="unknown"
case "$stage" in
  preflight|image-*) category="artifact" ;;
  bootloader) category="bootloader" ;;
  kernel) category="kernel" ;;
  systemd) category="systemd" ;;
  firstboot-service|oobe) category="firstboot" ;;
  handoff|user-phase) category="handoff" ;;
esac

# Fine-grained firstboot failure classification
if [ -n "$logs_dir" ] && [ -d "$logs_dir" ]; then
  diagnose_file="$logs_dir/firstboot-diagnose.txt"
  journal_file="$logs_dir/firstboot-service-journal.txt"
  unit_file="$logs_dir/firstboot-service-unit.txt"

  if [ ! -f "$unit_file" ] || ! grep -q "Description=" "$unit_file" 2>/dev/null; then
    category="firstboot-service-missing"
  elif [ -f "$diagnose_file" ]; then
    if grep -q "Marker 'started': absent" "$diagnose_file"; then
      category="firstboot-service-not-started"
    elif grep -q "Marker 'failed': present" "$diagnose_file"; then
      category="firstboot-service-failed"
    elif grep -q "Marker 'completed': absent" "$diagnose_file" && grep -q "Marker 'failed': absent" "$diagnose_file"; then
      category="firstboot-state-incomplete"
    elif grep -q "Marker 'completed': present" "$diagnose_file"; then
      if [ ! -f "$logs_dir/firstboot-report.md" ] || grep -q "No handoff" "$logs_dir/firstboot-report.md"; then
        category="handoff-missing"
      else
        # Completed but failed boot run indicates repeated firstboot run
        category="firstboot-repeated"
      fi
    fi
  fi

  if [ -f "$diagnose_file" ] && (grep -qi "resume" "$diagnose_file" || grep -qi "seed" "$diagnose_file"); then
    # Double check if resume/seed missing is the root cause
    if grep -qi "missing" "$diagnose_file" || grep -qi "failed" "$diagnose_file"; then
      category="resume-state-missing"
    fi
  fi
fi

cat > "$output_file" <<EOF
# Boot Failure Classification

Category: $category
Stage: $stage
Status: $status

Evidence:
- Stage failed: $stage
- Failure reason: $reason

Suggested next checks:
- Verify logs under logs/ directory.
- Check service state using: cidre-recovery firstboot-status
EOF

echo "Failure classification report generated at: $output_file"
