#!/usr/bin/env bash
# cidre-image-build-report: Write summary markdown reports for successful prototype builds
set -euo pipefail

output_file=""
logs_dir=""
manifest_path=""

usage() {
  cat <<EOF
Usage: cidre-image-build-report [options]

Summarize build outcomes and verification checkpoints in a markdown report.

Options:
  --output <file>   Markdown report output path
  --logs <dir>      Directory where logs are stored
  --manifest <path> Path to the build manifest file
  --help            Show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --output) output_file="$2"; shift 2 ;;
    --logs) logs_dir="$2"; shift 2 ;;
    --manifest) manifest_path="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if [ -z "$output_file" ]; then
  echo "ERROR: --output file is required" >&2
  exit 1
fi

mkdir -p "$(dirname "$output_file")"

# Read properties from manifest if python3 is available
cidre_rev="unknown"
builder_rev="unknown"
registered_img="unknown"
checksum_val="unknown"

if [ -n "$manifest_path" ] && [ -f "$manifest_path" ] && command -v python3 >/dev/null 2>&1; then
  cidre_rev=$(python3 -c "import json; d=json.load(open('$manifest_path')); print(d.get('cidre_version', 'unknown'))")
  builder_rev=$(python3 -c "import json; d=json.load(open('$manifest_path')); print(d.get('builder', {}).get('commit', 'unknown'))")
  registered_img=$(python3 -c "import json; d=json.load(open('$manifest_path')); print(d.get('artifacts', {}).get('registered_image', 'unknown'))")
  checksum_val=$(python3 -c "import json; d=json.load(open('$manifest_path')); print(d.get('artifacts', {}).get('checksum', 'unknown'))")
fi

cat >"$output_file" <<EOF
# Cidre Prototype Image Build Report

Generated on: $(date -u +%Y-%m-%dT%H:%M:%SZ)

## Build Properties
- **Build Status**: Success
- **Cidre Release Version**: $cidre_rev
- **ALARM Builder Revision**: $builder_rev

## Artifact Information
- **Registered Prototype Image**: $registered_img
- **Checksum File**: $checksum_val

## Next Steps & Known Limitations
- The registered prototype is a **local developer layout**, not a public release asset.
- Real Apple Silicon hardware boot testing is deferred.
- Run \`scripts/cidre-image-mount\` to check system layouts.
EOF

echo "Image build report written to: $output_file"
EOF
