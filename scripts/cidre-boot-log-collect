#!/usr/bin/env bash
# cidre-boot-log-collect: Collect boot validation logs after a Cidre first boot
set -euo pipefail

SCRIPT_VERSION="0.17.0"
SCRIPT_NAME="cidre-boot-log-collect"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEFAULT_OUTPUT_DIR=".local/state/cidre/boot-validation"

output_dir="$DEFAULT_OUTPUT_DIR"
no_journal=false
dry_run=false

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME [options]

Collect boot validation logs after a Cidre first boot.

Options:
  --output <dir>    Output directory (default: $DEFAULT_OUTPUT_DIR)
  --no-journal      Skip journalctl collection
  --dry-run         Show what would be collected without collecting
  --help            Show this help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --output) output_dir="$2"; shift 2 ;;
    --boot-test-state) output_dir="$2"; shift 2 ;;
    --no-journal) no_journal=true; shift ;;
    --dry-run) dry_run=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

if "$dry_run"; then
  echo "Cidre boot log collection (dry-run)"
  echo ""
  echo "Would collect to: $output_dir/"
  echo ""
  echo "Collection plan:"
  if ! "$no_journal"; then
    echo "  journalctl -b              -> $output_dir/journal.txt"
  fi
  echo "  systemctl status cidre-firstboot-root.service"
  echo "                             -> $output_dir/cidre-firstboot-root.service.txt"
  echo "  /var/lib/cidre/firstboot-root/firstboot.log"
  echo "                             -> $output_dir/firstboot.log"
  echo "  /var/lib/cidre/firstboot-root/handoff.txt"
  echo "                             -> $output_dir/handoff.txt"
  echo "  scripts/cidre-doctor --firstboot"
  echo "                             -> $output_dir/doctor-firstboot.txt"
  echo "  scripts/cidre-recovery firstboot-status"
  echo "                             -> $output_dir/recovery-firstboot-status.txt"
  echo "  ~/.local/state/cidre/exit/current/uninstall-check.log"
  echo "                             -> $output_dir/uninstall-check.log"
  echo "  ~/.local/state/cidre/exit/current/partition-audit.txt"
  echo "                             -> $output_dir/partition-audit.txt"
  echo "  ~/.local/state/cidre/exit/current/exit-plan.md"
  echo "                             -> $output_dir/exit-plan.md"
  echo "  ~/.local/state/cidre/exit/current/uninstall-risk.json"
  echo "                             -> $output_dir/uninstall-risk.json"
  echo "  ~/.local/state/cidre/rescue/"
  echo "                             -> $output_dir/rescue/"
  echo "  ~/.local/state/cidre/rescue-boot/"
  echo "                             -> $output_dir/rescue-boot/"
  echo "  ~/.local/state/cidre/macos-rescue/"
  echo "                             -> $output_dir/macos-rescue/"
  echo ""
  echo "No files written (dry-run)."
  exit 0
fi

mkdir -p "$output_dir"

_collect() {
  local label="$1" dest="$2"
  shift 2
  echo "  Collecting: $label"
  if "$@" > "$output_dir/$dest" 2>&1; then
    echo "    -> $output_dir/$dest"
  else
    echo "    -> $output_dir/$dest (command exited non-zero; output may be partial)"
  fi
}

echo "Cidre boot log collection"
echo "output: $output_dir"
echo ""

if ! "$no_journal"; then
  if command -v journalctl >/dev/null 2>&1; then
    _collect "journalctl -b" "journal.txt" journalctl -b --no-pager
  else
    echo "  [SKIP] journalctl not available"
  fi
fi

if command -v systemctl >/dev/null 2>&1; then
  _collect "systemctl status cidre-firstboot-root.service" \
    "cidre-firstboot-root.service.txt" \
    systemctl status cidre-firstboot-root.service --no-pager
else
  echo "  [SKIP] systemctl not available"
fi

if [ -f "/var/lib/cidre/firstboot-root/firstboot.log" ]; then
  cp "/var/lib/cidre/firstboot-root/firstboot.log" "$output_dir/firstboot.log"
  echo "  -> $output_dir/firstboot.log"
else
  echo "  [SKIP] /var/lib/cidre/firstboot-root/firstboot.log not found"
fi

if [ -f "/var/lib/cidre/firstboot-root/handoff.txt" ]; then
  cp "/var/lib/cidre/firstboot-root/handoff.txt" "$output_dir/handoff.txt"
  echo "  -> $output_dir/handoff.txt"
else
  echo "  [SKIP] /var/lib/cidre/firstboot-root/handoff.txt not found"
fi

if [ -x "$SCRIPT_DIR/cidre-doctor" ]; then
  _collect "cidre-doctor --firstboot" "doctor-firstboot.txt" \
    "$SCRIPT_DIR/cidre-doctor" --firstboot
else
  echo "  [SKIP] cidre-doctor not found"
fi

if [ -x "$SCRIPT_DIR/cidre-recovery" ]; then
  _collect "cidre-recovery firstboot-status" "recovery-firstboot-status.txt" \
    "$SCRIPT_DIR/cidre-recovery" firstboot-status
else
  echo "  [SKIP] cidre-recovery not found"
fi

# Collect firstboot fixup diagnostic details (v0.21.0)
if [ -x "$SCRIPT_DIR/cidre-firstboot-diagnose" ]; then
  _collect "cidre-firstboot-diagnose" "firstboot-diagnose.txt" \
    "$SCRIPT_DIR/cidre-firstboot-diagnose"
fi

if [ -f "/var/lib/cidre/firstboot-root/report.md" ]; then
  cp "/var/lib/cidre/firstboot-root/report.md" "$output_dir/firstboot-report.md"
  echo "  -> $output_dir/firstboot-report.md"
fi

if [ -x "$SCRIPT_DIR/cidre-firstboot-console" ]; then
  _collect "cidre-firstboot-console --status" "firstboot-console.txt" \
    "$SCRIPT_DIR/cidre-firstboot-console" --status
fi

if command -v systemctl >/dev/null 2>&1; then
  _collect "systemctl cat cidre-firstboot-root.service" "firstboot-service-unit.txt" \
    systemctl cat cidre-firstboot-root.service
fi

# Collect user phase metrics (v0.22.0)
USER_STATE_DIR_COLLECT="${HOME}/.local/state/cidre/user-phase"
if [ -d "$USER_STATE_DIR_COLLECT" ]; then
  mkdir -p "$output_dir/user-phase"
  cp -r "$USER_STATE_DIR_COLLECT"/* "$output_dir/user-phase/" 2>/dev/null || true
  echo "  -> Collected user phase state files to user-phase/"
fi

if [ -x "$SCRIPT_DIR/cidre-doctor" ]; then
  _collect "cidre-doctor --user-phase" "doctor-user-phase.txt" \
    "$SCRIPT_DIR/cidre-doctor" --user-phase
fi

if [ -x "$SCRIPT_DIR/cidre-recovery" ]; then
  _collect "cidre-recovery user-phase-status" "recovery-user-phase-status.txt" \
    "$SCRIPT_DIR/cidre-recovery" user-phase-status
fi

EXIT_STATE_DIR="${HOME}/.local/state/cidre/exit/current"
for artifact in uninstall-check.log partition-audit.txt exit-plan.md uninstall-risk.json; do
  if [ -f "$EXIT_STATE_DIR/$artifact" ]; then
    cp "$EXIT_STATE_DIR/$artifact" "$output_dir/$artifact"
    echo "  -> $output_dir/$artifact"
  fi
done

RECOVERY_STATE_DIR="${HOME}/.local/state/cidre/recovery-screen"
if [ -d "$RECOVERY_STATE_DIR" ]; then
  mkdir -p "$output_dir/recovery-screen"
  cp -r "$RECOVERY_STATE_DIR"/* "$output_dir/recovery-screen/" 2>/dev/null || true
  echo "  -> Collected recovery screen state files"
fi

if [ -d "/var/lib/cidre/recovery-screen" ]; then
  mkdir -p "$output_dir/recovery-screen-system"
  cp -r /var/lib/cidre/recovery-screen/* "$output_dir/recovery-screen-system/" 2>/dev/null || true
  echo "  -> Collected system recovery screen state files"
fi

RESCUE_STATE_DIR="${HOME}/.local/state/cidre/rescue"
if [ -d "$RESCUE_STATE_DIR" ]; then
  mkdir -p "$output_dir/rescue"
  cp -r "$RESCUE_STATE_DIR"/* "$output_dir/rescue/" 2>/dev/null || true
  echo "  -> Collected rescue state files"
fi

RESCUE_BOOT_STATE_DIR="${HOME}/.local/state/cidre/rescue-boot"
if [ -d "$RESCUE_BOOT_STATE_DIR" ]; then
  mkdir -p "$output_dir/rescue-boot"
  cp -r "$RESCUE_BOOT_STATE_DIR"/* "$output_dir/rescue-boot/" 2>/dev/null || true
  echo "  -> Collected rescue boot state files"
fi

MACOS_RESCUE_STATE_DIR="${HOME}/.local/state/cidre/macos-rescue"
if [ -d "$MACOS_RESCUE_STATE_DIR" ]; then
  mkdir -p "$output_dir/macos-rescue"
  cp -r "$MACOS_RESCUE_STATE_DIR"/* "$output_dir/macos-rescue/" 2>/dev/null || true
  echo "  -> Collected macOS rescue state files"
fi

echo ""
echo "Collection complete: $output_dir/"
ls -1 "$output_dir/" 2>/dev/null | sed 's/^/  /'
