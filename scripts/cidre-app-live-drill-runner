#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_ROOT="$REPO_ROOT/.local/state/cidre/live-drill"
CURRENT_DIR="$STATE_ROOT/current"

plan=""
json_mode=false
dry_run=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --plan) plan="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-live-drill-runner --plan plan.json [--dry-run] [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done
[ -n "$plan" ] || { echo "ERROR: --plan is required" >&2; exit 2; }
mkdir -p "$CURRENT_DIR"

drill_id="$(python3 - "$plan" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as handle:
    print(json.load(handle).get("drill_id", "live-drill-unknown"))
PY
)"
drill_dir="$STATE_ROOT/$drill_id"
mkdir -p "$drill_dir"

signature="$plan.sig.json"
"$SCRIPT_DIR/cidre-app-mutation-plan-sign" --plan "$plan" --json > "$drill_dir/plan-signature.json"

level="$(python3 - "$plan" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as handle:
    print(json.load(handle).get("level", "0"))
PY
)"
target="$(python3 - "$plan" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as handle:
    print(json.load(handle).get("target") or "")
PY
)"
requires_confirmation="$(python3 - "$plan" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as handle:
    print("true" if json.load(handle).get("requires_confirmation") else "false")
PY
)"

confirmation_file=""
if [ "$requires_confirmation" = true ]; then
  "$SCRIPT_DIR/cidre-app-mutation-confirmation" --plan "$plan" --phrase "I understand this can destroy the selected disposable target." --json > "$drill_dir/confirmation.json"
  confirmation_file="$drill_dir/confirmation.json"
fi

gate_json="$("$SCRIPT_DIR/cidre-app-gate-evaluate" --scope live-drill ${target:+--target "$target"} --json 2>/dev/null || true)"
plan_verify_json="$("$SCRIPT_DIR/cidre-app-mutation-plan-verify" --plan "$plan" --signature "$signature" --json 2>/dev/null || true)"
helper_gate_json="$("$SCRIPT_DIR/cidre-app-helper-gate" --operation live-drill --level "$level" ${target:+--target "$target"} --json 2>/dev/null || true)"
recovery_json="$("$SCRIPT_DIR/cidre-app-recovery-survival-check" --json 2>/dev/null || true)"
disposable_json=""
if [ -n "$target" ]; then
  disposable_json="$("$SCRIPT_DIR/cidre-app-disposable-target-check" --target "$target" --json 2>/dev/null || true)"
fi
before_result="$("$SCRIPT_DIR/cidre-app-disk-snapshot" --label "live-drill-before-$level" --json 2>/dev/null || true)"
before_snapshot="$(printf '%s\n' "$before_result" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("snapshot_file",""))' 2>/dev/null || true)"
"$SCRIPT_DIR/cidre-app-apfs-snapshot" --label "live-drill-before-$level" --json > "$drill_dir/before-apfs.json" 2>/dev/null || true

case "$level" in
  0) drill_output="$("$SCRIPT_DIR/cidre-app-noop-drill" --json 2>/dev/null || true)" ;;
  1) drill_output="$("$SCRIPT_DIR/cidre-app-metadata-drill" --drill-dir "$drill_dir" --json 2>/dev/null || true)" ;;
  2) drill_output="$("$SCRIPT_DIR/cidre-app-disposable-marker-drill" --target "$target" --drill-dir "$drill_dir" --json 2>/dev/null || true)" ;;
  3)
    if [ "$dry_run" = true ]; then
      drill_output="$("$SCRIPT_DIR/cidre-app-apfs-volume-drill" --target "$target" --plan "$plan" --signature "$signature" --confirmation "$confirmation_file" --drill-dir "$drill_dir" --dry-run --json 2>/dev/null || true)"
    else
      drill_output="$("$SCRIPT_DIR/cidre-app-apfs-volume-drill" --target "$target" --plan "$plan" --signature "$signature" --confirmation "$confirmation_file" --drill-dir "$drill_dir" --json 2>/dev/null || true)"
    fi
    ;;
  *) drill_output='{"status":"blocked","summary":"Unknown live drill level.","exit_code":4}' ;;
esac

after_result="$("$SCRIPT_DIR/cidre-app-disk-snapshot" --label "live-drill-after-$level" --json 2>/dev/null || true)"
after_snapshot="$(printf '%s\n' "$after_result" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("snapshot_file",""))' 2>/dev/null || true)"
"$SCRIPT_DIR/cidre-app-apfs-snapshot" --label "live-drill-after-$level" --json > "$drill_dir/after-apfs.json" 2>/dev/null || true
verify_json=""
if [ -n "$before_snapshot" ] && [ -n "$after_snapshot" ]; then
  verify_json="$("$SCRIPT_DIR/cidre-app-live-drill-verify" --plan "$plan" --before "$before_snapshot" --after "$after_snapshot" --json 2>/dev/null || true)"
fi

python3 - "$CURRENT_DIR" "$drill_dir" "$plan" "$json_mode" "$dry_run" "$gate_json" "$plan_verify_json" "$helper_gate_json" "$disposable_json" "$recovery_json" "$before_result" "$after_result" "$drill_output" "$verify_json" <<'PY'
import json, os, sys
current_dir, drill_dir, plan_path, json_mode, dry_run, gate_raw, plan_verify_raw, helper_gate_raw, disposable_raw, recovery_raw, before_raw, after_raw, drill_raw, verify_raw = sys.argv[1:]
json_mode = json_mode == "true"
dry_run = dry_run == "true"
def parse(raw):
    try:
        return json.loads((raw or "").strip()) if (raw or "").strip() else {}
    except Exception:
        return {}
gate = parse(gate_raw)
plan_verify = parse(plan_verify_raw)
helper_gate = parse(helper_gate_raw)
disposable = parse(disposable_raw)
recovery = parse(recovery_raw)
before = parse(before_raw)
after = parse(after_raw)
drill = parse(drill_raw)
verify = parse(verify_raw)
with open(plan_path, "r", encoding="utf-8") as handle:
    plan = json.load(handle)
checks = []
errors = []
def add_check(identifier, passed, reason):
    checks.append({"id": identifier, "status": "passed" if passed else "blocked", "reason": None if passed else reason})
    if not passed:
        errors.append({"code": identifier, "message": reason})
add_check("gate-evaluate", gate.get("status") == "passed", gate.get("summary") or "Live drill gate evaluation blocked.")
add_check("plan-hash-verified", plan_verify.get("status") == "passed", plan_verify.get("summary") or "Plan hash verification failed.")
if plan.get("requires_disposable_target"):
    add_check("disposable-target", disposable.get("status") == "passed", disposable.get("summary") or "Disposable target check failed.")
add_check("helper-gate", helper_gate.get("status") == "passed", helper_gate.get("summary") or "Helper gate blocked live drill.")
add_check("pre-snapshot", bool(before.get("snapshot_file")), "Before snapshot missing.")
add_check("recovery-survival", recovery.get("status") == "passed", recovery.get("summary") or "Recovery survival failed.")

status = "blocked" if errors else drill.get("status", "passed")
summary = "Live drill execution completed." if not errors else "Live drill execution is blocked."
if not errors and verify and verify.get("status") != "passed":
    status = "failed"
    summary = "Live drill execution completed but verification failed."
payload = {
    "schema_version": 1,
    "command": "cidre-app-live-drill-runner",
    "status": status,
    "summary": summary,
    "exit_code": 0 if status == "passed" else (8 if status == "failed" else 4),
    "dry_run": dry_run,
    "plan": plan,
    "checks": checks,
    "errors": errors,
    "before_snapshot": before.get("snapshot_file"),
    "after_snapshot": after.get("snapshot_file"),
    "drill_result": drill,
    "verification": verify,
}
state = {
    "schema_version": 1,
    "command": "cidre-app-live-drill-state",
    "status": status,
    "summary": summary,
    "drill_id": plan.get("drill_id"),
    "level": plan.get("level"),
}
for base in (current_dir, drill_dir):
    os.makedirs(base, exist_ok=True)
    for name, value in (
        ("last-plan.json", plan),
        ("last-result.json", payload),
        ("last-state.json", state),
    ):
        with open(os.path.join(base, name), "w", encoding="utf-8") as handle:
            json.dump(value, handle, indent=2, sort_keys=True)
            handle.write("\n")
    if verify:
        with open(os.path.join(base, "last-verification.json"), "w", encoding="utf-8") as handle:
            json.dump(verify, handle, indent=2, sort_keys=True)
            handle.write("\n")
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY

"$SCRIPT_DIR/cidre-app-live-drill-report" --json > "$drill_dir/report.json" 2>/dev/null || true
"$SCRIPT_DIR/cidre-app-live-drill-report" --markdown > "$drill_dir/report.md" 2>/dev/null || true
"$SCRIPT_DIR/cidre-app-live-drill-report" --json > "$CURRENT_DIR/report.json" 2>/dev/null || true
"$SCRIPT_DIR/cidre-app-live-drill-report" --markdown > "$CURRENT_DIR/report.md" 2>/dev/null || true
