#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-rollback-report-check [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

python3 - "$REPO_ROOT" "$json_mode" <<'PY'
import json
import os
import sys

repo_root, json_mode = sys.argv[1:]
json_mode = json_mode == "true"

candidates = [
    os.path.join(repo_root, ".local/state/cidre/boot-safety/current/gate-report.md"),
    os.path.join(repo_root, ".local/state/cidre/incidents/latest/report.md"),
    os.path.join(repo_root, ".local/state/cidre/incidents/DFU_RESTORE_001/report.md"),
    os.path.join(repo_root, ".local/state/cidre/macos-restore/current/restore-report.md"),
    os.path.join(repo_root, ".local/state/cidre/app-wizard/current/setup-report.md"),
]
existing = [path for path in candidates if os.path.exists(path)]
payload = {
    "schema_version": 1,
    "command": "cidre-app-rollback-report-check",
    "status": "passed" if existing else "blocked",
    "summary": "Rollback or failure report exists." if existing else "Rollback report missing.",
    "phase": "safety",
    "stage": "rollback-report-check",
    "exit_code": 0 if existing else 8,
    "warnings": [],
    "errors": [] if existing else [{"code": "rollback-report-missing", "message": "rollback report missing"}],
    "report_candidates": candidates,
    "existing_reports": existing,
}
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY
