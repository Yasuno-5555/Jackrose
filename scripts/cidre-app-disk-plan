#!/bin/sh
set -eu

mode="install"
target=""
container_size=""
partition_size=""
partition_mode="custom"   # max | min | auto | custom
volume_name="Cidre"
plan_id=""
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode) mode="$2"; shift 2 ;;
    --target) target="$2"; shift 2 ;;
    --container-size) container_size="$2"; shift 2 ;;
    --partition-size) partition_size="$2"; shift 2 ;;
    --partition-mode) partition_mode="$2"; shift 2 ;;
    --volume-name) volume_name="$2"; shift 2 ;;
    --plan-id) plan_id="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-disk-plan --mode install|uninstall --target diskNsM [--partition-mode max|min|auto|custom --container-size 200G --partition-size 80G --volume-name Cidre --plan-id id] [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/cidre/mutation/current"
mkdir -p "$STATE_DIR"

python3 - "$STATE_DIR" "$mode" "$target" "$container_size" "$partition_size" "$partition_mode" "$volume_name" "$plan_id" "$json_mode" <<'PY'
import hashlib, json, math, platform, plistlib, re, subprocess, sys

state_dir, mode, target, container_size, partition_size, partition_mode, volume_name, plan_id, json_mode = sys.argv[1:]
errors = []
limits_info = {}

def run_diskutil(*args):
    completed = subprocess.run(["/usr/sbin/diskutil", *args], check=True, capture_output=True)
    return plistlib.loads(completed.stdout)

def size_bytes(value):
    scale = {"B":1,"K":1000,"M":1000**2,"G":1000**3,"T":1000**4,"P":1000**5}
    return int(value[:-1]) * scale[value[-1].upper()]

def fmt_human(b):
    for unit, divisor in [("TB",1e12),("GB",1e9),("MB",1e6),("KB",1e3)]:
        if b >= divisor:
            return f"{b/divisor:.1f} {unit}"
    return f"{b} B"

if mode not in ("install", "uninstall"):
    errors.append("mode must be install or uninstall")
if not re.fullmatch(r"disk\d+s\d+", target):
    errors.append("target must look like disk3s2")

if mode == "install" and not errors and platform.system() == "Darwin":
    try:
        lim = run_diskutil("apfs", "resizeContainer", target, "limits", "-plist")
        current = lim["CurrentSize"]
        min_preferred = lim["MinimumSizePreferred"]
        min_absolute = lim.get("MinimumSizeRequired", 0)
        max_partition = current - min_preferred
        max_partition_abs = current - min_absolute
        auto_partition = max(10 * 1000**3, (round(max_partition * 0.6 / (10 * 1000**3))) * (10 * 1000**3))
        auto_partition = min(auto_partition, max_partition)
        limits_info = {
            "current_bytes": current,
            "min_preferred_bytes": min_preferred,
            "max_partition_bytes": max_partition,
            "max_partition_abs_bytes": max_partition_abs,
            "auto_partition_bytes": auto_partition,
            "current_human": fmt_human(current),
            "max_partition_human": fmt_human(max_partition),
            "auto_partition_human": fmt_human(auto_partition),
        }
        if partition_mode == "max":
            resolved_partition = max_partition
            resolved_container = min_preferred
        elif partition_mode == "min":
            min_cidre = 20 * 1000**3
            if max_partition < min_cidre:
                errors.append(f"Not enough free space for a minimum Cidre partition. Need at least {fmt_human(min_cidre)}, only {fmt_human(max_partition)} available.")
                resolved_partition = max_partition
                resolved_container = min_preferred
            else:
                resolved_partition = min_cidre
                resolved_container = current - resolved_partition
        elif partition_mode == "auto":
            resolved_partition = auto_partition
            resolved_container = current - resolved_partition
        else:
            resolved_partition = None
            resolved_container = None

        if partition_mode == "custom" and re.fullmatch(r"max", partition_size, re.I):
            if re.fullmatch(r"[1-9]\d*(?:B|K|M|G|T|P)", container_size, re.I):
                requested_container = size_bytes(container_size)
                resolved_partition = current - requested_container
                if resolved_partition <= 0:
                    errors.append("partition size 'max' leaves no space for the new Cidre partition.")
                else:
                    partition_size = f"{resolved_partition}B"
            else:
                errors.append("partition size 'max' requires a valid explicit container size.")

        if partition_mode != "custom":
            if partition_mode == "min":
                container_size = f"{current - resolved_partition}B"
                partition_size = f"{resolved_partition}B"
            else:
                container_size = f"{resolved_container}B"
                partition_size = f"{current - resolved_container}B"
    except Exception as error:
        errors.append(f"could not read APFS resize limits: {error}")

if mode == "install":
    if not re.fullmatch(r"[1-9]\d*(?:B|K|M|G|T|P)", container_size, re.I):
        errors.append("container size is invalid or not yet resolved — use --partition-mode max|min|auto or provide --container-size and --partition-size")
    if not re.fullmatch(r"[1-9]\d*(?:B|K|M|G|T|P)", partition_size, re.I):
        errors.append("partition size is invalid or not yet resolved")
    if not volume_name or "/" in volume_name or len(volume_name) > 64:
        errors.append("volume name is invalid")
    if not errors and platform.system() == "Darwin" and limits_info:
        requested = size_bytes(container_size)
        partition = size_bytes(partition_size)
        if requested < limits_info["min_preferred_bytes"]:
            errors.append(
                f"container size ({fmt_human(requested)}) is below macOS recommended minimum "
                f"({fmt_human(limits_info['min_preferred_bytes'])})."
            )
        if requested + partition > limits_info["current_bytes"]:
            errors.append(
                f"container ({fmt_human(requested)}) + partition ({fmt_human(partition)}) = "
                f"{fmt_human(requested + partition)} exceeds physical store ({fmt_human(limits_info['current_bytes'])})."
            )

helper_operation = "partition-create" if mode == "install" else "partition-delete"
canonical = "\n".join((mode, helper_operation, target, container_size, partition_size, volume_name if mode == "install" else ""))
plan_id = plan_id or hashlib.sha256(canonical.encode()).hexdigest()[:16]

mutation_plan = {
    "schema_version": 1,
    "plan_id": plan_id,
    "operation": "create-cidre-test-target" if mode == "install" else "delete-cidre-test-target",
    "helper_operation": helper_operation,
    "target": target,
    "destructive": True,
    "test_mode_required": True,
    "install_target_required": True,
    "allowed_target_classes": [
        "startup-physical-store",
        "startup-container",
    ],
    "required_checks": [
        "install-target-check",
        "protected-partition-guard",
        "recovery-survival",
        "pre-snapshot",
        "confirmation",
    ],
    "container_size": container_size or None,
    "partition_size": partition_size or None,
    "volume_name": volume_name if mode == "install" else None,
    "required_confirmation": f"CIDRE EXECUTE {plan_id}",
}
plan_hash = hashlib.sha256(json.dumps(mutation_plan, sort_keys=True).encode()).hexdigest()
mutation_plan["plan_hash"] = plan_hash
plan_file = f"{state_dir}/{plan_id}.plan.json"
with open(plan_file, "w", encoding="utf-8") as handle:
    json.dump(mutation_plan, handle, indent=2, sort_keys=True)
    handle.write("\n")

summary_ok = (
    f"Ready: shrink macOS container to {fmt_human(size_bytes(container_size))}, "
    f"create {fmt_human(size_bytes(partition_size))} Cidre partition."
    if not errors and container_size and partition_size else
    "Disk mutation plan is ready for review."
)

payload = {
    "schema_version": 1,
    "command": "cidre-app-disk-plan",
    "status": "pass" if not errors else "blocked",
    "summary": summary_ok if not errors else "Disk plan validation failed.",
    "phase": "disk",
    "stage": "plan",
    "exit_code": 0 if not errors else 4,
    "warnings": ["This operation changes the partition map. Keep a current backup and power connected."],
    "errors": [{"code":"invalid-plan","message":item} for item in errors],
    "plan_id": plan_id,
    "plan_file": plan_file,
    "plan_hash": plan_hash,
    "mode": mode,
    "operation": helper_operation,
    "partition_mode": partition_mode,
    "target": target,
    "container_size": container_size or None,
    "partition_size": partition_size or None,
    "volume_name": volume_name if mode == "install" else None,
    "helper_required": True,
    "required_confirmation": mutation_plan["required_confirmation"],
    "limits": limits_info or None,
}
print(json.dumps(payload, indent=2) if json_mode == "true" else payload["summary"])
sys.exit(payload["exit_code"])
PY
