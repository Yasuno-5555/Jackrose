#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/cidre-macos-restore-common"

json=false
strict=false
output_dir="$(cidre_macos_restore_current_dir)"

usage() {
  cat <<EOF
Usage: cidre-macos-restore-check [options]

Options:
  --json
  --output <dir>
  --strict
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json) json=true; shift ;;
    --output) output_dir="$2"; shift 2 ;;
    --strict) strict=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

cidre_macos_restore_require_macos
cidre_macos_restore_prepare_dirs
mkdir -p "$output_dir"

log_file="$output_dir/restore-check.log"
bootstrap_dir="$(cidre_macos_restore_bootstrap_dir)"

ok_count=0
warn_count=0
fail_count=0
status=0
messages=""

add_result() {
  level="$1"
  message="$2"
  case "$level" in
    OK) ok_count=$((ok_count + 1)) ;;
    WARN) warn_count=$((warn_count + 1)); [ "$strict" = "true" ] && status=1 ;;
    FAIL) fail_count=$((fail_count + 1)); status=1 ;;
  esac
  messages="${messages}${level}|${message}
"
}

check_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    add_result OK "tool available: $1"
  else
    add_result FAIL "tool missing: $1"
  fi
}

add_result OK "running on macOS"
check_cmd sh
check_cmd diskutil
check_cmd uname
check_cmd sw_vers

if mkdir -p "$output_dir" 2>/dev/null; then
  add_result OK "restore state dir writable: $output_dir"
else
  add_result FAIL "restore state dir is not writable: $output_dir"
fi

if [ -d "$bootstrap_dir" ]; then
  add_result OK "previous macOS bootstrap state exists"
else
  add_result WARN "previous macOS bootstrap state not found"
fi

if [ -f "$PWD/.local/state/cidre/exit/current/cidre-state-export.tar.gz" ] || [ -f "$PWD/.local/state/cidre/exit/current/cidre-state-export.tar.zst" ]; then
  add_result OK "Linux-side export path hint exists"
else
  add_result WARN "Linux-side export path hint not found in repository state"
fi

if diskutil list >/dev/null 2>&1; then
  add_result OK "diskutil list can be collected"
else
  add_result FAIL "diskutil list failed"
fi

if diskutil apfs list >/dev/null 2>&1; then
  add_result OK "APFS layout can be collected"
else
  add_result WARN "APFS layout could not be collected"
fi

if [ -x "$SCRIPT_DIR/cidre-macos-partition-audit" ]; then
  add_result OK "partition candidate audit script is available"
else
  add_result FAIL "partition candidate audit script missing"
fi

if [ -x "$SCRIPT_DIR/cidre-macos-uninstall-guide" ]; then
  add_result OK "uninstall guide can be generated"
else
  add_result FAIL "uninstall guide script missing"
fi

if [ -x "$SCRIPT_DIR/cidre-macos-restore-report" ]; then
  add_result OK "restore report can be generated"
else
  add_result FAIL "restore report script missing"
fi

add_result OK "destructive mode unavailable"

{
  echo "Cidre macOS restore readiness"
  echo
  printf '%s' "$messages" | while IFS='|' read -r level message; do
    [ -n "$level" ] || continue
    printf '[%s] %s\n' "$level" "$message"
  done
  echo
  echo "No destructive action will be performed."
} > "$log_file"

if [ "$json" = "true" ]; then
  printf '{\n'
  printf '  "schema_version": 1,\n'
  printf '  "created_at": "%s",\n' "$(cidre_macos_restore_timestamp)"
  printf '  "strict": %s,\n' "$(cidre_macos_restore_bool "$strict")"
  printf '  "ok_count": %s,\n' "$ok_count"
  printf '  "warn_count": %s,\n' "$warn_count"
  printf '  "fail_count": %s,\n' "$fail_count"
  printf '  "log_path": "%s"\n' "$(cidre_macos_restore_json_escape "$log_file")"
  printf '}\n'
else
  cat "$log_file"
fi

exit "$status"
