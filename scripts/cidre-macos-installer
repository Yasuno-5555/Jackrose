#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
PROFILE=""
DRY_RUN=0
NO_SEED=0
CHECK_ONLY=0
PRINT_HANDOFF=0
RESTORE_HELP=0
RESTORE_CHECK=0
PARTITION_AUDIT=0
STARTUP_DISK_CHECK=0
UNINSTALL_GUIDE=0
RESTORE_REPORT=0
RESCUE_HELP=0
RESCUE_CHECK=0
RESCUE_DISK_AUDIT=0
RESCUE_PLAN=0
RESCUE_GUIDE=0
RESCUE_REPORT=0
RESCUE_CREATE_DRY_RUN=0

usage() {
  cat <<'EOF'
Usage:
  ./install-macos [options]

Options:
  --check              Run readiness checks only
  --dry-run            Print planned actions without making changes
  --profile <name>     Select profile: desktop, developer, minimal, recovery
  --no-seed            Skip manifest generation
  --print-handoff      Print handoff instructions only
  --restore-help       Print uninstall/restore guidance only
  --restore-check      Run macOS restore readiness checks
  --partition-audit    Collect a read-only macOS partition audit
  --startup-disk-check Generate startup disk guidance
  --uninstall-guide    Generate a macOS uninstall guide
  --restore-report     Generate a macOS restore report
  --rescue-help        Print Rescue Slot guidance
  --rescue-check       Run macOS-side Rescue Slot readiness checks
  --rescue-disk-audit  Collect a read-only macOS rescue disk audit
  --rescue-plan        Generate a macOS rescue planning document
  --rescue-guide       Generate a macOS rescue guide
  --rescue-report      Generate a macOS rescue report
  --rescue-create-dry-run Print rescue creation dry-run guidance
  -h, --help           Show this help
EOF
}

validate_profile() {
  case "$1" in
    desktop|developer|minimal|recovery) return 0 ;;
    *) printf 'ERROR: unknown profile: %s\n' "$1" >&2; exit 1 ;;
  esac
}

require_macos() {
  if [ "$(uname -s)" != "Darwin" ]; then
    printf 'ERROR: rescue macOS commands require macOS.\nNo disk operation was performed.\n' >&2
    exit 1
  fi
}

choose_profile() {
  if [ -n "$PROFILE" ]; then
    return 0
  fi

  if [ -t 0 ] && [ -t 1 ]; then
    printf 'Select Cidre profile:\n'
    printf '  [1] desktop\n'
    printf '  [2] developer\n'
    printf '  [3] minimal\n'
    printf '  [4] recovery\n'
    printf 'Select option [1-4] (default: 1): '
    read answer || true
    case "${answer:-1}" in
      2) PROFILE="developer" ;;
      3) PROFILE="minimal" ;;
      4) PROFILE="recovery" ;;
      *) PROFILE="desktop" ;;
    esac
  else
    PROFILE="desktop"
  fi
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --check)
      CHECK_ONLY=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --profile)
      [ "$#" -ge 2 ] || {
        printf 'ERROR: --profile requires an argument\n' >&2
        exit 1
      }
      PROFILE="$2"
      validate_profile "$PROFILE"
      shift 2
      ;;
    --no-seed)
      NO_SEED=1
      shift
      ;;
    --print-handoff)
      PRINT_HANDOFF=1
      shift
      ;;
    --restore-help)
      RESTORE_HELP=1
      shift
      ;;
    --restore-check)
      RESTORE_CHECK=1
      shift
      ;;
    --partition-audit)
      PARTITION_AUDIT=1
      shift
      ;;
    --startup-disk-check)
      STARTUP_DISK_CHECK=1
      shift
      ;;
    --uninstall-guide)
      UNINSTALL_GUIDE=1
      shift
      ;;
    --restore-report)
      RESTORE_REPORT=1
      shift
      ;;
    --rescue-help)
      RESCUE_HELP=1
      shift
      ;;
    --rescue-check)
      RESCUE_CHECK=1
      shift
      ;;
    --rescue-disk-audit)
      RESCUE_DISK_AUDIT=1
      shift
      ;;
    --rescue-plan)
      RESCUE_PLAN=1
      shift
      ;;
    --rescue-guide)
      RESCUE_GUIDE=1
      shift
      ;;
    --rescue-report)
      RESCUE_REPORT=1
      shift
      ;;
    --rescue-create-dry-run)
      RESCUE_CREATE_DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'ERROR: unknown option: %s\n' "$1" >&2
      usage
      exit 1
      ;;
  esac
done

if [ "$CHECK_ONLY" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-check"
fi

if [ "$RESTORE_CHECK" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-restore-check"
fi

if [ "$PARTITION_AUDIT" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-partition-audit"
fi

if [ "$STARTUP_DISK_CHECK" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-startup-disk-check"
fi

if [ "$UNINSTALL_GUIDE" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-uninstall-guide"
fi

if [ "$RESTORE_REPORT" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-restore-report"
fi

if [ "$RESCUE_CHECK" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-rescue-check"
fi

if [ "$RESCUE_DISK_AUDIT" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-rescue-disk-audit"
fi

if [ "$RESCUE_PLAN" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-rescue-plan"
fi

if [ "$RESCUE_GUIDE" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-rescue-guide"
fi

if [ "$RESCUE_REPORT" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-rescue-report"
fi

if [ "$RESCUE_CREATE_DRY_RUN" -eq 1 ]; then
  require_macos
  cat <<'EOF'
Cidre macOS rescue create dry-run

- This release only generates read-only planning output.
- No partition will be created.
- No boot entry will be modified.
- Generate rescue plan, guide, and report first.
EOF
  exit 0
fi

if [ "$RESTORE_HELP" -eq 1 ]; then
  cat <<'EOF'
Cidre restore and removal guidance

- v0.24.0 adds macOS-side restore check, partition audit, startup disk guidance, uninstall guide, and restore report generation.
- v0.24.0 does not delete partitions, resize APFS containers, or change the default startup disk automatically.
- Review Linux-side artifacts first:
  - scripts/cidre-uninstall-check
  - scripts/cidre-state-export --include-logs --include-reports
  - scripts/cidre-partition-audit
  - scripts/cidre-macos-restore-guide
- Then, from macOS:
  - ./install-macos --restore-check
  - ./install-macos --partition-audit
  - ./install-macos --startup-disk-check
  - ./install-macos --uninstall-guide
  - ./install-macos --restore-report

Destructive operations remain unavailable in this release.
EOF
  exit 0
fi

if [ "$RESCUE_HELP" -eq 1 ]; then
  cat <<'EOF'
Cidre Rescue Slot guidance

- v0.27.0 introduces Rescue Boot Integration planning for cases where main Cidre no longer boots.
- Recommended size: 6-12 GiB, with 8 GiB as a reasonable starting point.
- Rescue is a minimal ALARM-based environment, not a daily desktop.
- v0.27.0 does not create partitions or modify boot entries automatically.
- Use Rescue for mount/export/kernel inspection.
- macOS-side planning commands:
  - ./install-macos --rescue-check
  - ./install-macos --rescue-disk-audit
  - ./install-macos --rescue-plan
  - ./install-macos --rescue-guide
  - ./install-macos --rescue-report
- Use macOS Restore Assistant if Rescue cannot recover main Cidre.
EOF
  exit 0
fi

choose_profile

if [ "$PRINT_HANDOFF" -eq 1 ]; then
  require_macos
  exec "$SCRIPT_DIR/cidre-macos-handoff" --profile "$PROFILE" --state-dir "$REPO_ROOT/.local/state/cidre/macos-bootstrap"
fi

require_macos

printf 'Cidre macOS Bootstrap\n\n'
printf 'This tool prepares your Apple Silicon Mac for a Cidre installation.\n'
printf 'Cidre will not directly modify APFS containers, resize partitions, or change Apple Silicon boot policy.\n'
printf 'Disk preparation and OS installation are handled by the Asahi/ALARM installer.\n\n'

"$SCRIPT_DIR/cidre-macos-check"

printf '\nSelected profile:\n  %s\n' "$PROFILE"
printf '\nNext:\n'
printf '  1. Run the ALARM/Asahi installer\n'
printf '  2. Boot into the new ALARM environment\n'
printf '  3. Run Cidre preinstall/install continuation\n'

if [ "$DRY_RUN" -eq 1 ]; then
  printf '\n[DRY-RUN] Would create macOS bootstrap manifest under .local/state/cidre/macos-bootstrap/.\n'
  if [ "$NO_SEED" -eq 1 ]; then
    printf '[DRY-RUN] Seed creation disabled by --no-seed.\n'
  else
    "$SCRIPT_DIR/cidre-macos-seed" --profile "$PROFILE" --dry-run
  fi
  printf '[DRY-RUN] Would print ALARM/Asahi installer handoff instructions.\n\n'
  "$SCRIPT_DIR/cidre-macos-handoff" --profile "$PROFILE" --state-dir "$REPO_ROOT/.local/state/cidre/macos-bootstrap"
  exit 0
fi

if [ "$NO_SEED" -eq 0 ]; then
  "$SCRIPT_DIR/cidre-macos-seed" --profile "$PROFILE"
else
  printf '\nSeed creation skipped by --no-seed.\n'
fi

printf '\n'
"$SCRIPT_DIR/cidre-macos-handoff" --profile "$PROFILE" --state-dir "$REPO_ROOT/.local/state/cidre/macos-bootstrap"
