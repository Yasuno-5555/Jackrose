#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/cidre/boot-safety/current"
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-before-shutdown-gate [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

mkdir -p "$STATE_DIR"
gate_json="$("$SCRIPT_DIR/cidre-app-boot-safety-gate" --json 2>/dev/null || true)"
rollback_json="$("$SCRIPT_DIR/cidre-app-rollback-report-check" --json 2>/dev/null || true)"
mutation_json="$("$SCRIPT_DIR/cidre-app-mutation-report" --json 2>/dev/null || true)"
live_drill_json="$("$SCRIPT_DIR/cidre-app-live-drill-report" --json 2>/dev/null || true)"
install_json="$("$SCRIPT_DIR/cidre-app-install-report" --json 2>/dev/null || true)"
python3 - "$STATE_DIR/before-shutdown-gate.json" "$json_mode" "$gate_json" "$rollback_json" "$mutation_json" "$live_drill_json" "$install_json" <<'PY'
import json
import sys

state_file, json_mode, gate_raw, rollback_raw, mutation_raw, live_drill_raw, install_raw = sys.argv[1:]
json_mode = json_mode == "true"

try:
    gate = json.loads(gate_raw)
except Exception:
    gate = {}
try:
    rollback = json.loads(rollback_raw)
except Exception:
    rollback = {}
try:
    mutation = json.loads(mutation_raw)
except Exception:
    mutation = {}
try:
    live_drill = json.loads(live_drill_raw)
except Exception:
    live_drill = {}
try:
    install = json.loads(install_raw)
except Exception:
    install = {}

allowed = gate.get("status") == "passed" and rollback.get("status") == "passed" and mutation.get("status") != "failed" and live_drill.get("status") != "failed" and install.get("status") != "failed"
payload = {
    "schema_version": 1,
    "command": "cidre-app-before-shutdown-gate",
    "status": "pass" if allowed else "blocked",
    "summary": "Shutdown/restart UI may be shown." if allowed else "Shutdown/restart UI must remain blocked.",
    "phase": "safety",
    "stage": "before-shutdown-gate",
    "exit_code": 0 if allowed else 4,
    "warnings": [] if allowed else ["Do not offer Finish, Restart, or Shutdown from the installer yet."],
    "errors": [] if allowed else [{"code": "boot-safety-not-verified", "message": install.get("summary") if install.get("status") == "failed" else live_drill.get("summary") if live_drill.get("status") == "failed" else mutation.get("summary") if mutation.get("status") == "failed" else gate.get("summary", "Boot safety gate blocked shutdown.")}],
    "shutdown_allowed": allowed,
}

with open(state_file, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY
