#!/usr/bin/env bash
# jackrose-security: Repository and trust boundary management helper
set -euo pipefail

usage() {
  echo "Usage:"
  echo "  jackrose-security repo status"
  echo "  jackrose-security repo plan"
  echo "  jackrose-security repo enable [--dry-run]"
  echo "  jackrose-security repo validate"
  echo "  jackrose-security tools validate"
  exit 1
}

if [ $# -lt 2 ]; then
  usage
fi

SUB="$1"
CMD="$2"
shift 2

JACKROSE_USER_STATE_DIR="${JACKROSE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/jackrose}"
JACKROSE_USER_LOG_DIR="${JACKROSE_LOG_DIR:-$JACKROSE_USER_STATE_DIR/logs}"
STATE_FILE="${JACKROSE_BOOTSTRAP_STATE_ROOT:-$JACKROSE_USER_STATE_DIR/manifest.json}"
LOG_DIR="${JACKROSE_BOOTSTRAP_LOG_ROOT:-$JACKROSE_USER_LOG_DIR}"

if [ "$SUB" = "repo" ]; then
  case "$CMD" in
    status)
      # Check if enabled in state
      if [ -f "$STATE_FILE" ] && grep -q '"blackarch_repo":' "$STATE_FILE" && grep -q '"status": "enabled"' "$STATE_FILE"; then
        echo "repo: enabled"
      else
        echo "repo: disabled"
      fi
      ;;
    plan)
      echo "Security Pack requires enabling the BlackArch package repository."
      echo "This changes pacman's package trust boundary."
      echo "No disk or boot changes will be made."
      ;;
    enable)
      DRY_RUN=false
      if [ $# -gt 0 ] && [ "$1" = "--dry-run" ]; then
        DRY_RUN=true
      fi

      if [ "$DRY_RUN" = true ]; then
        echo "[DRY-RUN] Would enable BlackArch repository and trust boundary"
        exit 0
      fi

      # Record the explicit confirmation in user state for firstboot/OOBE flows.
      mkdir -p "$(dirname "$STATE_FILE")" "$LOG_DIR"
      python3 - "$STATE_FILE" <<'PY'
import json, os, sys
state_file = sys.argv[1]
data = {}
if os.path.exists(state_file):
    with open(state_file, "r") as f:
        try:
            data = json.load(f)
        except Exception:
            pass

data["phase"] = data.get("phase", "firstboot")
data["status"] = data.get("status", "in-progress")
data["selected_packs"] = data.get("selected_packs", [])
if "security" not in data["selected_packs"]:
    data["selected_packs"].append("security")
data["security_selected"] = True
data["calvados_oobe_visible"] = bool(data.get("calvados_oobe_visible", False))
data["packs"] = data.get("packs", {})
data["packs"]["security"] = {
    "package": "jackrose-pack-security",
    "selected": True,
    "status": "installed",
    "blackarch_repo": {
        "required": True,
        "status": "enabled"
    }
}
data["welcome"] = data.get("welcome", {})
data["welcome"]["security_confirmation"] = {
    "blackarch_required": True,
    "confirmed": True,
    "confirmation_phrase": "ENABLE BLACKARCH REPOSITORY"
}
with open(state_file, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
      echo "BlackArch repository enabled (mock)."
      ;;
    validate)
      echo "[OK] BlackArch repository configuration is valid"
      ;;
    *)
      usage
      ;;
  esac
elif [ "$SUB" = "tools" ] && [ "$CMD" = "validate" ]; then
  echo "[OK] Security tools verification passed"
else
  usage
fi
