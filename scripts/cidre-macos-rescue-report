#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/cidre-macos-restore-common"

output_file="$PWD/.local/state/cidre/macos-rescue/current/macos-rescue-report.md"
json_output=false

usage() {
  cat <<EOF
Usage: cidre-macos-rescue-report [options]

Options:
  --output <file>
  --json
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --output) output_file="$2"; shift 2 ;;
    --json) json_output=true; shift ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

cidre_macos_restore_require_macos
mkdir -p "$(dirname "$output_file")"
disk_audit_status="$( [ -f "$PWD/.local/state/cidre/macos-rescue/current/macos-rescue-disk-audit.json" ] && printf generated || printf pending )"
plan_status="$( [ -f "$PWD/.local/state/cidre/macos-rescue/current/macos-rescue-plan.md" ] && printf generated || printf pending )"
guide_status="$( [ -f "$PWD/.local/state/cidre/macos-rescue/current/macos-rescue-guide.md" ] && printf generated || printf pending )"

cat > "$output_file" <<EOF
# Cidre macOS Rescue Report

- macOS environment: ready
- disk audit status: \`$disk_audit_status\`
- rescue plan status: \`$plan_status\`
- rescue guide status: \`$guide_status\`
- risk summary: planning-only, destructive operations unavailable
- pending validation: real Apple Silicon rescue boot
EOF

if [ "$json_output" = "true" ]; then
  cat <<EOF
{
  "schema_version": 1,
  "disk_audit": "$disk_audit_status",
  "plan": "$plan_status",
  "guide": "$guide_status"
}
EOF
else
  printf '%s\n' "$output_file"
fi
