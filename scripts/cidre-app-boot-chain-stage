#!/bin/sh
set -eu
# cidre-app-boot-chain-stage
# Deploys the complete Apple Silicon boot chain to a Cidre volume:
#   m1n1 → Linux kernel → initramfs → rootfs
#
# The Cidre volume layout after staging:
#   /boot/
#     m1n1.macho          # stage-1 bootloader (also at System/Library/CoreServices/boot.efi)
#     Image                # Linux kernel
#     initramfs.img        # Initramfs
#     dtb/                 # Device tree blobs (from m1n1 or kernel package)
#   /cidre/
#     rootfs/              # Root filesystem placeholder or tarball
#     install/
#     state/
#   /System/Library/CoreServices/
#     boot.efi             # Copy of m1n1.macho
#     SystemVersion.plist

m1n1_path=""
kernel_path=""
initramfs_path=""
target_mount=""
dry_run=false
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --m1n1-path) m1n1_path="$2"; shift 2 ;;
    --kernel-path) kernel_path="$2"; shift 2 ;;
    --initramfs-path) initramfs_path="$2"; shift 2 ;;
    --target-mount) target_mount="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-boot-chain-stage --m1n1-path <file> --target-mount <path> [--kernel-path <file>] [--initramfs-path <file>] [--dry-run] [--json]"
      echo "Deploys the complete boot chain (m1n1 + kernel + initramfs) to a Cidre volume."
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

[ -n "$m1n1_path" ] || { echo "ERROR: --m1n1-path is required" >&2; exit 2; }
[ -n "$target_mount" ] || { echo "ERROR: --target-mount is required" >&2; exit 2; }

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
steps=""
errors=""
staged_files=""

if [ "$dry_run" = true ]; then
  python3 -c "import json; print(json.dumps({'schema_version':1,'command':'cidre-app-boot-chain-stage','status':'passed','summary':'Dry-run: would deploy m1n1 + kernel + initramfs','exit_code':0,'dry_run':True},indent=2))"
  exit 0
fi

# ── Stage m1n1 ──────────────────────────────────────────────────────
if [ -f "$m1n1_path" ]; then
  # Verify it's a valid Mach-O binary (not a kernelcache/IMG4)
  if ! file "$m1n1_path" 2>/dev/null | grep -q "Mach-O"; then
    errors="${errors}m1n1-not-mach-o($m1n1_path) "
  else
    # Copy to both the boot directory and System/Library/CoreServices
    mkdir -p "$target_mount/boot"
    mkdir -p "$target_mount/System/Library/CoreServices"

    cp "$m1n1_path" "$target_mount/boot/m1n1.macho"
    chmod 755 "$target_mount/boot/m1n1.macho"

    cp "$m1n1_path" "$target_mount/System/Library/CoreServices/boot.efi"
    chmod 755 "$target_mount/System/Library/CoreServices/boot.efi"

    # Save backup as boot.efi.m1n1 (protection against accidental overwrite)
    cp "$m1n1_path" "$target_mount/System/Library/CoreServices/boot.efi.m1n1"
    chmod 755 "$target_mount/System/Library/CoreServices/boot.efi.m1n1"

    # Verify the copy
    if file "$target_mount/System/Library/CoreServices/boot.efi" 2>/dev/null | grep -q "Mach-O"; then
      staged_files="$staged_files boot/m1n1.macho System/Library/CoreServices/boot.efi System/Library/CoreServices/boot.efi.m1n1"
      steps="${steps}m1n1-staged "
    else
      errors="${errors}boot.efi-verify-failed "
    fi
  fi
else
  errors="${errors}m1n1-not-found($m1n1_path) "
fi

# ── Stage kernel ────────────────────────────────────────────────────
if [ -n "$kernel_path" ] && [ -f "$kernel_path" ]; then
  mkdir -p "$target_mount/boot"
  cp "$kernel_path" "$target_mount/boot/Image"
  chmod 644 "$target_mount/boot/Image" 2>/dev/null || true
  staged_files="$staged_files boot/Image"
  steps="${steps}kernel-staged "
fi

# ── Stage initramfs ─────────────────────────────────────────────────
if [ -n "$initramfs_path" ] && [ -f "$initramfs_path" ]; then
  mkdir -p "$target_mount/boot"
  cp "$initramfs_path" "$target_mount/boot/initramfs.img"
  chmod 644 "$target_mount/boot/initramfs.img" 2>/dev/null || true
  staged_files="$staged_files boot/initramfs.img"
  steps="${steps}initramfs-staged "
fi

# ── Stage device trees from m1n1 ────────────────────────────────────
# m1n1 embeds device trees; extract if available
m1n1_dir="$(dirname "$m1n1_path")/../m1n1"
if [ -d "$m1n1_dir/data" ]; then
  # m1n1 doesn't produce separate dtb files; the DT is compiled in
  # For kernel-based DTs, they come from the kernel package
  :
fi

# ── Create SystemVersion.plist if missing ───────────────────────────
if [ ! -f "$target_mount/System/Library/CoreServices/SystemVersion.plist" ]; then
  mkdir -p "$target_mount/System/Library/CoreServices"
  cat > "$target_mount/System/Library/CoreServices/SystemVersion.plist" << 'SVPEOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>CFBundleIdentifier</key><string>com.apple.SystemVersion</string>
<key>ProductBuildVersion</key><string>1</string>
<key>ProductCopyright</key><string>Cidre Project</string>
<key>ProductName</key><string>Cidre</string>
<key>ProductUserVisibleVersion</key><string>1.0</string>
<key>ProductVersion</key><string>1.0</string>
</dict></plist>
SVPEOF
  staged_files="$staged_files System/Library/CoreServices/SystemVersion.plist"
fi

# ── Create m1n1 boot configuration ──────────────────────────────────
# m1n1 uses a config file or default paths on the same volume
# Default behavior: searches for /boot/Image, /boot/initramfs.img
# Device tree is embedded in m1n1 for the detected machine
cat > "$target_mount/boot/m1n1.conf" << 'M1N1EOF'
# Cidre m1n1 boot configuration
# m1n1 auto-detects the machine and loads the appropriate device tree.
# Kernel and initramfs are loaded from /boot/ on this volume.

# Boot target: Linux kernel
chainload=boot/Image

# Initramfs
initramfs=boot/initramfs.img

# Boot arguments for ALARM/Asahi
# These will be appended to the device tree /chosen/bootargs
cmdline=root=/dev/disk0s3 rw loglevel=3
M1N1EOF
staged_files="$staged_files boot/m1n1.conf"
steps="${steps}m1n1-conf-created "

# ── Report ──────────────────────────────────────────────────────────
status="passed"
exit_code=0
summary="Boot chain staged: $steps"

if [ -n "$errors" ]; then
  status="blocked"
  exit_code=4
  summary="$summary Errors: $errors"
fi

python3 - "$json_mode" "$status" "$exit_code" "$summary" "$target_mount" "$staged_files" "$steps" "$errors" <<'PY'
import json, sys
json_mode, status, exit_code, summary, target_mount, staged_files, steps, errors = sys.argv[1:]
exit_code = int(exit_code); json_mode = json_mode == "true"
payload = {
    "schema_version": 1,
    "command": "cidre-app-boot-chain-stage",
    "status": status, "summary": summary, "exit_code": exit_code,
    "target_mount": target_mount,
    "staged_files": staged_files.strip().split() if staged_files.strip() else [],
    "steps_completed": steps.strip() if steps.strip() else None,
}
if errors.strip():
    payload["errors"] = [{"code": "staging-error", "message": errors.strip()}]
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(exit_code)
PY
