#!/bin/sh
set -eu

scope="install"
target=""
level=""
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --scope) scope="$2"; shift 2 ;;
    --target) target="$2"; shift 2 ;;
    --level) level="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h) echo "Usage: cidre-app-gate-evaluate --scope install|shutdown|helper|finish|wizard|live-drill|controlled-install [--level 0|1|2|3] [--target diskXsY] [--json]"; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
CURRENT_DIR="$REPO_ROOT/.local/state/cidre/boot-safety/current"
mkdir -p "$CURRENT_DIR"

killswitch_json="$("$SCRIPT_DIR/cidre-app-installer-killswitch" --status --json 2>/dev/null || true)"
mutation_mode_json="$("$SCRIPT_DIR/cidre-app-mutation-test-mode" --status --json 2>/dev/null || true)"
boot_json="$("$SCRIPT_DIR/cidre-app-boot-safety-gate" --json 2>/dev/null || true)"
shutdown_json="$("$SCRIPT_DIR/cidre-app-before-shutdown-gate" --json 2>/dev/null || true)"
rollback_json="$("$SCRIPT_DIR/cidre-app-rollback-report-check" --json 2>/dev/null || true)"
recovery_json="$("$SCRIPT_DIR/cidre-app-recovery-survival-check" --json 2>/dev/null || true)"
disposable_json=""
install_target_json=""
if [ -n "$target" ]; then
  disposable_json="$("$SCRIPT_DIR/cidre-app-disposable-target-check" --target "$target" --json 2>/dev/null || true)"
  install_target_json="$("$SCRIPT_DIR/cidre-app-install-target-check" --target "$target" --json 2>/dev/null || true)"
fi
guard_json=""
latest_after="$(find "$REPO_ROOT/.local/state/cidre/boot-safety/snapshots" -type f -name '*after*.json' 2>/dev/null | sort | tail -n 1 || true)"
if [ -n "$latest_after" ]; then
  guard_json="$("$SCRIPT_DIR/cidre-app-protected-partition-guard" --snapshot "$latest_after" --json 2>/dev/null || true)"
fi

python3 - "$scope" "$target" "$level" "$json_mode" "$killswitch_json" "$mutation_mode_json" "$boot_json" "$shutdown_json" "$rollback_json" "$recovery_json" "$disposable_json" "$install_target_json" "$guard_json" "$CURRENT_DIR/gate-evaluate-${scope}.json" <<'PY'
import json
import sys

scope, target, level_raw, json_mode, killswitch_raw, mutation_mode_raw, boot_raw, shutdown_raw, rollback_raw, recovery_raw, disposable_raw, install_target_raw, guard_raw, state_file = sys.argv[1:]
json_mode = json_mode == "true"
level = int(level_raw) if level_raw else None

def parse(raw):
    raw = (raw or "").strip()
    if not raw:
        return {}
    try:
        return json.loads(raw)
    except Exception:
        return {}

killswitch = parse(killswitch_raw)
mutation_mode = parse(mutation_mode_raw)
boot = parse(boot_raw)
shutdown = parse(shutdown_raw)
rollback = parse(rollback_raw)
recovery = parse(recovery_raw)
disposable = parse(disposable_raw)
install_target = parse(install_target_raw)
guard = parse(guard_raw)

checks = []
blocked_actions = set()
allowed_actions = set()
status = "passed"

def add_check(check_id, value_status, reason=None):
    global status
    checks.append({"id": check_id, "status": value_status, "reason": reason})
    if value_status in {"failed", "blocked", "unknown", "warn"} and status == "passed":
        status = "failed" if value_status == "failed" else "blocked"

if not killswitch.get("destructive_install_allowed"):
    add_check("installer-killswitch", "blocked", killswitch.get("reason", "installer killswitch active"))
else:
    add_check("installer-killswitch", "passed")

if mutation_mode.get("enabled") and mutation_mode.get("environment_enabled"):
    add_check("mutation-test-mode", "passed")
else:
    add_check("mutation-test-mode", "blocked", mutation_mode.get("summary", "controlled mutation test mode disabled"))

add_check("boot-safety-gate", boot.get("status", "unknown"), boot.get("summary"))
add_check("before-shutdown-gate", shutdown.get("status", "unknown"), shutdown.get("summary"))
add_check("rollback-report", rollback.get("status", "unknown"), rollback.get("summary"))
add_check("recovery-survival", recovery.get("status", "unknown"), recovery.get("summary"))
if target:
    target_allowed = disposable.get("status") == "passed" or install_target.get("status") == "passed"
    target_summary = (
        disposable.get("summary")
        if disposable.get("status") == "passed"
        else install_target.get("summary")
        if install_target.get("status") == "passed"
        else install_target.get("summary")
        or disposable.get("summary")
    )
    add_check("target-review", "passed" if target_allowed else "failed", target_summary)
if guard:
    add_check("protected-partition-guard", guard.get("status", "unknown"), guard.get("summary"))
else:
    add_check("protected-partition-guard", "unknown", "protected partition state missing")

if scope == "helper":
    blocked_actions.update(["disk-mutation"])
    if (
        killswitch.get("destructive_install_allowed")
        and mutation_mode.get("enabled")
        and mutation_mode.get("environment_enabled")
        and recovery.get("status") == "passed"
        and (not target or disposable.get("status") == "passed" or install_target.get("status") == "passed")
    ):
        allowed_actions.update(["dry-run-helper", "disk-mutation-test"])
elif scope == "shutdown":
    blocked_actions.update(["finish", "restart", "shutdown"])
    if boot.get("status") == "passed" and rollback.get("status") == "passed":
        status = "passed"
        blocked_actions.clear()
        allowed_actions.update(["finish", "restart", "shutdown"])
elif scope == "finish":
    blocked_actions.update(["finish", "restart", "shutdown"])
    if boot.get("status") == "passed" and rollback.get("status") == "passed":
        status = "passed"
        blocked_actions.clear()
        allowed_actions.add("finish")
elif scope == "live-drill":
    blocked_actions.update(["live-drill-execution"])
    level_requires_disposable = level in {2, 3}
    gate_ready = (
        killswitch.get("destructive_install_allowed")
        and mutation_mode.get("enabled")
        and mutation_mode.get("environment_enabled")
        and recovery.get("status") == "passed"
        and (not level_requires_disposable or disposable.get("status") == "passed")
    )
    if gate_ready:
        status = "passed"
        blocked_actions.clear()
        allowed_actions.add("live-drill-execution")
elif scope == "controlled-install":
    blocked_actions.update(["controlled-install-execution"])
    gate_ready = (
        killswitch.get("destructive_install_allowed")
        and mutation_mode.get("enabled")
        and mutation_mode.get("environment_enabled")
        and recovery.get("status") == "passed"
        and (not target or disposable.get("status") == "passed" or install_target.get("status") == "passed")
    )
    if gate_ready:
        status = "passed"
        blocked_actions.clear()
        allowed_actions.add("controlled-install-execution")
else:
    blocked_actions.update(["finish", "restart", "shutdown", "disk-mutation"])
    if (
        killswitch.get("destructive_install_allowed")
        and mutation_mode.get("enabled")
        and mutation_mode.get("environment_enabled")
        and recovery.get("status") == "passed"
        and guard.get("status") == "passed"
    ):
        allowed_actions.add("install-execution-test")
    if boot.get("status") == "passed" and rollback.get("status") == "passed":
        allowed_actions.add("finish")

payload = {
    "schema_version": 1,
    "command": "cidre-app-gate-evaluate",
    "status": status,
    "summary": "Boot safety has been verified." if status == "passed" else "Boot safety has not been verified.",
    "checks": checks,
    "allowed_actions": sorted(allowed_actions),
    "blocked_actions": sorted(blocked_actions if status != "passed" else []),
    "scope": scope,
    "target": target or None,
    "exit_code": 0 if status == "passed" else 8,
}
with open(state_file, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")
print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
sys.exit(payload["exit_code"])
PY
