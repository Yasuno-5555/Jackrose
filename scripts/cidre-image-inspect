#!/bin/sh
set -eu

mode=""
target=""
rescue_mode=false

usage() {
  cat <<'EOF'
Usage:
  cidre-image-inspect [options]

Options:
  --overlay <dir>   Inspect rootfs overlay directory
  --rescue-overlay <dir> Inspect rescue overlay directory
  --tar <file>      Inspect overlay tarball listing
  --rootfs <dir>    Inspect mounted rootfs directory
  --rescue          Inspect default rescue overlay
  -h, --help        Show help
EOF
}

check_tar_entry() {
  path="$1"
  tar -tzf "$target" | grep -Fx "$path" >/dev/null 2>&1 && return 0
  tar -tzf "$target" | grep -Fx "$path/" >/dev/null 2>&1 && return 0
  return 1
}

check_path() {
  path="$1"
  case "$mode" in
    --overlay|--rootfs)
      [ -e "$target/$path" ] && printf '[OK] %s\n' "$path" || {
        printf '[FAIL] missing: %s\n' "$path" >&2
        exit 1
      }
      ;;
    --tar)
      check_tar_entry "$path" && printf '[OK] %s\n' "$path" || {
        printf '[FAIL] missing in tar: %s\n' "$path" >&2
        exit 1
      }
      ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --overlay|--tar|--rootfs|--rescue-overlay)
      [ "$#" -ge 2 ] || {
        printf 'ERROR: %s requires a path\n' "$1" >&2
        exit 1
      }
      mode="$1"
      target="$2"
      shift 2
      ;;
    --rescue)
      mode="--rescue-overlay"
      target="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)/rescue/overlay"
      rescue_mode=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'ERROR: unknown option: %s\n' "$1" >&2
      usage
      exit 1
      ;;
  esac
done

[ -n "$mode" ] || {
  usage
  exit 1
}

case "$mode" in
  --overlay|--rootfs|--rescue-overlay)
    [ -d "$target" ] || {
      printf 'ERROR: directory not found: %s\n' "$target" >&2
      exit 1
    }
    ;;
  --tar)
    [ -f "$target" ] || {
      printf 'ERROR: tarball not found: %s\n' "$target" >&2
      exit 1
    }
    ;;
esac

printf 'Cidre image inspection\n\n'

# When in --rootfs mode, delegate to cidre-rootfs-inspect for richer output
if [ "$mode" = "--rootfs" ]; then
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  if [ -x "$SCRIPT_DIR/cidre-rootfs-inspect" ]; then
    exec "$SCRIPT_DIR/cidre-rootfs-inspect" --rootfs "$target" "$@"
  fi
fi

if [ "$mode" = "--rescue-overlay" ] || [ "$rescue_mode" = "true" ]; then
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  exec "$SCRIPT_DIR/cidre-rescue-image-inspect" --overlay "$target"
fi

check_path usr/lib/cidre/cidre-firstboot-root
check_path usr/lib/cidre/cidre-oobe
check_path usr/lib/cidre/cidre-firstboot-state
check_path usr/lib/cidre/cidre-firstboot-handoff
check_path usr/lib/cidre/cidre-seed
check_path usr/lib/cidre/cidre-seed-verify
check_path usr/lib/cidre/cidre-seed-import
check_path usr/lib/cidre/cidre-resume
check_path usr/lib/cidre/cidre-doctor
check_path usr/lib/cidre/cidre-recovery
check_path usr/lib/cidre/cidre-panic
check_path usr/lib/cidre/cidre-recovery-screen
check_path usr/lib/cidre/cidre-safe-mode
check_path usr/lib/cidre/cidre-safe-shell
check_path usr/lib/cidre/cidre-session-failure
check_path usr/lib/cidre/cidre-desktop-failure-detect
check_path usr/lib/cidre/cidre-recovery-actions
check_path usr/lib/cidre/cidre-emergency-banner
check_path usr/lib/cidre/cidre-recovery-report
check_path usr/lib/cidre/cidre-rescue
check_path usr/lib/cidre/cidre-rescue-check
check_path usr/lib/cidre/cidre-rescue-plan
check_path usr/lib/cidre/cidre-rescue-profile
check_path usr/lib/cidre/cidre-rescue-image-build
check_path usr/lib/cidre/cidre-rescue-image-inspect
check_path usr/lib/cidre/cidre-rescue-manifest
check_path usr/lib/cidre/cidre-rescue-mount
check_path usr/lib/cidre/cidre-rescue-export
check_path usr/lib/cidre/cidre-rescue-kernel-check
check_path usr/lib/cidre/cidre-rescue-report
check_path usr/lib/cidre/cidre-rescue-clean
check_path usr/lib/cidre/cidre-rescue-boot-plan
check_path usr/lib/cidre/cidre-rescue-disk-check
check_path usr/lib/cidre/cidre-rescue-slot-metadata
check_path usr/lib/cidre/cidre-rescue-boot-guide
check_path usr/lib/cidre/cidre-rescue-boot-report
check_path usr/lib/cidre/cidre-rescue-create-dry-run
check_path usr/lib/cidre/cidre-rescue-boot-checklist
check_path usr/lib/cidre/cidre-rescue-boot-risk
check_path usr/lib/cidre/cidre-rescue-boot-validate
check_path usr/lib/cidre/cidre-preinstall
check_path usr/lib/cidre/cidre-installer
check_path etc/systemd/system/cidre-firstboot-root.service
check_path etc/systemd/system/cidre-recovery-screen.service
check_path etc/systemd/system/cidre-safe-mode.service
check_path etc/systemd/system/cidre-emergency-banner.service
check_path etc/systemd/system/cidre-desktop-failure.target
check_path etc/systemd/system/cidre-safe-mode.target
check_path etc/systemd/system/multi-user.target.wants/cidre-firstboot-root.service
check_path var/lib/cidre/seed
check_path var/lib/cidre/resume
check_path var/lib/cidre/firstboot-root
check_path var/lib/cidre/rescue
