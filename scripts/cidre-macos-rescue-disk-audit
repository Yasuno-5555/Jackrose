#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/cidre-macos-restore-common"

output_dir="$PWD/.local/state/cidre/macos-rescue/current"
json_output=false

usage() {
  cat <<EOF
Usage: cidre-macos-rescue-disk-audit [options]

Options:
  --json
  --output <dir>
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json) json_output=true; shift ;;
    --output) output_dir="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

cidre_macos_restore_require_macos
mkdir -p "$output_dir"
text_file="$output_dir/macos-rescue-disk-audit.txt"
json_file="$output_dir/macos-rescue-disk-audit.json"
diskutil_list="$(diskutil list 2>/dev/null || true)"
apfs_list="$(diskutil apfs list 2>/dev/null || true)"

cat > "$text_file" <<EOF
Cidre macOS Rescue Disk Audit

This audit is read-only.
It does not create, resize, delete, or modify partitions.

== diskutil list ==
$diskutil_list

== diskutil apfs list ==
$apfs_list
EOF

cat > "$json_file" <<EOF
{
  "schema_version": 1,
  "audit_type": "macos-rescue-disk-audit",
  "destructive_operations": false
}
EOF

if [ "$json_output" = "true" ]; then
  cat "$json_file"
else
  cat "$text_file"
fi
