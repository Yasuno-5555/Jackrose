#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

VERSION=1
MODE="check"
JSON_MODE=0
DRY_RUN=0
RESET_STATE=0

DEFAULT_STATE_ROOT="/var/lib/jackrose/bootstrap"
DEFAULT_LOG_ROOT="/var/log/jackrose"
LOCAL_STATE_ROOT="$REPO_ROOT/.local/state/jackrose/bootstrap"
LOCAL_LOG_ROOT="$REPO_ROOT/.local/state/jackrose/logs"

STATE_ROOT="${JACKROSE_BOOTSTRAP_STATE_ROOT:-$DEFAULT_STATE_ROOT}"
LOG_ROOT="${JACKROSE_BOOTSTRAP_LOG_ROOT:-$DEFAULT_LOG_ROOT}"

RESULTS_FILE=""
STATE_FILE=""
REPORT_TEXT=""
REPORT_JSON=""

steps="
environment_check
user_check
network_check
pacman_check
disk_space_check
repo_setup
keyring_setup
package_install
config_deploy
input_setup
session_setup
service_enable
firstboot_enable
doctor
final_report
"

usage() {
  cat <<'EOF'
Usage:
  jackrose-bootstrap [options]

Options:
  --check                 Run non-destructive readiness checks
  --apply                 Run safe mock bootstrap flow and write state/report artifacts
  --resume                Resume from existing bootstrap state in safe mock mode
  --report                Print the latest bootstrap report
  --reset-state           Remove bootstrap state and reports
  --json                  Emit machine-readable output where supported
  --dry-run               Preview planned apply actions without changing state
  --target-user USER      Specify the target user for configuration deployment
  --force-config          Force overwrite of existing configuration files
  --backup-config         Backup existing configuration before force overwriting (default: true)
  --skip-config-deploy    Skip configuration deployment step
  -h, --help              Show this help
EOF
}

say() {
  printf '%s\n' "$*"
}

warn() {
  printf 'WARN: %s\n' "$*" >&2
}

init_paths() {
  if [ ! -d "$STATE_ROOT" ] && [ ! -w "$(dirname "$STATE_ROOT")" ] 2>/dev/null; then
    STATE_ROOT="$LOCAL_STATE_ROOT"
  fi
  if [ ! -d "$LOG_ROOT" ] && [ ! -w "$(dirname "$LOG_ROOT")" ] 2>/dev/null; then
    LOG_ROOT="$LOCAL_LOG_ROOT"
  fi

  STATE_FILE="$STATE_ROOT/state.json"
  REPORT_TEXT="$LOG_ROOT/bootstrap-report.txt"
  REPORT_JSON="$LOG_ROOT/bootstrap-report.json"
  RESULTS_FILE="$(mktemp)"
  trap 'rm -f "$RESULTS_FILE"' EXIT HUP INT TERM
}

ensure_dirs() {
  mkdir -p "$STATE_ROOT" "$LOG_ROOT"
}

emit_result() {
  level="$1"
  key="$2"
  summary="$3"
  detail="${4:-}"
  printf '%s|%s|%s|%s\n' "$level" "$key" "$summary" "$detail" >> "$RESULTS_FILE"
}

has_failures() {
  grep -Eq '^(FAIL|BLOCKED)\|' "$RESULTS_FILE"
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

check_linux() {
  if [ "$(uname -s)" = "Linux" ]; then
    emit_result OK running_on_linux "running on Linux"
  else
    emit_result FAIL running_on_linux "not running on Linux" "current kernel is $(uname -s)"
  fi
}

check_arch() {
  arch="$(uname -m 2>/dev/null || printf 'unknown')"
  if [ "$arch" = "aarch64" ] || [ "$arch" = "arm64" ]; then
    emit_result OK architecture "architecture is $arch"
  else
    emit_result WARN architecture "architecture is $arch" "expected aarch64 for supported Apple Silicon bootstrap"
  fi
}

check_asahi_alarm() {
  model="$(cat /proc/device-tree/model 2>/dev/null || true)"
  release="$(uname -r 2>/dev/null || true)"
  os_release="$(cat /etc/os-release 2>/dev/null || true)"
  if printf '%s\n%s\n%s\n' "$model" "$release" "$os_release" | grep -Eiq 'asahi|arch linux arm|alarm'; then
    emit_result OK asahi_alarm "Asahi or ALARM environment detected"
  else
    emit_result WARN asahi_alarm "Asahi or ALARM environment not confidently detected" "manual verification recommended"
  fi
}

check_normal_user() {
  if [ "$(id -u)" -eq 0 ]; then
    if awk -F: '$3 >= 1000 && $1 != "nobody" { found=1 } END { exit found ? 0 : 1 }' /etc/passwd 2>/dev/null; then
      emit_result OK normal_user "normal user exists"
    else
      emit_result WARN normal_user "normal user not detected" "bootstrap may need to create or prepare one later"
    fi
  else
    emit_result OK normal_user "current user is $(id -un)"
  fi
}

check_network() {
  if command_exists ip && ip route get 1.1.1.1 >/dev/null 2>&1; then
    emit_result OK network "network appears reachable"
  else
    emit_result WARN network "network reachability not confirmed" "connect using nmcli or equivalent"
  fi
}

check_dns() {
  if command_exists getent && getent hosts archlinuxarm.org >/dev/null 2>&1; then
    emit_result OK dns "DNS lookup works"
  elif command_exists ping && ping -c 1 -W 2 archlinuxarm.org >/dev/null 2>&1; then
    emit_result OK dns "DNS lookup works"
  else
    emit_result WARN dns "DNS lookup failed" "package sync may fail until DNS is fixed"
  fi
}

check_pacman() {
  if ! command_exists pacman; then
    emit_result FAIL pacman "pacman is not available"
    return
  fi
  if pacman -Sup --print-format '%n' bash >/dev/null 2>&1; then
    emit_result OK pacman "pacman package metadata query succeeded"
  else
    emit_result WARN pacman "pacman package metadata query failed" "sync database or network may be unavailable"
  fi
}

check_privilege() {
  if [ "$(id -u)" -eq 0 ]; then
    emit_result OK privilege "running as root"
  elif command_exists sudo; then
    emit_result OK privilege "sudo is available"
  else
    emit_result WARN privilege "sudo is not available" "root mode will be required for later bootstrap stages"
  fi
}

check_disk_space() {
  free_kb="$(df -Pk / 2>/dev/null | awk 'NR==2 {print $4}')"
  if [ -z "${free_kb:-}" ]; then
    emit_result WARN disk_space "disk space could not be determined"
    return
  fi
  if [ "$free_kb" -ge 5242880 ]; then
    emit_result OK disk_space "enough disk space is available" "free_kb=$free_kb"
  else
    emit_result WARN disk_space "disk space may be too low" "free_kb=$free_kb, recommended >= 5242880"
  fi
}

check_clock() {
  year="$(date +%Y 2>/dev/null || printf '0')"
  if [ "$year" -ge 2024 ] && [ "$year" -le 2035 ]; then
    emit_result OK clock "system clock is sane"
  else
    emit_result WARN clock "system clock may be wrong" "current year is $year"
  fi
}

check_japanese_locale() {
  if locale -a 2>/dev/null | grep -Eq 'ja_JP\.utf8|ja_JP\.UTF-8'; then
    emit_result OK japanese_locale "Japanese locale is available"
  else
    emit_result WARN japanese_locale "Japanese locale not configured"
  fi
}

check_tty() {
  if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
    emit_result OK session_context "graphical session detected"
  else
    emit_result WARN session_context "running from TTY"
  fi
}

run_checks() {
  : > "$RESULTS_FILE"
  check_linux
  check_arch
  check_asahi_alarm
  check_normal_user
  check_network
  check_dns
  check_pacman
  check_privilege
  check_disk_space
  check_clock
  check_japanese_locale
  check_tty
}

print_human_results() {
  while IFS='|' read -r level key summary detail; do
    case "$level" in
      OK) prefix='[OK]' ;;
      WARN) prefix='[WARN]' ;;
      FAIL) prefix='[FAIL]' ;;
      BLOCKED) prefix='[BLOCKED]' ;;
      *) prefix='[INFO]' ;;
    esac
    if [ -n "$detail" ]; then
      say "$prefix $summary ($detail)"
    else
      say "$prefix $summary"
    fi
  done < "$RESULTS_FILE"
}

print_json_results() {
  python3 - "$RESULTS_FILE" <<'PY'
import json, sys
path = sys.argv[1]
items = []
overall = "ok"
with open(path, "r", encoding="utf-8") as fh:
    for raw in fh:
        level, key, summary, detail = raw.rstrip("\n").split("|", 3)
        items.append({
            "level": level.lower(),
            "key": key,
            "summary": summary,
            "detail": detail or None,
        })
        if level in {"FAIL", "BLOCKED"}:
            overall = "fail"
        elif level == "WARN" and overall == "ok":
            overall = "warn"
print(json.dumps({
    "schema_version": 1,
    "command": "jackrose-bootstrap",
    "mode": "check",
    "status": overall,
    "results": items,
}, ensure_ascii=False, indent=2))
PY
}

iso_now() {
  date -Iseconds
}

write_state() {
  status="$1"
  last_error="$2"
  python3 - "$STATE_FILE" "$status" "$last_error" "$(iso_now)" <<'PY'
import json, os, sys
state_file, status, last_error, now = sys.argv[1:5]
steps = [
    "environment_check",
    "user_check",
    "network_check",
    "pacman_check",
    "disk_space_check",
    "repo_setup",
    "keyring_setup",
    "package_install",
    "config_deploy",
    "input_setup",
    "session_setup",
    "service_enable",
    "firstboot_enable",
    "doctor",
    "final_report",
]
data = {
    "version": 1,
    "status": status,
    "started_at": now,
    "updated_at": now,
    "steps": {step: "pending" for step in steps},
    "last_error": None if last_error == "null" else last_error,
}
if os.path.exists(state_file):
    with open(state_file, "r", encoding="utf-8") as fh:
        current = json.load(fh)
    data.update(current)
    data["status"] = status
    data["updated_at"] = now
    data["last_error"] = None if last_error == "null" else last_error
with open(state_file, "w", encoding="utf-8") as fh:
    json.dump(data, fh, ensure_ascii=False, indent=2)
PY
}

update_step() {
  step="$1"
  value="$2"
  python3 - "$STATE_FILE" "$step" "$value" "$(iso_now)" <<'PY'
import json, sys
state_file, step, value, now = sys.argv[1:5]
with open(state_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)
data.setdefault("steps", {})[step] = value
data["updated_at"] = now
with open(state_file, "w", encoding="utf-8") as fh:
    json.dump(data, fh, ensure_ascii=False, indent=2)
PY
}

update_config_deploy_state() {
  local tgt_user="$1"
  local tgt_home="$2"
  local src="$3"
  local dst="$4"
  local action="$5"
  local backup="$6"
  local validation="$7"

  python3 - "$STATE_FILE" "$tgt_user" "$tgt_home" "$src" "$dst" "$action" "$backup" "$validation" "$(iso_now)" <<'PY'
import json, sys
state_file, tgt_user, tgt_home, src, dst, action, backup, validation, now = sys.argv[1:10]

with open(state_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)

data.setdefault("steps", {})["config_deploy"] = "done"
data["config_deploy"] = {
    "target_user": tgt_user,
    "target_home": tgt_home,
    "niri_config_source": src,
    "niri_config_target": dst,
    "niri_config_action": action,
    "backup_path": None if backup == "null" or not backup else backup,
    "validation": validation
}
data["updated_at"] = now

with open(state_file, "w", encoding="utf-8") as fh:
    json.dump(data, fh, ensure_ascii=False, indent=2)
PY
}

detect_target_user() {
  if [ -n "${TARGET_USER:-}" ]; then
    echo "$TARGET_USER"
    return 0
  fi
  if [ -n "${SUDO_USER:-}" ]; then
    echo "$SUDO_USER"
    return 0
  fi
  local cur_user
  cur_user="$(id -un)"
  if [ "$cur_user" != "root" ]; then
    echo "$cur_user"
    return 0
  fi
  local normal_user
  normal_user="$(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1; exit}' /etc/passwd 2>/dev/null)"
  if [ -n "$normal_user" ]; then
    echo "$normal_user"
    return 0
  fi
  return 1
}

resolve_target_home() {
  if [ -n "${JACKROSE_TEST_HOME:-}" ]; then
    echo "$JACKROSE_TEST_HOME"
    return 0
  fi
  local user="$1"
  eval echo "~$user"
}

validate_niri_config() {
  local cfg="$1"
  if [ ! -f "$cfg" ]; then
    say "[FAIL] Source niri config not found at $cfg"
    return 1
  fi
  if grep -qi 'cidre' "$cfg"; then
    say "[FAIL] legacy Cidre reference found in $cfg"
    return 1
  fi
  if grep -q 'ghostty || foot' "$cfg"; then
    say "[FAIL] baseline config must not prefer Ghostty in $cfg"
    return 1
  fi
  if ! grep -q 'spawn "foot"' "$cfg"; then
    say "[FAIL] foot terminal binding not found in $cfg"
    return 1
  fi
  if ! grep -q '/usr/share/jackrose/' "$cfg"; then
    say "[FAIL] Jackrose asset path not found in $cfg"
    return 1
  fi

  if [ -x "${SRC_VALIDATE_SCRIPT:-}" ]; then
    if ! "$SRC_VALIDATE_SCRIPT" "$cfg"; then
      say "[FAIL] validate-jackrose-niri-config failed for $cfg"
      return 1
    fi
  else
    if command_exists niri; then
      if ! niri validate -c "$cfg" >/dev/null 2>&1; then
        say "[FAIL] niri validate failed for $cfg"
        return 1
      fi
    fi
  fi
  return 0
}

run_config_deploy() {
  local tgt_user
  tgt_user="$(detect_target_user || true)"
  if [ -z "$tgt_user" ]; then
    say "[FAIL] Cannot determine target user."
    say "Run one of:"
    say "sudo jackrose-bootstrap --apply --target-user USER"
    return 1
  fi
  if [ "$tgt_user" = "root" ] && [ "${TARGET_USER:-}" != "root" ]; then
    say "[FAIL] Cannot determine target user (detected root)."
    say "Run one of:"
    say "sudo jackrose-bootstrap --apply --target-user USER"
    return 1
  fi

  local tgt_home
  tgt_home="$(resolve_target_home "$tgt_user")"
  if [ -z "$tgt_home" ] || [ ! -d "$tgt_home" ]; then
    say "[FAIL] Cannot resolve target home directory for $tgt_user"
    return 1
  fi

  local src_niri_config=""
  local src_wallpaper=""
  local src_welcome_md=""
  local src_welcome_ja_md=""
  SRC_VALIDATE_SCRIPT=""

  if [ -f "/usr/share/jackrose/defaults/niri/config.kdl" ]; then
    src_niri_config="/usr/share/jackrose/defaults/niri/config.kdl"
    src_wallpaper="/usr/share/jackrose/backgrounds/default.png"
    src_welcome_md="/usr/share/jackrose/welcome/content/desktop-basics.md"
    src_welcome_ja_md="/usr/share/jackrose/welcome/content/desktop-basics.ja.md"
    SRC_VALIDATE_SCRIPT="/usr/share/jackrose/defaults/niri/validate-jackrose-niri-config"
  elif [ -f "$REPO_ROOT/resources/niri/config.kdl" ]; then
    src_niri_config="$REPO_ROOT/resources/niri/config.kdl"
    src_wallpaper="$REPO_ROOT/resources/backgrounds/jackrose-default.png"
    src_welcome_md="$REPO_ROOT/components/welcome/content/desktop-basics.md"
    src_welcome_ja_md="$REPO_ROOT/components/welcome/content/desktop-basics.ja.md"
    SRC_VALIDATE_SCRIPT="$REPO_ROOT/scripts/dev/validate-jackrose-niri-config"
  else
    say "[FAIL] Could not find default config path."
    return 1
  fi

  if [ ! -f "$src_niri_config" ]; then
    say "[FAIL] Source niri config not found: $src_niri_config"
    return 1
  fi

  if ! validate_niri_config "$src_niri_config"; then
    say "[FAIL] Source niri config validation failed."
    update_config_deploy_state "$tgt_user" "$tgt_home" "$src_niri_config" "$tgt_home/.config/niri/config.kdl" "failed" "" "failed"
    return 1
  fi

  local target_config="$tgt_home/.config/niri/config.kdl"
  local target_welcome_dir="$tgt_home/.config/jackrose/welcome"

  if [ "$DRY_RUN" -eq 1 ]; then
    say "[DRY-RUN] Would deploy niri config:"
    say "  source: $src_niri_config"
    say "  target: $target_config"
    say "[DRY-RUN] Existing config policy:"
    say "  preserve by default"

    if [ -f "$target_config" ]; then
      if [ "$FORCE_CONFIG" -eq 1 ]; then
        local ts
        ts="$(date +%Y%m%d-%H%M%S)"
        say "[DRY-RUN] Existing niri config would be backed up and replaced."
        say "[DRY-RUN] Backup path: $target_config.jackrose-backup-$ts"
      else
        say "[DRY-RUN] Existing niri config would be preserved."
      fi
    else
      say "[DRY-RUN] Niri config would be installed (missing at target)."
    fi

    say "[DRY-RUN] Would create welcome directory: $target_welcome_dir"
    say "[DRY-RUN] Would deploy welcome content to $target_welcome_dir"
    return 0
  fi

  if [ "$SKIP_CONFIG_DEPLOY" -eq 1 ]; then
    say "[SKIP] Niri config deployment skipped by request."
    update_config_deploy_state "$tgt_user" "$tgt_home" "$src_niri_config" "$target_config" "skipped" "" "passed"
    return 0
  fi

  local user_uid
  user_uid="$(id -u "$tgt_user")"
  local user_gid
  user_gid="$(id -g "$tgt_user")"

  mkdir -p "$(dirname "$target_config")"
  mkdir -p "$target_welcome_dir"
  chown -R "$tgt_user:$user_gid" "$(dirname "$target_config")"
  chown -R "$tgt_user:$user_gid" "$target_welcome_dir"

  local action="installed"
  local backup_path="null"

  if [ -f "$target_config" ]; then
    if [ "$FORCE_CONFIG" -eq 1 ]; then
      local ts
      ts="$(date +%Y%m%d-%H%M%S)"
      backup_path="$target_config.jackrose-backup-$ts"
      cp "$target_config" "$backup_path"
      chown "$tgt_user:$user_gid" "$backup_path"
      cp "$src_niri_config" "$target_config"
      chown "$tgt_user:$user_gid" "$target_config"
      action="backup_and_replaced"
      say "[OK] Niri config backed up to $backup_path and replaced."
    else
      action="preserved_existing"
      say "[SKIP] Existing niri config preserved: $target_config"
    fi
  else
    cp "$src_niri_config" "$target_config"
    chown "$tgt_user:$user_gid" "$target_config"
    say "[OK] Niri config installed to $target_config"
  fi

  if [ -f "$src_welcome_md" ]; then
    cp "$src_welcome_md" "$target_welcome_dir/desktop-basics.md"
    chown "$tgt_user:$user_gid" "$target_welcome_dir/desktop-basics.md"
  fi
  if [ -f "$src_welcome_ja_md" ]; then
    cp "$src_welcome_ja_md" "$target_welcome_dir/desktop-basics.ja.md"
    chown "$tgt_user:$user_gid" "$target_welcome_dir/desktop-basics.ja.md"
  fi

  update_config_deploy_state "$tgt_user" "$tgt_home" "$src_niri_config" "$target_config" "$action" "$backup_path" "passed"
  return 0
}

run_firstboot_enable() {
  local tgt_user
  tgt_user="$(detect_target_user || true)"
  if [ -z "$tgt_user" ]; then
    say "[FAIL] Cannot determine target user for firstboot."
    return 1
  fi

  local firstboot_dir="$(dirname "$STATE_ROOT")/firstboot"
  local pending_file="$firstboot_dir/pending.json"
  local service_src=""

  if [ -f "$REPO_ROOT/components/firstboot/jackrose-firstboot.service" ]; then
    service_src="$REPO_ROOT/components/firstboot/jackrose-firstboot.service"
  else
    service_src="/usr/lib/systemd/user/jackrose-firstboot.service"
  fi

  local welcome_cmd="jackrose-welcome --firstboot"
  local status_val="pending"
  local enabled_val="false"
  local action_msg="Could not enable systemd user service from current context"

  if [ "$DRY_RUN" -eq 1 ]; then
    say "[DRY-RUN] Would enable firstboot welcome:"
    say "  target user: $tgt_user"
    say "  service: jackrose-firstboot.service"
    say "  command: $welcome_cmd"
    say "  pending marker: $pending_file"
    return 0
  fi

  mkdir -p "$firstboot_dir"

  cat > "$pending_file" <<EOF
{
  "version": 1,
  "status": "pending",
  "target_user": "$tgt_user",
  "welcome_command": "$welcome_cmd",
  "bootstrap_state": "$STATE_FILE",
  "bootstrap_report": "$REPORT_JSON"
}
EOF

  local is_target_user=0
  if [ "$(id -un)" = "$tgt_user" ]; then
    is_target_user=1
  fi

  if [ "$is_target_user" -eq 1 ]; then
    if command_exists systemctl; then
      if systemctl --user enable jackrose-firstboot.service >/dev/null 2>&1; then
        enabled_val="true"
        status_val="enabled"
        action_msg="User service enabled"
        say "[OK] Firstboot user service enabled."
      else
        action_msg="Failed to enable systemd user service via systemctl"
        warn "Could not enable systemd user service. Manual fallback required."
      fi
    fi
  else
    status_val="manual_fallback_required"
    say "[WARN] Could not enable systemd user service from current context. Manual fallback required."
  fi

  python3 - "$STATE_FILE" "$tgt_user" "$status_val" "$enabled_val" "$(iso_now)" <<'PY'
import json, sys
state_file, tgt_user, status_val, enabled_val, now = sys.argv[1:6]

with open(state_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)

data.setdefault("steps", {})["firstboot_enable"] = "done"
data["firstboot"] = {
    "target_user": tgt_user,
    "status": status_val,
    "service": "jackrose-firstboot.service",
    "enabled": enabled_val == "true",
    "fallback_command": "jackrose-firstboot --run",
    "welcome_command": "jackrose-welcome --firstboot"
}
data["updated_at"] = now

with open(state_file, "w", encoding="utf-8") as fh:
    json.dump(data, fh, ensure_ascii=False, indent=2)
PY

  return 0
}


build_report() {
  failed_step="$1"
  last_error="$2"
  python3 - "$STATE_FILE" "$REPORT_TEXT" "$REPORT_JSON" "$failed_step" "$last_error" "$(iso_now)" <<'PY'
import json, os, sys, subprocess

state_file, report_text, report_json, failed_step, last_error, now = sys.argv[1:7]

installed = "none detected"
try:
    if subprocess.call(["command", "-v", "pacman"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0:
        res = subprocess.run(["pacman", "-Qq"], capture_output=True, text=True)
        pkgs = [line for line in res.stdout.splitlines() if line.startswith("jackrose")]
        if pkgs:
            installed = " ".join(pkgs)
except Exception:
    pass

next_cmd = "scripts/jackrose-bootstrap --check"
if os.path.exists(state_file):
    next_cmd = "sudo scripts/jackrose-bootstrap --resume"

state_data = {}
if os.path.exists(state_file):
    try:
        with open(state_file, "r", encoding="utf-8") as fh:
            state_data = json.load(fh)
    except Exception:
        pass

txt = []
txt.append("Jackrose Bootstrap Report")
txt.append("")
txt.append(f"timestamp: {now}")
try:
    hostname = subprocess.check_output(["hostname"], text=True).strip()
except Exception:
    hostname = "unknown"
txt.append(f"hostname: {hostname}")

try:
    kernel = " ".join(os.uname()[:2])
except Exception:
    kernel = "unknown"
txt.append(f"kernel: {kernel}")

try:
    arch = os.uname().machine
except Exception:
    arch = "unknown"
txt.append(f"architecture: {arch}")

distro = "unknown"
if os.path.exists("/etc/os-release"):
    with open("/etc/os-release", "r") as fh:
        for line in fh:
            if line.startswith("PRETTY_NAME="):
                distro = line.split("=", 1)[1].strip().strip('"')
txt.append(f"detected distro: {distro}")

import getpass
txt.append(f"current user: {getpass.getuser()}")
txt.append("installed Jackrose packages: " + installed)
txt.append(f"failed step: {failed_step}")
txt.append(f"last error: {last_error}")
txt.append(f"state file: {state_file}")
txt.append(f"next suggested command: {next_cmd}")

cfg_deploy = state_data.get("config_deploy")
if cfg_deploy:
    txt.append("")
    txt.append("Config Deploy")
    txt.append("")
    txt.append(f"[OK] Target user: {cfg_deploy.get('target_user')}")
    txt.append(f"[OK] Target home: {cfg_deploy.get('target_home')}")
    
    source = cfg_deploy.get('niri_config_source')
    if source and os.path.exists(source):
        txt.append("[OK] Source niri config found")
    else:
        txt.append("[FAIL] Source niri config not found")
        
    validation = cfg_deploy.get('validation')
    if validation == "passed":
        txt.append("[OK] Source niri config validated")
    else:
        txt.append(f"[FAIL] Source niri config validation: {validation}")
        
    txt.append("[OK] Jackrose wallpaper path configured")
    
    action = cfg_deploy.get('niri_config_action')
    if action == "installed":
        txt.append(f"[OK] Niri config installed: {cfg_deploy.get('niri_config_target')}")
    elif action == "preserved_existing":
        txt.append(f"[SKIP] Existing niri config preserved: {cfg_deploy.get('niri_config_target')}")
    elif action == "backup_and_replaced":
        txt.append(f"[OK] Niri config backed up and replaced: {cfg_deploy.get('niri_config_target')}")
        txt.append(f"     Backup path: {cfg_deploy.get('backup_path')}")
    elif action == "skipped":
        txt.append("[SKIP] Niri config deploy skipped")
    elif action == "failed":
        txt.append("[FAIL] Niri config deploy failed")

firstboot = state_data.get("firstboot")
if firstboot:
    txt.append("")
    txt.append("Firstboot Welcome")
    txt.append("")
    txt.append(f"[OK] Target user: {firstboot.get('target_user')}")
    txt.append("[OK] Firstboot service found")
    txt.append("[OK] Firstboot pending marker written")
    
    if firstboot.get("enabled"):
        txt.append("[OK] User service enabled")
        txt.append("")
        txt.append("Next:")
        txt.append("Log in to Jackrose. Welcome will start automatically.")
        txt.append("")
        txt.append(f"Fallback:\n{firstboot.get('fallback_command')}")
    else:
        txt.append("[WARN] Could not enable systemd user service from current context")
        txt.append("")
        txt.append("Manual fallback:")
        txt.append("systemctl --user enable --now jackrose-firstboot.service")
        txt.append(f"{firstboot.get('fallback_command')}")

with open(report_text, "w", encoding="utf-8") as fh:
    fh.write("\n".join(txt) + "\n")

json_payload = {
    "schema_version": 1,
    "command": "jackrose-bootstrap",
    "state_file": state_file,
    "report_text": report_text,
    "failed_step": None if failed_step == "none" else failed_step,
    "last_error": None if last_error == "none" else last_error,
}
if state_data:
    json_payload["state"] = state_data

with open(report_json, "w", encoding="utf-8") as fh:
    json.dump(json_payload, fh, ensure_ascii=False, indent=2)
PY
}

run_check_mode() {
  run_checks
  if [ "$JSON_MODE" -eq 1 ]; then
    print_json_results
  else
    say "Jackrose Bootstrap"
    say
    say "This tool converts an Asahi ALARM minimal system into a Jackrose desktop environment."
    say
    print_human_results
  fi
}

run_apply_mode() {
  ensure_dirs
  if [ "$DRY_RUN" -eq 1 ]; then
    run_checks
    say "Jackrose Bootstrap"
    say
    say "Dry-run only. Planned steps:"
    for step in $steps; do
      say "- $step"
    done
    say
    print_human_results
    say
    run_config_deploy
    say
    run_firstboot_enable
    return
  fi

  write_state "in_progress" "null"
  run_checks

  if has_failures; then
    update_step environment_check failed
    write_state "failed" "readiness checks failed"
    build_report "environment_check" "readiness checks failed"
    if [ "$JSON_MODE" -eq 1 ]; then
      cat "$REPORT_JSON"
    else
      say "Bootstrap failed at: environment_check"
      say
      say "Reason:"
      say "readiness checks failed"
      say
      say "Try:"
      say "sudo scripts/jackrose-bootstrap --resume"
      say
      say "Report:"
      say "$REPORT_TEXT"
    fi
    return 1
  fi

  update_step environment_check done
  update_step user_check done
  update_step network_check done
  update_step pacman_check done
  update_step disk_space_check done

  # Execute real config_deploy step
  if ! run_config_deploy; then
    update_step config_deploy failed
    write_state "failed" "config deployment failed"
    build_report "config_deploy" "config deployment failed"
    return 1
  fi

  # Execute real firstboot_enable step
  if ! run_firstboot_enable; then
    update_step firstboot_enable failed
    write_state "failed" "firstboot enable failed"
    build_report "firstboot_enable" "firstboot enable failed"
    return 1
  fi

  for step in repo_setup keyring_setup package_install input_setup session_setup service_enable doctor; do
    update_step "$step" "safe_mock_pending"
  done
  update_step final_report done
  write_state "ready_for_manual_apply" "null"
  build_report "none" "none"

  if [ "$JSON_MODE" -eq 1 ]; then
    cat "$REPORT_JSON"
  else
    say "Jackrose Bootstrap"
    say
    say "Safe mock apply completed."
    say "No destructive or package-changing actions were executed."
    say
    say "State:"
    say "$STATE_FILE"
    say "Report:"
    say "$REPORT_TEXT"
  fi
}

run_resume_mode() {
  ensure_dirs
  if [ ! -f "$STATE_FILE" ]; then
    warn "no bootstrap state found at $STATE_FILE"
    return 1
  fi
  run_apply_mode
}

run_report_mode() {
  ensure_dirs
  if [ ! -f "$REPORT_TEXT" ] || [ ! -f "$REPORT_JSON" ]; then
    run_checks
    build_report "none" "none"
  fi
  if [ "$JSON_MODE" -eq 1 ]; then
    cat "$REPORT_JSON"
  else
    cat "$REPORT_TEXT"
  fi
}

run_reset_state() {
  rm -f "$STATE_FILE" "$REPORT_TEXT" "$REPORT_JSON"
  say "Reset bootstrap state and reports."
}

TARGET_USER=""
FORCE_CONFIG=0
BACKUP_CONFIG=1
SKIP_CONFIG_DEPLOY=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --check) MODE="check"; shift ;;
    --apply) MODE="apply"; shift ;;
    --resume) MODE="resume"; shift ;;
    --report) MODE="report"; shift ;;
    --reset-state) RESET_STATE=1; shift ;;
    --json) JSON_MODE=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --target-user) TARGET_USER="$2"; shift 2 ;;
    --force-config) FORCE_CONFIG=1; shift ;;
    --backup-config) BACKUP_CONFIG=1; shift ;;
    --skip-config-deploy) SKIP_CONFIG_DEPLOY=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *)
      printf 'ERROR: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

init_paths

if [ "$RESET_STATE" -eq 1 ]; then
  ensure_dirs
  run_reset_state
  exit 0
fi

case "$MODE" in
  check) run_check_mode ;;
  apply) run_apply_mode ;;
  resume) run_resume_mode ;;
  report) run_report_mode ;;
esac
