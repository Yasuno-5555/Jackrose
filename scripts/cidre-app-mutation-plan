#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/cidre/mutation/current"

operation=""
target=""
container_size=""
partition_size=""
volume_name="Cidre"
plan_id=""
json_mode=false

usage() {
  echo "Usage: cidre-app-mutation-plan --operation <name> --target diskXsY [--container-size 200G --partition-size 80G --volume-name Cidre] [--plan-id id] [--json]"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --operation) operation="$2"; shift 2 ;;
    --target) target="$2"; shift 2 ;;
    --container-size) container_size="$2"; shift 2 ;;
    --partition-size) partition_size="$2"; shift 2 ;;
    --volume-name) volume_name="$2"; shift 2 ;;
    --plan-id) plan_id="$2"; shift 2 ;;
    --json) json_mode=true; shift ;;
    --help|-h) usage; exit 0 ;;
    *) echo "ERROR: unknown option: $1" >&2; usage; exit 2 ;;
  esac
done

[ -n "$operation" ] || { echo "ERROR: --operation is required" >&2; exit 2; }
[ -n "$target" ] || { echo "ERROR: --target is required" >&2; exit 2; }
mkdir -p "$STATE_DIR"

python3 - "$STATE_DIR" "$operation" "$target" "$container_size" "$partition_size" "$volume_name" "$plan_id" "$json_mode" <<'PY'
import hashlib
import json
import os
import sys
from datetime import datetime, timezone

state_dir, operation, target, container_size, partition_size, volume_name, plan_id, json_mode = sys.argv[1:]
json_mode = json_mode == "true"

if not plan_id:
    digest = hashlib.sha256(f"{operation}\n{target}\n{container_size}\n{partition_size}\n{volume_name}".encode()).hexdigest()[:10]
    plan_id = f"mutation-{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}-{digest}"

plan = {
    "schema_version": 1,
    "plan_id": plan_id,
    "operation": operation,
    "target": target,
    "destructive": True,
    "test_mode_required": True,
    "disposable_target_required": True,
    "required_checks": [
        "protected-partition-guard",
        "recovery-survival",
        "pre-snapshot",
        "confirmation",
    ],
    "container_size": container_size or None,
    "partition_size": partition_size or None,
    "volume_name": volume_name or None,
    "created_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
}

plan_json = json.dumps(plan, indent=2, sort_keys=True)
plan_hash = hashlib.sha256(plan_json.encode()).hexdigest()
plan["plan_hash"] = plan_hash

plan_file = os.path.join(state_dir, f"{plan_id}.plan.json")
with open(plan_file, "w", encoding="utf-8") as handle:
    json.dump(plan, handle, indent=2, sort_keys=True)
    handle.write("\n")
with open(os.path.join(state_dir, "last-plan.json"), "w", encoding="utf-8") as handle:
    json.dump(plan, handle, indent=2, sort_keys=True)
    handle.write("\n")

payload = dict(plan)
payload.update({
    "command": "cidre-app-mutation-plan",
    "status": "passed",
    "summary": "Mutation plan generated.",
    "exit_code": 0,
    "plan_file": plan_file,
})

print(json.dumps(payload, indent=2) if json_mode else payload["summary"])
PY
