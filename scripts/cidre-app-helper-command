#!/bin/sh
set -eu

operation=""
target=""
container_size=""
volume_name="Cidre"
partition_size=""
plan_id=""
plan_path=""
signature_path=""
confirmation_file=""
confirmation=""
dry_run=false
json_mode=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --operation) operation="$2"; shift 2 ;;
    --target) target="$2"; shift 2 ;;
    --container-size) container_size="$2"; shift 2 ;;
    --volume-name) volume_name="$2"; shift 2 ;;
    --partition-size) partition_size="$2"; shift 2 ;;
    --plan-id) plan_id="$2"; shift 2 ;;
    --plan) plan_path="$2"; shift 2 ;;
    --signature) signature_path="$2"; shift 2 ;;
    --confirmation-file) confirmation_file="$2"; shift 2 ;;
    --confirm) confirmation="$2"; shift 2 ;;
    --dry-run) dry_run=true; shift ;;
    --json) json_mode=true; shift ;;
    --help|-h)
      echo "Usage: cidre-app-helper-command --operation partition-create|partition-delete|apfs-add-volume|apfs-delete-volume|apfs-resize-container --target diskN|diskNsM [--container-size 200G] [--volume-name Cidre] [--partition-size 80G] [--plan-id ID] --plan plan.json --signature plan.sig.json --confirmation-file confirmation.json [--confirm token] [--dry-run] [--json]"
      exit 0
      ;;
    *) echo "ERROR: unknown option: $1" >&2; exit 2 ;;
  esac
done

[ -n "$operation" ] || { echo "ERROR: --operation is required" >&2; exit 2; }
[ -n "$target" ] || { echo "ERROR: --target is required" >&2; exit 2; }
[ -n "$plan_id" ] || plan_id="$(date -u +%Y%m%dT%H%M%SZ)-$$"
[ -n "$signature_path" ] || [ -z "$plan_path" ] || signature_path="${plan_path}.sig.json"

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
HELPER_PACKAGE="$REPO_ROOT/apps/macos/CidreApp/Helper/CidrePrivilegedHelper"
PACKAGED_HELPER="$REPO_ROOT/libexec/CidrePrivilegedHelper"
STATE_DIR="${CIDRE_STATE_DIR:-$HOME/Library/Application Support/Cidre/state/app-wizard/current}"
MUTATION_STATE_DIR="$REPO_ROOT/.local/state/cidre/mutation/current"
mkdir -p "$STATE_DIR" "$MUTATION_STATE_DIR"
request_file="$(mktemp /tmp/cidre-helper-request.XXXXXX.json)"
trap 'rm -f "$request_file"' EXIT HUP INT TERM

if [ "$operation" = "partition-create" ] || [ "$operation" = "apfs-resize-container" ] || [ "$operation" = "apfs-add-volume" ] || [ "$operation" = "apfs-delete-volume" ] || [ "$operation" = "controlled-install" ]; then
  gate_operation="$operation"
  gate_level=""
  if [ "$operation" = "apfs-add-volume" ] || [ "$operation" = "apfs-delete-volume" ]; then
    gate_operation="live-drill"
    gate_level="3"
  fi
  helper_gate_json="$("$SCRIPT_DIR/cidre-app-helper-gate" --operation "$gate_operation" ${gate_level:+--level "$gate_level"} --target "$target" --json 2>/dev/null || true)"
  helper_allowed="$(printf '%s\n' "$helper_gate_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("status") == "passed" else "false")' 2>/dev/null || printf false)"
  if [ "$helper_allowed" != "true" ]; then
    if [ "$json_mode" = true ]; then
      printf '%s\n' "$helper_gate_json"
    else
      printf '%s\n' "$helper_gate_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary","Helper mutation is blocked."))'
    fi
    exit 8
  fi

  killswitch_json="$("$SCRIPT_DIR/cidre-app-installer-killswitch" --status --json)"
  destructive_allowed="$(printf '%s\n' "$killswitch_json" | python3 -c 'import json,sys; print(str(json.load(sys.stdin).get("destructive_install_allowed", False)).lower())')"
  if [ "$destructive_allowed" != "true" ]; then
    python3 - "$json_mode" <<'PY'
import json
import sys
payload = {
    "schema_version": 1,
    "command": "cidre-app-helper-command",
    "status": "blocked",
    "summary": "Disk-changing install is disabled by DFU incident containment.",
    "phase": "disk",
    "stage": "execute",
    "exit_code": 4,
    "warnings": ["Enable the installer test override only after validating the controlled mutation test flow."],
    "errors": [{"code": "installer-killswitch-disabled", "message": "Disk-changing install is disabled by DFU incident containment."}],
}
print(json.dumps(payload, indent=2) if sys.argv[1] == "true" else payload["summary"])
sys.exit(4)
PY
  fi

  mutation_mode_json="$("$SCRIPT_DIR/cidre-app-mutation-test-mode" --status --json)"
  mutation_enabled="$(printf '%s\n' "$mutation_mode_json" | python3 -c 'import json,sys; data=json.load(sys.stdin); print("true" if data.get("enabled") and data.get("environment_enabled") else "false")' 2>/dev/null || printf false)"
  if [ "$mutation_enabled" != "true" ]; then
    python3 - "$json_mode" <<'PY'
import json
import sys
payload = {
    "schema_version": 1,
    "command": "cidre-app-helper-command",
    "status": "blocked",
    "summary": "Controlled mutation test mode is not fully enabled.",
    "phase": "disk",
    "stage": "execute",
    "exit_code": 4,
    "warnings": [],
    "errors": [{"code": "mutation-test-mode-disabled", "message": "Enable CIDRE_MUTATION_TEST_MODE=1 and cidre-app-mutation-test-mode before helper mutation."}],
}
print(json.dumps(payload, indent=2) if sys.argv[1] == "true" else payload["summary"])
sys.exit(4)
PY
  fi

  use_install_target_check=false
  if [ "$operation" = "controlled-install" ]; then
    use_install_target_check=true
  elif [ -n "$plan_path" ] && [ -f "$plan_path" ]; then
    use_install_target_check="$(python3 - "$plan_path" <<'PY'
import json
import sys
with open(sys.argv[1], "r", encoding="utf-8") as handle:
    plan = json.load(handle)
print("true" if plan.get("install_target_required") else "false")
PY
)"
  fi
  if [ "$use_install_target_check" = "true" ]; then
    disposable_json="$("$SCRIPT_DIR/cidre-app-install-target-check" --target "$target" --json 2>/dev/null || true)"
  else
    disposable_json="$("$SCRIPT_DIR/cidre-app-disposable-target-check" --target "$target" --json 2>/dev/null || true)"
  fi
  disposable_allowed="$(printf '%s\n' "$disposable_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("status") == "passed" else "false")' 2>/dev/null || printf false)"
  if [ "$disposable_allowed" != "true" ]; then
    if [ "$json_mode" = true ]; then
      printf '%s\n' "$disposable_json"
    else
      printf '%s\n' "$disposable_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary","Disposable target check failed."))'
    fi
    exit 8
  fi

  [ -n "$plan_path" ] || { echo "ERROR: --plan is required for destructive helper mutation" >&2; exit 4; }
  [ -n "$signature_path" ] || { echo "ERROR: --signature is required for destructive helper mutation" >&2; exit 4; }
  [ -n "$confirmation_file" ] || { echo "ERROR: --confirmation-file is required for destructive helper mutation" >&2; exit 4; }

  if [ "$operation" = "controlled-install" ]; then
    plan_verify_json="$("$SCRIPT_DIR/cidre-app-install-plan-verify" --plan "$plan_path" --signature "$signature_path" --json 2>/dev/null || true)"
  else
    plan_verify_json="$("$SCRIPT_DIR/cidre-app-mutation-plan-verify" --plan "$plan_path" --signature "$signature_path" --json 2>/dev/null || true)"
  fi
  plan_allowed="$(printf '%s\n' "$plan_verify_json" | python3 -c 'import json,sys; print("true" if json.load(sys.stdin).get("status") == "passed" else "false")' 2>/dev/null || printf false)"
  if [ "$plan_allowed" != "true" ]; then
    if [ "$json_mode" = true ]; then
      printf '%s\n' "$plan_verify_json"
    else
      printf '%s\n' "$plan_verify_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary","Mutation plan verification failed."))'
    fi
    exit 8
  fi

  confirmation_valid="$(python3 - "$plan_path" "$confirmation_file" "$confirmation" "$dry_run" "$operation" "$target" <<'PY'
import hashlib
import json
import sys

plan_path, confirmation_file, provided_token, dry_run, operation, target = sys.argv[1:]
with open(plan_path, "rb") as handle:
    plan_bytes = handle.read()
with open(confirmation_file, "r", encoding="utf-8") as handle:
    confirmation = json.load(handle)
plan = json.loads(plan_bytes.decode("utf-8"))
expected_hash = hashlib.sha256(plan_bytes).hexdigest()
matches = (
    confirmation.get("status") == "passed"
    and confirmation.get("plan_hash") == expected_hash
    and plan.get("target") == target
    and (plan.get("helper_operation") == operation or plan.get("operation") == operation or plan.get("mode") == "controlled-manual-boot" or plan.get("helper_operation") == "live-drill")
    and (dry_run == "true" or confirmation.get("confirmation_token") == provided_token)
)
print("true" if matches else "false")
PY
)"
  if [ "$confirmation_valid" != "true" ]; then
    python3 - "$json_mode" <<'PY'
import json
import sys
payload = {
    "schema_version": 1,
    "command": "cidre-app-helper-command",
    "status": "blocked",
    "summary": "Mutation confirmation token is invalid.",
    "phase": "disk",
    "stage": "execute",
    "exit_code": 4,
    "warnings": [],
    "errors": [{"code": "confirmation-token-invalid", "message": "The helper refused to trust the provided confirmation token."}],
}
print(json.dumps(payload, indent=2) if sys.argv[1] == "true" else payload["summary"])
sys.exit(4)
PY
  fi
fi

arguments_json="$(python3 - "$operation" "$container_size" "$volume_name" "$partition_size" <<'PY'
import json
import sys

operation, container_size, volume_name, partition_size = sys.argv[1:]
if operation == "partition-create":
    args = [container_size, volume_name, partition_size]
elif operation == "apfs-add-volume":
    args = ["APFS", volume_name]
elif operation == "apfs-resize-container":
    args = [container_size]
else:
    args = []
print(json.dumps(args))
PY
)"

python3 - "$request_file" "$operation" "$target" "$dry_run" "$confirmation" "$plan_id" "$STATE_DIR/helper-audit.log" "$arguments_json" "$plan_path" "$signature_path" "$confirmation_file" <<'PY'
import json
import sys

path, operation, target, dry_run, confirmation, plan_id, audit_path, arguments, plan_path, signature_path, confirmation_file = sys.argv[1:]
payload = {
    "schema_version": 1,
    "operation": operation,
    "target": target,
    "dry_run": dry_run == "true",
    "confirmation_token": confirmation or None,
    "plan_id": plan_id,
    "plan_path": plan_path or None,
    "signature_path": signature_path or None,
    "confirmation_file": confirmation_file or None,
    "audit_log_path": audit_path,
    "arguments": json.loads(arguments),
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle)
PY
chmod 600 "$request_file"

if [ "$(uname -s)" != "Darwin" ]; then
  python3 - "$json_mode" <<'PY'
import json
import sys
payload = {"schema_version":1,"command":"cidre-app-helper-command","status":"blocked","summary":"Privileged disk operations require macOS.","phase":"disk","stage":"execute","exit_code":4,"warnings":[],"errors":[{"code":"requires-macos","message":"Privileged disk operations require macOS."}]}
print(json.dumps(payload, indent=2) if sys.argv[1] == "true" else payload["summary"])
PY
  exit 4
fi

if [ -x "$PACKAGED_HELPER" ]; then
  helper="$PACKAGED_HELPER"
else
  bin_dir="$(swift build -c release --package-path "$HELPER_PACKAGE" --show-bin-path)"
  helper="$bin_dir/CidrePrivilegedHelper"
  if [ ! -x "$helper" ] || [ -n "$(find "$HELPER_PACKAGE/Sources" -type f -newer "$helper" -print -quit 2>/dev/null)" ]; then
    swift build -c release --package-path "$HELPER_PACKAGE" >/dev/null
  fi
fi

if [ "$dry_run" = true ]; then
  output="$($helper "$request_file" || true)"
else
  [ -n "$confirmation_file" ] || [ "$confirmation" = "CIDRE EXECUTE $plan_id" ] || {
    echo "ERROR: confirmation must be exactly: CIDRE EXECUTE $plan_id" >&2
    exit 4
  }
  elevated_command="$(python3 - "$helper" "$request_file" <<'PY'
import shlex
import sys
print(f"{shlex.quote(sys.argv[1])} {shlex.quote(sys.argv[2])} || true")
PY
)"
  output="$(/usr/bin/osascript \
    -e 'on run argv' \
    -e 'do shell script (item 1 of argv) with administrator privileges' \
    -e 'end run' \
    "$elevated_command")"
fi

printf '%s\n' "$output" >> "$STATE_DIR/helper-results.jsonl"
printf '%s\n' "$output" | python3 - "$MUTATION_STATE_DIR/last-helper-output.json" <<'PY'
import json
import sys

payload = json.load(sys.stdin)
with open(sys.argv[1], "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")
PY

if [ "$json_mode" = true ]; then
  printf '%s\n' "$output"
else
  printf '%s\n' "$output" | python3 -c 'import json,sys; print(json.load(sys.stdin)["summary"])'
fi

status="$(printf '%s\n' "$output" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("status", "fail"))')"
[ "$status" = pass ] || [ "$status" = passed ]
