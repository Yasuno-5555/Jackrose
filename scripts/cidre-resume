#!/bin/sh
set -eu

CIDRE_SYSTEM_ROOT="${CIDRE_SYSTEM_ROOT:-/var/lib/cidre}"
SYSTEM_RESUME="$CIDRE_SYSTEM_ROOT/resume/resume.env"
USER_RESUME="${HOME}/.local/state/cidre/resume"

usage() {
  cat <<'EOF'
Usage:
  cidre-resume <command> [args]

Commands:
  status
  show
  profile
  validate [--profile <name>]
EOF
}

load_resume() {
  [ -f "$SYSTEM_RESUME" ] || {
    printf 'ERROR: no Cidre resume state found.\n' >&2
    exit 1
  }

  CIDRE_SEED_SCHEMA_VERSION=""
  CIDRE_PROFILE=""
  CIDRE_INSTALL_MODE=""
  # shellcheck disable=SC1090
  . "$SYSTEM_RESUME"
}

cmd="${1:-status}"

case "$cmd" in
  status)
    if [ -f "$SYSTEM_RESUME" ]; then
      printf '[OK] resume state found\n'
      if [ -f "$USER_RESUME/applied-profile" ]; then
        printf '[OK] user resume state applied\n'
      else
        printf '[WARN] user resume state not yet applied\n'
      fi
    else
      printf '[WARN] no Cidre resume state found\n'
      exit 1
    fi
    ;;
  show)
    load_resume
    printf 'Cidre resume state\n\n'
    printf 'profile: %s\n' "${CIDRE_PROFILE:-unknown}"
    printf 'install mode: %s\n' "${CIDRE_INSTALL_MODE:-unknown}"
    if [ -f "$USER_RESUME/applied-profile" ]; then
      printf 'user applied profile: %s\n' "$(cat "$USER_RESUME/applied-profile")"
    fi
    ;;
  profile)
    load_resume
    printf '%s\n' "${CIDRE_PROFILE:-}"
    ;;
  validate)
    load_resume
    if [ "${CIDRE_SEED_SCHEMA_VERSION:-0}" -lt 1 ]; then
      printf 'ERROR: Seed schema version legacy or invalid: %s (expected >= 1)\n' "${CIDRE_SEED_SCHEMA_VERSION:-0}" >&2
      exit 1
    fi
    expected_profile=""
    while [ "$#" -gt 1 ]; do
      case "$2" in
        --profile) expected_profile="$3"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [ -n "$expected_profile" ] && [ -n "${CIDRE_PROFILE:-}" ]; then
      if [ "$expected_profile" != "$CIDRE_PROFILE" ]; then
        printf 'WARN: Requested profile (%s) does not match seed profile (%s)\n' "$expected_profile" "$CIDRE_PROFILE" >&2
      fi
    fi
    printf '[OK] resume state validation successful\n'
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'ERROR: unknown resume command: %s\n' "$cmd" >&2
    usage
    exit 1
    ;;
esac
