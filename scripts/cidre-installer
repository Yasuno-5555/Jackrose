#!/bin/bash
# cidre-installer: Main guided installer orchestration tool for Cidre desktop
set -euo pipefail

# ----- Source shared libraries -----
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CIDRE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export CIDRE_ROOT

if [ -f "$CIDRE_ROOT/lib/cidre/ui.sh" ]; then
  source "$CIDRE_ROOT/lib/cidre/ui.sh"
fi

# ----- Configuration variables -----
DRY_RUN=false
CHECK_ONLY=false
PROFILE=""
YES=false
NO_CONFIRM_DANGEROUS=false  # --no-confirm does NOT skip dangerous operations
NO_COLOR=false
RC_DRY_RUN=false
RESUME_MODE=false
NO_RESUME=false
DOCTOR_MODE=false
REPAIR_MODE=false
CIDRE_SYSTEM_ROOT="${CIDRE_SYSTEM_ROOT:-/var/lib/cidre}"
SYSTEM_RESUME_FILE="${CIDRE_SYSTEM_ROOT}/resume/resume.env"
INSTALL_DASHBOARD=false
INSTALL_STATE=false
INSTALL_REPORT=false
INSTALL_VERIFY=false

show_help() {
  echo "Usage: install [options]"
  echo ""
  echo "Install profiles (mutually exclusive):"
  echo "  --desktop           Desktop install (Niri, Ghostty, waybar, fcitx5 Mozc)"
  echo "  --dev               Developer install (Desktop + dev toolchain, fish, starship)"
  echo "  --student           Student install (lightweight desktop, educational tools)"
  echo "  --minimal           Core session and config deployment only"
  echo "  --repair            Repair an existing Cidre installation"
  echo ""
  echo "Other options:"
  echo "  --check             Perform preflight system checks without making changes"
  echo "  --dry-run           Show the commands that would be executed"
  echo "  --doctor            Run cidre-doctor diagnostics and exit"
  echo "  --profile <name>    Set installation profile (desktop, developer, student, minimal, recovery)"
  echo "  --resume            Use imported Cidre resume state to select the profile"
  echo "  --resume-profile    Print the imported resume profile and exit"
  echo "  --no-resume         Ignore imported resume state and use normal selection"
  echo "  --yes               Skip non-dangerous confirmation prompts"
  echo "  --no-confirm        Skip all confirmation prompts EXCEPT dangerous operations"
  echo "  --no-color          Disable colored terminal output"
  echo "  --rc-dry-run        Validate all installer/doctor profiles in simulation mode"
  echo "  --help              Show this help message"
}

# Parse options
while [ $# -gt 0 ]; do
  case "$1" in
    --check) CHECK_ONLY=true; shift ;;
    --dry-run) DRY_RUN=true; shift ;;
    --rc-dry-run) RC_DRY_RUN=true; shift ;;
    --desktop) PROFILE="desktop"; shift ;;
    --dev|--developer) PROFILE="developer"; shift ;;
    --student) PROFILE="student"; shift ;;
    --minimal) PROFILE="minimal"; shift ;;
    --repair) REPAIR_MODE=true; shift ;;
    --doctor) DOCTOR_MODE=true; shift ;;
    --profile)
      if [ $# -lt 2 ]; then
        echo "Error: --profile requires an argument." >&2
        exit 1
      fi
      PROFILE="$2"
      shift 2
      ;;
    --resume) RESUME_MODE=true; shift ;;
    --resume-profile)
      if [ -f "${SYSTEM_RESUME_FILE}" ]; then
        # shellcheck disable=SC1090
        . "${SYSTEM_RESUME_FILE}"
        printf '%s\n' "${CIDRE_RESUME_PROFILE:-}"
        exit 0
      fi
      echo "ERROR: no Cidre resume state found." >&2
      exit 1
      ;;
    --no-resume) NO_RESUME=true; shift ;;
    --yes) YES=true; shift ;;
    --no-confirm) YES=true; NO_CONFIRM_DANGEROUS=true; shift ;;
    --no-color) NO_COLOR=true; shift ;;
    --dashboard) INSTALL_DASHBOARD=true; shift ;;
    --install-state) INSTALL_STATE=true; shift ;;
    --install-report) INSTALL_REPORT=true; shift ;;
    --verify) INSTALL_VERIFY=true; shift ;;
    --help|-h) show_help; exit 0 ;;
    *)
      echo "Unknown option: $1" >&2
      show_help
      exit 1
      ;;
  esac
done

# Validate profile if set
if [ -n "$PROFILE" ]; then
  case "$PROFILE" in
    desktop|developer|student|minimal|recovery) ;;
    *)
      echo "Error: Invalid profile '$PROFILE'." >&2
      echo "Valid profiles: desktop, developer, student, minimal, recovery" >&2
      exit 1
      ;;
  esac
fi

# ----- Mode routing -----

if [ "$INSTALL_DASHBOARD" = true ]; then
  exec "${SCRIPT_DIR}/cidre-install-dashboard"
fi

if [ "$INSTALL_STATE" = true ]; then
  exec "${SCRIPT_DIR}/cidre-install-state" "$@"
fi

if [ "$INSTALL_REPORT" = true ]; then
  exec "${SCRIPT_DIR}/cidre-install-report"
fi

if [ "$INSTALL_VERIFY" = true ]; then
  exec "${SCRIPT_DIR}/cidre-install-verify" --desktop
fi

if [ "$DOCTOR_MODE" = true ]; then
  exec "${SCRIPT_DIR}/cidre-doctor" --daily
fi

if [ "$REPAIR_MODE" = true ]; then
  exec "${SCRIPT_DIR}/cidre-repair"
fi

if [ "$RC_DRY_RUN" = true ]; then
  echo "=== Running Release Candidate Dry-Run Verification ==="
  errors=0

  echo "1. Checking system compatibilities..."
  for cmd in pacman systemctl sudo bash python3 makepkg; do
    if command -v "$cmd" >/dev/null 2>&1; then
      echo "[OK] Command '$cmd' is available."
    else
      echo "[FAIL] Required command '$cmd' is missing."
      errors=$((errors + 1))
    fi
  done

  echo ""
  echo "2. Simulating system bootstrap actions..."
  if "${SCRIPT_DIR}/bootstrap.sh" --dry-run --yes >/dev/null; then
    echo "[OK] Bootstrap dry-run simulated successfully."
  else
    echo "[FAIL] Bootstrap dry-run simulation failed."
    errors=$((errors + 1))
  fi

  for prof in desktop developer student minimal; do
    echo ""
    echo "3. Simulating profile configuration apply: ${prof}..."
    if python3 "${SCRIPT_DIR}/cidre-user-setup" apply --profile "${prof}" --dry-run >/dev/null; then
      echo "[OK] Profile '${prof}' dry-run simulated successfully."
    else
      echo "[FAIL] Profile '${prof}' dry-run simulation failed."
      errors=$((errors + 1))
    fi
  done

  echo ""
  echo "4. Simulating doctor diagnostics readiness check..."
  if "${SCRIPT_DIR}/cidre-doctor" --rc-readiness; then
    echo "[OK] Doctor RC readiness diagnostics check passed."
  else
    echo "[WARN/FAIL] Doctor RC readiness diagnostics check failed or has warnings."
    errors=$((errors + 1))
  fi

  echo ""
  echo "=== RC Dry-Run Verification Summary ==="
  if [ $errors -eq 0 ]; then
    echo "SUCCESS: Release candidate dry-run completed with 0 errors."
    exit 0
  else
    echo "FAILURE: Release candidate dry-run completed with ${errors} issues."
    exit 1
  fi
fi

# ----- Banner -----
if declare -f cidre_banner >/dev/null 2>&1; then
  cidre_banner
else
  echo -e "\e[1;36m====================================================\e[0m"
  echo -e "\e[1;35m               Cidre Guided Installer               \e[0m"
  echo -e "\e[1;36m====================================================\e[0m"
  echo "  The cider after Homebrew."
  echo ""
fi

# ----- Setup logging -----
USER_HOME="${HOME:-$(getent passwd "${USER:-$(id -un)}" | cut -d: -f6)}"
LOG_DIR="${USER_HOME}/.local/state/cidre"
LOG_FILE="${LOG_DIR}/install-$(date +%Y%m%d-%H%M%S).log"
mkdir -p "$LOG_DIR"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "Installation started at $(date)"
echo "Log file: $LOG_FILE"
echo ""

# ----- Trap failure handler -----
failure_handler() {
  local exit_code=$?
  echo ""
  echo "============================================="
  echo -e "\e[1;31m[FAILED] Installation failed at $(date)\e[0m"
  echo "Exit code: $exit_code"
  echo ""
  echo "Likely causes:"
  echo "  - A required package failed to install"
  echo "  - Network connectivity was lost"
  echo "  - pacman database is inconsistent"
  echo ""
  echo "Try:"
  echo "  ./install --repair"
  echo "  scripts/cidre-doctor --daily"
  echo "  sudo pacman -Syy"
  echo ""
  echo "Log:"
  echo "  $LOG_FILE"
  echo "============================================="

  if [ "$DRY_RUN" = false ] && [ "$CHECK_ONLY" = false ] && [ "${RESUME_MODE}" = true ]; then
    "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "failed" >/dev/null || true
    "${SCRIPT_DIR}/cidre-user-phase-state" set-error "installer execution failed with exit code $exit_code" >/dev/null || true
    "${SCRIPT_DIR}/cidre-user-phase-state" mark-failed >/dev/null || true
    "${SCRIPT_DIR}/cidre-user-phase-report" >/dev/null || true
  fi
  exit $exit_code
}
trap failure_handler ERR

write_user_resume_state() {
  if [ "${RESUME_MODE}" = false ]; then
    return 0
  fi
  local user_resume_dir="${LOG_DIR}/resume"
  mkdir -p "${user_resume_dir}"
  if [ -f "${CIDRE_SYSTEM_ROOT}/seed/manifest.json" ]; then
    cp "${CIDRE_SYSTEM_ROOT}/seed/manifest.json" "${user_resume_dir}/manifest.json"
  fi
  printf '%s\n' "${PROFILE}" > "${user_resume_dir}/applied-profile"
  date -Is > "${user_resume_dir}/applied-at"
  {
    echo "resume_mode=true"
    echo "profile=${PROFILE}"
    echo "source_commit=${CIDRE_RESUME_SOURCE_COMMIT:-unknown}"
    echo "source_branch=${CIDRE_RESUME_SOURCE_BRANCH:-unknown}"
    echo "applied_at=$(date -Is)"
  } > "${user_resume_dir}/resume.log"
}

# ----- Root check: show guidance instead of rejecting -----
if [ "$EUID" -eq 0 ] && [ "$DRY_RUN" = false ] && [ "$CHECK_ONLY" = false ] && [ "$RC_DRY_RUN" = false ]; then
  echo ""
  echo -e "\e[1;33mYou are running Cidre as root.\e[0m"
  echo ""
  echo "Cidre uses two phases:"
  echo "  1. Root phase:  create/prepare user, sudo, base dependencies"
  echo "  2. User phase:  install Cidre desktop, session, and configs"
  echo ""
  echo "To run the root phase now:"
  echo "  ./preinstall"
  echo ""
  echo "After root phase, switch to the normal user:"
  echo "  su - <username>"
  echo "  cd $(pwd)"
  echo "  ./install.sh --desktop"
  echo ""
  echo "To inspect readiness first:"
  echo "  scripts/cidre-doctor --base-readiness --summary"
  echo ""
  echo "For a dry-run preview (safe as root):"
  echo "  ./install.sh --desktop --dry-run"
  echo ""
  exit 0
fi

# =====================================================================
# Step 1: System Checks
# =====================================================================
echo "=== Step 1: Running System Preflight Checks ==="
errors=0
warnings=0

if [ -f /etc/arch-release ]; then
  echo "[OK] Arch/ALARM-like environment detected."
else
  echo "[WARN] /etc/arch-release not found. This might not be Arch Linux."
  warnings=$((warnings + 1))
fi

for cmd in pacman systemctl sudo bash python3 makepkg; do
  if command -v "$cmd" >/dev/null 2>&1; then
    echo "[OK] Command '$cmd' is available."
  else
    echo "[FAIL] Required command '$cmd' is missing."
    errors=$((errors + 1))
  fi
done

if [ $errors -gt 0 ]; then
  echo ""
  echo -e "\e[1;31m[FAILED] System compatibility checks failed.${C_RESET:-}"
  echo ""
  echo "Likely causes:"
  echo "  - Fresh ALARM install without base packages"
  echo "  - Running on a non-Arch system"
  echo ""
  echo "Try:"
  echo "  sudo pacman -Syu --needed pacman systemd sudo bash python3 base-devel"
  echo "  ./preinstall --prepare"
  echo ""
  echo "Log: $LOG_FILE"
  exit 1
fi

if [ "$CHECK_ONLY" = true ]; then
  echo ""
  echo "Check-only mode complete. System is ready for install."
  echo "Log: $LOG_FILE"
  exit 0
fi

# =====================================================================
# Resume mode handling
# =====================================================================
if [ "${NO_RESUME}" = true ]; then
  RESUME_MODE=false
fi

if [ "${RESUME_MODE}" = true ]; then
  "${SCRIPT_DIR}/cidre-user-handoff" --import >/dev/null 2>&1 || true

  if ! "${SCRIPT_DIR}/cidre-user-phase-verify"; then
    echo "ERROR: User phase preflight checks failed." >&2
    exit 1
  fi

  "${SCRIPT_DIR}/cidre-user-phase-state" mark-started >/dev/null || true
  "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "init" >/dev/null || true

  if [ ! -f "${SYSTEM_RESUME_FILE}" ]; then
    echo "ERROR: no Cidre resume state found." >&2
    echo "Hint: run ./preinstall --import-seed /path/to/cidre-seed.tar.gz first, or run ./install normally." >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  . "${SYSTEM_RESUME_FILE}"
  RESUME_PROFILE="${CIDRE_PROFILE:-${CIDRE_RESUME_PROFILE:-}}"
  if [ -z "${RESUME_PROFILE}" ]; then
    echo "ERROR: imported Cidre resume state does not include a profile." >&2
    exit 1
  fi
  if [ -n "${PROFILE}" ] && [ "${PROFILE}" != "${RESUME_PROFILE}" ]; then
    echo "[WARN] --profile ${PROFILE} overrides resume profile ${RESUME_PROFILE}."
  else
    PROFILE="${RESUME_PROFILE}"
    echo "Resume profile selected from imported seed: ${PROFILE}"
  fi
fi

# =====================================================================
# Step 2: Profile Selection
# =====================================================================
if [ -z "$PROFILE" ]; then
  if [ "$YES" = true ]; then
    PROFILE="desktop"
    echo "Profile: desktop (auto-selected with --yes)"
  else
    echo ""
    echo "Choose installation profile:"
    echo "  [1] Desktop       Recommended (Niri, Ghostty, waybar, fcitx5 Mozc)"
    echo "  [2] Developer     Desktop + development toolchain (fish, starship prompt)"
    echo "  [3] Student       Lightweight desktop for educational use"
    echo "  [4] Minimal       Core session and config deployment only"
    echo "  [5] Recovery      Diagnostics and recovery tools only"
    read -r -p "Select option [1-5] (default: 1): " opt
    case "$opt" in
      2) PROFILE="developer" ;;
      3) PROFILE="student" ;;
      4) PROFILE="minimal" ;;
      5) PROFILE="recovery" ;;
      *) PROFILE="desktop" ;;
    esac
  fi
fi

# Verify profile
case "$PROFILE" in
  desktop|developer|student|minimal|recovery) ;;
  *)
    echo "Error: Invalid profile '$PROFILE'." >&2
    exit 1
    ;;
esac

# Profile descriptions
profile_desc() {
  case "$1" in
    desktop)   echo "Full desktop (Niri, Ghostty, waybar, fcitx5 Mozc)" ;;
    developer) echo "Developer desktop (+ fish, starship, dev tools)" ;;
    student)   echo "Student pack (lightweight desktop, educational tools)" ;;
    minimal)   echo "Minimal (core session and config only)" ;;
    recovery)  echo "Recovery (diagnostics and recovery tools only)" ;;
  esac
}

echo "Selected profile: $PROFILE — $(profile_desc "$PROFILE")"

# =====================================================================
# Step 3: Preview planned actions
# =====================================================================
echo ""
echo "=== Step 3: Previewing Planned Actions ==="

echo "Proposed bootstrap system actions:"
"${SCRIPT_DIR}/bootstrap.sh" --dry-run --yes

echo ""
SETUP_PROFILE="$PROFILE"
if [ "$PROFILE" = "recovery" ]; then
  SETUP_PROFILE="minimal"
elif [ "$PROFILE" = "student" ]; then
  # Student is desktop minus dev tools
  SETUP_PROFILE="desktop"
fi

echo "Proposed user configuration deployment actions:"
python3 "${SCRIPT_DIR}/cidre-user-setup" apply --profile "$SETUP_PROFILE" --dry-run

if [ "$DRY_RUN" = true ]; then
  echo ""
  echo "Dry-run mode complete. No system modifications were performed."
  echo "Log: $LOG_FILE"
  exit 0
fi

# =====================================================================
# Step 4: Confirmation with BRAND PROMISE
# =====================================================================
echo ""

if declare -f cidre_brand_promise >/dev/null 2>&1; then
  cidre_brand_promise
else
  echo -e "\e[1mCidre will NOT change:\e[0m"
  echo "  - macOS default boot"
  echo "  - NVRAM boot order"
  echo "  - boot policy"
  echo "  - recovery partition"
  echo ""
fi

# Brand promise confirmation is NEVER skipped, even with --no-confirm
# Only --yes in dry-run/check mode skips it
if [ "$YES" = false ] || [ "$NO_CONFIRM_DANGEROUS" = true ]; then
  read -r -p "Ready to install Cidre with profile '$PROFILE'. Continue? [y/N]: " conf
  if [[ ! "$conf" =~ ^[yY] ]]; then
    echo "Installation cancelled by user."
    exit 0
  fi
fi

# =====================================================================
# Step 5: Execute System Bootstrap
# =====================================================================
echo ""
echo "=== Step 5: Executing System Bootstrap ==="

# Update guided installer state
"${SCRIPT_DIR}/cidre-install-state" --set-stage user-install --set-status running --set-next-command "./install --resume"

if [ "${RESUME_MODE}" = true ]; then
  "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "profile-setup" >/dev/null || true
fi

if ! sudo "${SCRIPT_DIR}/bootstrap.sh" --install --yes; then
  echo ""
  echo -e "\e[1;31m[FAILED] System bootstrap failed\e[0m"
  echo ""
  echo "Likely causes:"
  echo "  - pacman database is corrupted or out of sync"
  echo "  - Required dependencies are missing"
  echo "  - Insufficient disk space"
  echo ""
  echo "Try:"
  echo "  sudo pacman -Syy"
  echo "  sudo pacman -Sy archlinuxarm-keyring"
  echo "  ./install --repair"
  echo ""
  echo "Log: $LOG_FILE"
  exit 1
fi

# =====================================================================
# Step 6: Apply User Configurations
# =====================================================================
echo ""
echo "=== Step 6: Applying User Configurations ==="

if [ "${RESUME_MODE}" = true ]; then
  "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "config-apply" >/dev/null || true
fi

if ! python3 "${SCRIPT_DIR}/cidre-user-setup" apply --profile "$SETUP_PROFILE"; then
  echo ""
  echo -e "\e[1;31m[FAILED] User configuration application failed\e[0m"
  echo ""
  echo "Likely causes:"
  echo "  - Config directories not writable"
  echo "  - Missing user home directory"
  echo "  - Profile template is incomplete"
  echo ""
  echo "Try:"
  echo "  python3 ${SCRIPT_DIR}/cidre-user-setup} apply --profile $SETUP_PROFILE --force"
  echo "  ./install --repair"
  echo ""
  echo "Log: $LOG_FILE"
  exit 1
fi

python3 "${SCRIPT_DIR}/cidre-user-setup" verify
write_user_resume_state

# =====================================================================
# Step 7: Diagnostics
# =====================================================================
echo ""
echo "=== Step 7: Running Diagnostics Check ==="

if [ "${RESUME_MODE}" = true ]; then
  "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "desktop-setup" >/dev/null || true
fi

if XDG_SESSION_TYPE=wayland "${SCRIPT_DIR}/cidre-doctor"; then
  if [ "${RESUME_MODE}" = true ]; then
    "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "complete" >/dev/null || true
    "${SCRIPT_DIR}/cidre-user-phase-state" mark-completed >/dev/null || true
    cp "$LOG_FILE" "${USER_STATE_DIR}/install.log" || true
    "${SCRIPT_DIR}/cidre-user-phase-report" >/dev/null || true
  fi
  "${SCRIPT_DIR}/cidre-install-state" --set-stage user-install --set-status passed
  "${SCRIPT_DIR}/cidre-install-state" --set-stage firstboot --set-status pending --set-next-command "sudo reboot" --set-next-stage "user-phase"

  # =====================================================================
  # SUCCESS
  # =====================================================================
  echo ""
  echo -e "\e[1;32m====================================================\e[0m"
  echo -e "\e[1;32m     Cidre Installation Complete!                    \e[0m"
  echo -e "\e[1;32m====================================================\e[0m"
  echo ""
  echo -e "\e[1mNext steps:\e[0m"
  echo "  1. Reboot the system or log out of your current session."
  echo "  2. Select the 'Cidre' graphical session at the greeter screen."
  echo "  3. On first login, run: cidre-welcome"
  echo ""
  echo -e "\e[1mMaintenance Commands:\e[0m"
  echo "  * Diagnostics:          cidre-doctor --daily"
  echo "  * Repair:               cidre-repair --configs"
  echo "  * Audio fix:            cidre-repair --audio"
  echo "  * Update check:         cidre-update --check"
  echo "  * Full recovery:        cidre-recovery status"
  echo ""

else
  if [ "${RESUME_MODE}" = true ]; then
    "${SCRIPT_DIR}/cidre-user-phase-state" set-stage "failed" >/dev/null || true
    "${SCRIPT_DIR}/cidre-user-phase-state" set-error "post-installation doctor verification failed" >/dev/null || true
    "${SCRIPT_DIR}/cidre-user-phase-state" mark-failed >/dev/null || true
    cp "$LOG_FILE" "${USER_STATE_DIR}/install.log" || true
    "${SCRIPT_DIR}/cidre-user-phase-report" >/dev/null || true
  fi
  "${SCRIPT_DIR}/cidre-install-state" --mark-failed "verify-failed"
  "${SCRIPT_DIR}/cidre-install-failure-report" --stage user-install --reason "verify-failed" --output "${CIDRE_ROOT}/.local/state/cidre/install/current/install-failure-report.md"

  echo ""
  echo -e "\e[1;33m=== Diagnostics detected post-install warnings/errors ===\e[0m"
  echo ""
  echo "Likely causes:"
  echo "  - Some desktop services are not yet running (expected before reboot)"
  echo "  - Missing optional components"
  echo "  - Display server not available in current environment"
  echo ""
  echo "Try:"
  echo "  cidre-recovery restore latest"
  echo "  cidre-doctor --last"
  echo "  cidre-doctor --fix-suggestions"
  echo "  ./install --repair"
  echo ""
fi

echo "Installation logs saved to: $LOG_FILE"
