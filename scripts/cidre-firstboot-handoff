#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
CIDRE_SYSTEM_ROOT="${CIDRE_SYSTEM_ROOT:-}"
USER_NAME=""
PROFILE_NAME=""
REPO_PATH="$REPO_ROOT"

state_dir() {
  if [ -z "$CIDRE_SYSTEM_ROOT" ] || [ "$CIDRE_SYSTEM_ROOT" = "/var/lib/cidre" ]; then
    printf '/var/lib/cidre/firstboot-root\n'
  else
    printf '%s/var/lib/cidre/firstboot-root\n' "$CIDRE_SYSTEM_ROOT"
  fi
}

STATE_DIR="$(state_dir)"

usage() {
  cat <<'EOF'
Usage:
  cidre-firstboot-handoff [options]

Options:
  --user <name>
  --profile <name>
  --repo-path <path>
  -h, --help
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --user) USER_NAME="$2"; shift 2 ;;
    --profile) PROFILE_NAME="$2"; shift 2 ;;
    --repo-path) REPO_PATH="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage; exit 1 ;;
  esac
done

[ -n "$USER_NAME" ] || {
  printf 'ERROR: --user is required\n' >&2
  exit 1
}

handoff_dir() {
  if [ -z "$CIDRE_SYSTEM_ROOT" ] || [ "$CIDRE_SYSTEM_ROOT" = "/var/lib/cidre" ]; then
    printf '/var/lib/cidre/handoff\n'
  else
    printf '%s/var/lib/cidre/handoff\n' "$CIDRE_SYSTEM_ROOT"
  fi
}
HANDOFF_DIR="$(handoff_dir)"

mkdir -p "$STATE_DIR" "$HANDOFF_DIR"

# Write user-phase.env
created_time="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
{
  printf 'CIDRE_SELECTED_USER=%s\n' "$USER_NAME"
  printf 'CIDRE_SELECTED_PROFILE=%s\n' "${PROFILE_NAME:-developer}"
  printf 'CIDRE_REPO_PATH=%s\n' "$REPO_PATH"
  printf 'CIDRE_RESUME_STATE_PATH=/var/lib/cidre/resume/resume.env\n'
  printf 'CIDRE_HANDOFF_CREATED_AT=%s\n' "$created_time"
} > "$HANDOFF_DIR/user-phase.env"

# Write user-phase.json
{
  printf '{\n'
  printf '  "schema_version": 1,\n'
  printf '  "selected_user": "%s",\n' "$USER_NAME"
  printf '  "selected_profile": "%s",\n' "${PROFILE_NAME:-developer}"
  printf '  "repo_path": "%s",\n' "$REPO_PATH"
  printf '  "resume_state_path": "/var/lib/cidre/resume/resume.env",\n'
  printf '  "handoff_created_at": "%s",\n' "$created_time"
  printf '  "root_phase_completed": true,\n'
  printf '  "user_phase_started": false,\n'
  printf '  "user_phase_completed": false\n'
  printf '}\n'
} > "$HANDOFF_DIR/user-phase.json"

{
  printf '%s\n' "$USER_NAME" > "$HANDOFF_DIR/selected-user"
  printf '%s\n' "${PROFILE_NAME:-developer}" > "$HANDOFF_DIR/selected-profile"
  printf '%s\n' "$REPO_PATH" > "$HANDOFF_DIR/repo-path"
  printf '/var/lib/cidre/resume/resume.env\n' > "$HANDOFF_DIR/resume-state-path"
  printf '%s\n' "$created_time" > "$HANDOFF_DIR/created-at"
}

{
  printf 'Cidre root phase is complete.\n\n'
  printf 'Next as normal user:\n\n'
  printf '  su - %s\n' "$USER_NAME"
  printf '  cd %s\n' "$REPO_PATH"
  printf '  ./install --resume\n\n'
  printf 'Before installing, verify handoff:\n\n'
  printf '  scripts/cidre-user-handoff --verify\n'
  printf '  scripts/cidre-user-phase-verify\n\n'
  printf 'If something fails:\n\n'
  printf '  scripts/cidre-user-phase-report\n'
  printf '  scripts/cidre-recovery user-phase-status\n\n'
  printf 'Default root credentials are unsafe.\n'
  printf 'Change the root password before using this system as a daily driver.\n\n'
  printf 'Recommended:\n\n'
  printf '  passwd root\n'
} > "$STATE_DIR/handoff.txt"

cp "$STATE_DIR/handoff.txt" "$HANDOFF_DIR/handoff.txt"

printf '%s\n' "$USER_NAME" > "$STATE_DIR/selected-user"
if [ -n "$PROFILE_NAME" ]; then
  printf '%s\n' "$PROFILE_NAME" > "$STATE_DIR/selected-profile"
fi

cat "$STATE_DIR/handoff.txt"
