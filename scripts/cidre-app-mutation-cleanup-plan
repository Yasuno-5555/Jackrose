#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="$REPO_ROOT/.local/state/cidre/mutation/current"

rm -f \
  "$STATE_DIR"/last-plan.json \
  "$STATE_DIR"/last-signature.json \
  "$STATE_DIR"/last-confirmation.json \
  "$STATE_DIR"/last-execution.json \
  "$STATE_DIR"/last-verification.json

echo "Mutation plan state cleaned."
