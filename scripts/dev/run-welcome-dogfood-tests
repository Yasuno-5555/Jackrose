#!/usr/bin/env bash
# run-welcome-dogfood-tests: Run J16 Welcome dogfood validation stack
set -euo pipefail

echo "=== Running Jackrose Welcome Dogfood Tests ==="

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

"$REPO_ROOT"/scripts/dev/validate-jackrose-welcome-dogfood
"$REPO_ROOT"/scripts/dev/validate-jackrose-dogfood-catalogs
"$REPO_ROOT"/scripts/dev/validate-jackrose-pack-depends
"$REPO_ROOT"/scripts/dev/validate-jackrose-p0-feasibility
"$REPO_ROOT"/scripts/dev/validate-jackrose-critical-build-plan

for artifact in /tmp/jackrose-build-artifacts/jackrose-ghostty-*.pkg.tar.* /tmp/jackrose-pkgs/jackrose-ghostty-*.pkg.tar.*; do
  if [ -f "$artifact" ]; then
    "$REPO_ROOT"/scripts/dev/validate-jackrose-ghostty-package --artifact "$artifact"
    break
  fi
done

echo "=== All Jackrose Welcome Dogfood Tests Passed Successfully ==="
