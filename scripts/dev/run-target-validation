#!/bin/bash
# run-target-validation: Phase 7 target package/rootfs validation orchestrator
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

DRY_RUN=0
PACKAGES_ONLY=0
ROOTFS_PATH=""
APPLY=0

usage() {
  echo "Usage: $0 [options]"
  echo "Options:"
  echo "  --dry-run           Perform dry-run simulation of the pipeline"
  echo "  --packages-only     Only build and collect packages"
  echo "  --rootfs <path>     Path to test rootfs to validate"
  echo "  --apply             Perform real package install and firstboot enable (requires --rootfs)"
  echo "  --metadata-only     Run local installer metadata validation checks only"
  echo "  --installer-local-only Run local installer selection integration tests"
  echo "  --real-artifact-only   Run real image artifact binding integration validation tests"
  echo "  --metadata-wiring-only Run local installer wiring integration tests"
  echo "  --release-hosting-only Run local release asset hosting integration tests"
  echo "  --hosted-dev-only      Run hosted dev release fetch integration tests"
  echo "  --installer-compat-only Run upstream installer compatibility study tests"
  echo "  --asahi-adapter-only    Run Asahi metadata adapter prototype tests"
  echo "  --installer-override-only Run INSTALLER_DATA override dryrun tests"
  echo "  --bootstrap-inspection-only Run bootstrap override static inspections"
  echo "  --bootstrap-report-only     Run bootstrap compatibility report tests"
  echo "  --installer-boundary-probe-only Run installer boundary probe tests"
  echo "  --installer-asset-layout-only   Run installer asset layout normalization tests"
  echo "  --metadata-only-override-harness-only Run metadata-only override harness tests"
  echo "  --bootstrap-safe-mode-probe-only      Run bootstrap safe-mode probe tests"
  echo "  --cidre-wrapper-strategy-only         Run Cidre installer wrapper strategy tests"
  echo "  --cidre-wrapper-selection-only        Run Cidre installer wrapper selection tests"
  echo "  --cidre-wrapper-artifact-only         Run Cidre installer wrapper artifact fetch tests"
  echo "  --cidre-wrapper-extraction-only       Run Cidre installer wrapper sandbox extraction tests"
  echo "  --cidre-rootfs-plan-only              Run Cidre installer wrapper rootfs plan tests"
  echo "  --cidre-target-discovery-only         Run Cidre installer wrapper target discovery tests"
  echo "  --cidre-target-selection-only         Run Cidre installer wrapper target selection tests"
  echo "  --cidre-final-contract-only           Run Cidre installer wrapper final contract tests"
  echo "  --cidre-installer-mvp-only            Run Cidre installer wrapper MVP tests"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --packages-only)
      PACKAGES_ONLY=1
      shift
      ;;
    --rootfs)
      if [ $# -lt 2 ]; then
        echo "ERROR: --rootfs requires a path argument." >&2
        exit 1
      fi
      ROOTFS_PATH="$2"
      shift 2
      ;;
    --apply)
      APPLY=1
      shift
      ;;
    --metadata-only)
      METADATA_ONLY=1
      shift
      ;;
    --installer-local-only)
      INSTALLER_LOCAL_ONLY=1
      shift
      ;;
    --real-artifact-only)
      REAL_ARTIFACT_ONLY=1
      shift
      ;;
    --metadata-wiring-only)
      METADATA_WIRING_ONLY=1
      shift
      ;;
    --release-hosting-only)
      RELEASE_HOSTING_ONLY=1
      shift
      ;;
    --hosted-dev-only)
      HOSTED_DEV_ONLY=1
      shift
      ;;
    --installer-compat-only)
      INSTALLER_COMPAT_ONLY=1
      shift
      ;;
    --asahi-adapter-only)
      ASAHI_ADAPTER_ONLY=1
      shift
      ;;
    --installer-override-only)
      INSTALLER_OVERRIDE_ONLY=1
      shift
      ;;
    --bootstrap-inspection-only)
      BOOTSTRAP_INSPECTION_ONLY=1
      shift
      ;;
    --bootstrap-report-only)
      BOOTSTRAP_REPORT_ONLY=1
      shift
      ;;
    --installer-boundary-probe-only)
      INSTALLER_BOUNDARY_PROBE_ONLY=1
      shift
      ;;
    --installer-asset-layout-only)
      INSTALLER_ASSET_LAYOUT_ONLY=1
      shift
      ;;
    --metadata-only-override-harness-only)
      METADATA_ONLY_OVERRIDE_HARNESS_ONLY=1
      shift
      ;;
    --bootstrap-safe-mode-probe-only)
      BOOTSTRAP_SAFE_MODE_PROBE_ONLY=1
      shift
      ;;
    --cidre-wrapper-strategy-only)
      CIDRE_WRAPPER_STRATEGY_ONLY=1
      shift
      ;;
    --cidre-wrapper-selection-only)
      CIDRE_WRAPPER_SELECTION_ONLY=1
      shift
      ;;
    --cidre-wrapper-artifact-only)
      CIDRE_WRAPPER_ARTIFACT_ONLY=1
      shift
      ;;
    --cidre-wrapper-extraction-only)
      CIDRE_WRAPPER_EXTRACTION_ONLY=1
      shift
      ;;
    --cidre-rootfs-plan-only)
      CIDRE_ROOTFS_PLAN_ONLY=1
      shift
      ;;
    --cidre-target-discovery-only)
      CIDRE_TARGET_DISCOVERY_ONLY=1
      shift
      ;;
    --cidre-target-selection-only)
      CIDRE_TARGET_SELECTION_ONLY=1
      shift
      ;;
    --cidre-final-contract-only)
      CIDRE_FINAL_CONTRACT_ONLY=1
      shift
      ;;
    --cidre-installer-mvp-only)
      CIDRE_INSTALLER_MVP_ONLY=1
      shift
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ "${METADATA_ONLY:-0}" -eq 1 ]; then
  echo "Running metadata validation only..."
  "$REPO_ROOT/installer/scripts/validate-installer-metadata" "$REPO_ROOT/installer/metadata/cidre-seed.local.json"
  exit 0
fi

if [ "${INSTALLER_LOCAL_ONLY:-0}" -eq 1 ]; then
  echo "Running installer local integration validation tests only..."
  "$REPO_ROOT/installer/scripts/run-local-integration-tests"
  exit 0
fi

if [ "${REAL_ARTIFACT_ONLY:-0}" -eq 1 ]; then
  echo "Running real artifact binding integration validation tests only..."
  "$REPO_ROOT/installer/scripts/run-real-artifact-binding-test" \
    --metadata "$REPO_ROOT/installer/metadata/cidre-seed.local.json" \
    --id cidre-seed-aarch64 \
    --image "$REPO_ROOT/out/cidre-seed-aarch64-v0.10.0.tar.zst" \
    --manifest "$REPO_ROOT/out/cidre-seed-aarch64-v0.10.0.manifest"
  exit 0
fi

if [ "${METADATA_WIRING_ONLY:-0}" -eq 1 ]; then
  echo "Running installer metadata wiring integration validation tests only..."
  "$REPO_ROOT/installer/scripts/run-metadata-wiring-tests"
  exit 0
fi

if [ "${RELEASE_HOSTING_ONLY:-0}" -eq 1 ]; then
  echo "Running release asset hosting integration validation tests only..."
  "$REPO_ROOT/installer/scripts/run-release-hosting-tests"
  exit 0
fi

if [ "${HOSTED_DEV_ONLY:-0}" -eq 1 ]; then
  echo "Running hosted dev release fetch integration validation tests only..."
  "$REPO_ROOT/installer/scripts/run-hosted-dev-artifact-tests"
  exit 0
fi

if [ "${INSTALLER_COMPAT_ONLY:-0}" -eq 1 ]; then
  echo "Running upstream installer compatibility study tests only..."
  "$REPO_ROOT/installer/scripts/run-installer-compat-study-tests"
  exit 0
fi

if [ "${ASAHI_ADAPTER_ONLY:-0}" -eq 1 ]; then
  echo "Running Asahi metadata adapter prototype tests only..."
  "$REPO_ROOT/installer/scripts/run-asahi-adapter-tests"
  exit 0
fi

if [ "${INSTALLER_OVERRIDE_ONLY:-0}" -eq 1 ]; then
  echo "Running INSTALLER_DATA override dryrun tests only..."
  "$REPO_ROOT/installer/scripts/run-installer-override-dryrun-tests"
  exit 0
fi

if [ "${BOOTSTRAP_INSPECTION_ONLY:-0}" -eq 1 ]; then
  echo "Running bootstrap override static inspections only..."
  "$REPO_ROOT/installer/scripts/run-bootstrap-inspection-tests"
  exit 0
fi

if [ "${BOOTSTRAP_REPORT_ONLY:-0}" -eq 1 ]; then
  echo "Running bootstrap compatibility report tests only..."
  "$REPO_ROOT/installer/scripts/run-bootstrap-compat-report-tests"
  exit 0
fi

if [ "${INSTALLER_BOUNDARY_PROBE_ONLY:-0}" -eq 1 ]; then
  echo "Running installer boundary probe tests only..."
  "$REPO_ROOT/installer/scripts/run-controlled-installer-boundary-probe-tests"
  exit 0
fi

if [ "${INSTALLER_ASSET_LAYOUT_ONLY:-0}" -eq 1 ]; then
  echo "Running installer asset layout normalization tests only..."
  "$REPO_ROOT/installer/scripts/run-installer-asset-layout-tests"
  exit 0
fi

if [ "${METADATA_ONLY_OVERRIDE_HARNESS_ONLY:-0}" -eq 1 ]; then
  echo "Running metadata-only override harness tests only..."
  "$REPO_ROOT/installer/scripts/run-metadata-only-override-harness-tests"
  exit 0
fi

if [ "${BOOTSTRAP_SAFE_MODE_PROBE_ONLY:-0}" -eq 1 ]; then
  echo "Running bootstrap safe-mode probe tests only..."
  "$REPO_ROOT/installer/scripts/run-bootstrap-safe-mode-probe-tests"
  exit 0
fi

if [ "${CIDRE_WRAPPER_STRATEGY_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper strategy tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-wrapper-strategy-tests"
  exit 0
fi

if [ "${CIDRE_WRAPPER_SELECTION_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper selection tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-wrapper-selection-tests"
  exit 0
fi

if [ "${CIDRE_WRAPPER_ARTIFACT_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper artifact fetch tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-wrapper-artifact-tests"
  exit 0
fi

if [ "${CIDRE_WRAPPER_EXTRACTION_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper sandbox extraction tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-wrapper-extraction-tests"
  exit 0
fi

if [ "${CIDRE_ROOTFS_PLAN_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper rootfs plan tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-rootfs-plan-tests"
  exit 0
fi

if [ "${CIDRE_TARGET_DISCOVERY_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper target discovery tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-target-discovery-tests"
  exit 0
fi

if [ "${CIDRE_TARGET_SELECTION_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper target selection tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-target-selection-tests"
  exit 0
fi

if [ "${CIDRE_FINAL_CONTRACT_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper final contract tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-final-contract-tests"
  exit 0
fi

if [ "${CIDRE_INSTALLER_MVP_ONLY:-0}" -eq 1 ]; then
  echo "Running Cidre installer wrapper MVP tests only..."
  "$REPO_ROOT/installer/scripts/run-cidre-installer-mvp-tests"
  exit 0
fi

# Prerequisite: verify host environment contains required tools
echo "Checking target environment prerequisites..."
REQUIRED_TOOLS=(bash makepkg pacman systemctl grep awk sed find tar)
missing=0
for tool in "${REQUIRED_TOOLS[@]}"; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "  Missing tool: $tool" >&2
    missing=$((missing + 1))
  fi
done

if [ $missing -gt 0 ]; then
  echo "" >&2
  echo "makepkg/target-tools was not found." >&2
  echo "" >&2
  echo "What happened:" >&2
  echo "  Package validation requires an Arch/ALARM target." >&2
  echo "" >&2
  echo "Next step:" >&2
  echo "  Run this validation later on an ALARM/Arch environment." >&2
  exit 1
fi

echo "All required tools verified."
echo ""

# Stage 1: Build Packages
echo "=== Stage 1/4: Building Cidre Packages ==="
if [ "$DRY_RUN" -eq 1 ]; then
  echo "  [DRY-RUN] would validate PKGBUILDs via build-cidre-packages --printsrcinfo-only"
else
  "$REPO_ROOT/scripts/dev/build-cidre-packages" --build
fi
echo ""

# Stage 2: Collect Packages
echo "=== Stage 2/4: Collecting Built Packages ==="
if [ "$DRY_RUN" -eq 1 ]; then
  echo "  [DRY-RUN] would collect package archives using collect-cidre-packages"
else
  "$REPO_ROOT/scripts/dev/collect-cidre-packages"
fi
echo ""

if [ "$PACKAGES_ONLY" -eq 1 ]; then
  echo "Validation completed (packages only)."
  exit 0
fi

# Stage 3: Rootfs Integration (if rootfs is provided)
if [ -n "$ROOTFS_PATH" ]; then
  echo "=== Stage 3/4: Rootfs Integration ==="
  if [ "$DRY_RUN" -eq 1 ]; then
    "$REPO_ROOT/image/scripts/install-local-packages" --rootfs "$ROOTFS_PATH" --packages "$REPO_ROOT/packages/out" --dry-run
    "$REPO_ROOT/image/scripts/enable-firstboot" --rootfs "$ROOTFS_PATH" --dry-run
  else
    if [ "$APPLY" -eq 1 ]; then
      "$REPO_ROOT/image/scripts/install-local-packages" --rootfs "$ROOTFS_PATH" --packages "$REPO_ROOT/packages/out" --apply
      "$REPO_ROOT/image/scripts/enable-firstboot" --rootfs "$ROOTFS_PATH" --apply
    else
      echo "ERROR: Use --apply to perform mutation or --dry-run." >&2
      exit 1
    fi
  fi
  echo ""

  # Stage 4: Sanity Validation
  echo "=== Stage 4/4: Rootfs Sanity Check ==="
  if [ "$DRY_RUN" -eq 1 ]; then
    "$REPO_ROOT/image/scripts/validate-rootfs" --rootfs "$ROOTFS_PATH" --dry-run
  else
    "$REPO_ROOT/image/scripts/validate-rootfs" --rootfs "$ROOTFS_PATH"
  fi
  echo ""
else
  echo "Skipped Stage 3 & 4 (No --rootfs provided)."
fi

echo "=== Target Validation Finished Successfully ==="
