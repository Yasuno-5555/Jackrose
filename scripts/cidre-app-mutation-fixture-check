#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
FIXTURE_DIR="$REPO_ROOT/test/fixtures/mutation"

required_files="
disposable-target-valid.json
disposable-target-startup-disk.json
disposable-target-apple-recovery.json
mutation-plan-valid.json
mutation-plan-tampered.json
mutation-before.json
mutation-after-safe.json
mutation-after-protected-changed.json
"

missing=""
for file in $required_files; do
  if [ ! -f "$FIXTURE_DIR/$file" ]; then
    missing="$missing $file"
  fi
done

if [ -n "$missing" ]; then
  echo "Missing mutation fixtures:$missing" >&2
  exit 8
fi

echo "Mutation fixtures are present."
