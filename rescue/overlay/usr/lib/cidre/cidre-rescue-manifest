#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
STATE_ROOT="${CIDRE_RESCUE_STATE_ROOT:-$REPO_ROOT/.local/state/cidre/rescue}"
CURRENT_DIR="$STATE_ROOT/current"
ARTIFACTS_DIR="$STATE_ROOT/artifacts"
mode=""
validate_file=""
output_file="$CURRENT_DIR/rescue-manifest.json"

usage() {
  cat <<EOF
Usage: cidre-rescue-manifest [options]

Options:
  --generate
  --validate <file>
  --output <file>
  --help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --generate) mode="generate"; shift ;;
    --validate) mode="validate"; validate_file="$2"; shift 2 ;;
    --output) output_file="$2"; shift 2 ;;
    --help) usage; exit 0 ;;
    *) printf 'ERROR: unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
done

[ -n "$mode" ] || mode="generate"

if [ "$mode" = "validate" ]; then
  [ -f "$validate_file" ] || { printf 'ERROR: manifest not found: %s\n' "$validate_file" >&2; exit 1; }
  grep -q '"artifact_type": "rescue-rootfs"' "$validate_file" || { printf 'ERROR: artifact_type rescue-rootfs missing\n' >&2; exit 1; }
  grep -q '"profile": "minimal-rescue"' "$validate_file" || { printf 'ERROR: profile minimal-rescue missing\n' >&2; exit 1; }
  grep -q '"contains_destructive_tools": false' "$validate_file" || { printf 'ERROR: contains_destructive_tools false missing\n' >&2; exit 1; }
  printf 'Rescue manifest validation passed: %s\n' "$validate_file"
  exit 0
fi

mkdir -p "$CURRENT_DIR" "$ARTIFACTS_DIR"
cat > "$output_file" <<EOF
{
  "schema_version": 1,
  "cidre_version": "0.26.0",
  "artifact_type": "rescue-rootfs",
  "profile": "minimal-rescue",
  "desktop": false,
  "primary_shell": "bash",
  "contains_destructive_tools": false,
  "boot_integration": "pending",
  "created_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "files": []
}
EOF
printf '%s\n' "$output_file"
