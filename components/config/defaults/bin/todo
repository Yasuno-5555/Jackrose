#!/usr/bin/env bash
set -euo pipefail

store="${HOME}/.local/share/jackrose/todo.tsv"
mkdir -p "$(dirname "$store")"
touch "$store"

list_items() {
    awk -F '\t' '$2 != "done" { printf "[ ] %s %s %s\n", $1, $3, $4 }' "$store"
}

new_item() {
    local title="$1"
    local id created
    id="$(date +%s%N | cut -b1-10)"
    created="$(date '+%Y-%m-%d %H:%M')"
    printf '%s\topen\t%s\t%s\n' "$id" "$created" "$title" >> "$store"
}

done_item() {
    local target="$1"
    awk -F '\t' -v id="$target" 'BEGIN{OFS="\t"} { if ($1 == id) $2="done"; print }' "$store" > "${store}.tmp"
    mv "${store}.tmp" "$store"
}

delete_item() {
    local target="$1"
    awk -F '\t' -v id="$target" '$1 != id { print }' "$store" > "${store}.tmp"
    mv "${store}.tmp" "$store"
}

case "${1:-list}" in
  list)
    list_items
    ;;
  new)
    shift
    if [ "${1:-}" = "-l" ]; then
      shift 2 || true
    fi
    [ "$#" -gt 0 ] || exit 0
    new_item "$*"
    ;;
  done)
    shift
    [ "$#" -eq 1 ] || exit 1
    done_item "$1"
    ;;
  delete)
    shift
    if [ "${1:-}" = "--yes" ]; then
      shift
    fi
    [ "$#" -eq 1 ] || exit 1
    delete_item "$1"
    ;;
  *)
    list_items
    ;;
esac
