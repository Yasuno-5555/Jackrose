#!/usr/bin/env bash
set -euo pipefail

wallpaper="${1:-$HOME/.local/share/backgrounds/jackrose-glass-mocha.png}"

if command -v swww >/dev/null 2>&1; then
    if ! pgrep -x swww-daemon >/dev/null 2>&1; then
        swww-daemon >/dev/null 2>&1 &
        sleep 0.3
    fi
    exec swww img "$wallpaper" --transition-type fade --transition-duration 0.4
fi

pkill -x swaybg >/dev/null 2>&1 || true
exec swaybg -i "$wallpaper" -m fill
