pkgname=cidre-safe-session
pkgver=1.0.0
pkgrel=1
pkgdesc='Cidre environment minimal recovery safe session (Skeleton)'
url='https://github.com/Yasuno-5555/Cidre'
arch=('any')
license=('custom')
depends=('bash')
source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to cidre-packages.
_repo_root="${startdir}/../../.."

package() {
  # Skeleton phase: Create minimal marker or directories
  mkdir -p "${pkgdir}/usr/share/cidre/safe"
  echo "# safe session config skeleton" > "${pkgdir}/usr/share/cidre/safe/skeleton.txt"
}
