pkgname=cidre-healthcheck
pkgver=1.0.0
pkgrel=1
pkgdesc='Cidre environment health check diagnostic tool'
url='https://github.com/Yasuno-5555/Cidre'
arch=('any')
license=('custom')
depends=('bash' 'cidre-diagnostics')
source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to cidre-packages.
_repo_root="${startdir}/../../.."

package() {
  install -Dm755 "${_repo_root}/components/healthcheck/bin/cidre-healthcheck" \
    "${pkgdir}/usr/bin/cidre-healthcheck"
}
