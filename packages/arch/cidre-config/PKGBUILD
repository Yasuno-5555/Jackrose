# Maintainer: Yasuno <yasuno@example.invalid>

pkgname=cidre-config
pkgver=1.0.0
pkgrel=1
pkgdesc='Cidre default configuration assets'
url='https://github.com/Yasuno-5555/Cidre'
arch=('any')
license=('custom')
depends=()
source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to cidre-packages.
_repo_root="${startdir}/../../.."

package() {
  install -Dm644 "${_repo_root}/components/config/defaults/niri/config.kdl" "${pkgdir}/usr/share/cidre/defaults/niri/config.kdl"
  install -Dm644 "${_repo_root}/components/config/defaults/ghostty/config" "${pkgdir}/usr/share/cidre/defaults/ghostty/config"
  install -Dm644 "${_repo_root}/components/config/defaults/fcitx5/profile" "${pkgdir}/usr/share/cidre/defaults/fcitx5/profile"
  install -Dm644 "${_repo_root}/components/config/defaults/environment.d/90-cidre-ime.conf" "${pkgdir}/usr/share/cidre/defaults/environment.d/90-cidre-ime.conf"
  install -Dm644 "${_repo_root}/components/config/defaults/fish/config.fish" "${pkgdir}/usr/share/cidre/defaults/fish/config.fish"
  install -Dm644 "${_repo_root}/components/config/defaults/starship/starship.toml" "${pkgdir}/usr/share/cidre/defaults/starship/starship.toml"
  install -Dm644 "${_repo_root}/components/config/defaults/fuzzel/fuzzel.ini" "${pkgdir}/usr/share/cidre/defaults/fuzzel/fuzzel.ini"
  install -Dm644 "${_repo_root}/components/config/defaults/waybar/config" "${pkgdir}/usr/share/cidre/defaults/waybar/config"
  install -Dm644 "${_repo_root}/components/config/defaults/waybar/style.css" "${pkgdir}/usr/share/cidre/defaults/waybar/style.css"
  install -Dm644 "${_repo_root}/components/config/defaults/applications/com.mitchellh.ghostty.desktop" "${pkgdir}/usr/share/cidre/defaults/applications/com.mitchellh.ghostty.desktop"
}

