# Maintainer: Yasuno <yasuno@example.invalid>

pkgname=jackrose-meta-core
pkgver=1.0.0
pkgrel=1
pkgdesc='Jackrose v1.0 core platform profile for Apple Silicon Macs'
url='https://github.com/Yasuno-5555/Jackrose'
arch=('aarch64')
license=('custom')
depends=(
  'base'
  'base-devel'
  'sudo'
  'linux-asahi'
  'linux-firmware'
  'm1n1'
  'uboot-asahi'
  'grub'
  'archlinuxarm-keyring'
  'asahi-alarm-keyring'
  'asahi-meta'
  'asahi-fwextract'
  'asahi-audio'
  'asahi-scripts'
  'bankstown'
  'speakersafetyd'
  'rtkit'
  'btrfs-progs'
  'snapper'
  'snap-pac'
  'zram-generator'
  'networkmanager'
  'openssh'
  'rsync'
)
provides=('cidre-meta-core')
conflicts=('cidre-meta-core')
replaces=('cidre-meta-core')
source=('profile.txt')
sha256sums=('SKIP')

# Monorepo-local packaging path.
_repo_root="${startdir}/../../.."

package() {
  install -Dm644 "${srcdir}/profile.txt" "${pkgdir}/usr/share/doc/${pkgname}/profile.txt"
  install -Dm755 "${_repo_root}/scripts/jackrose" "${pkgdir}/usr/bin/jackrose"
  install -Dm755 "${_repo_root}/scripts/jackrose-migrate" "${pkgdir}/usr/bin/jackrose-migrate"
}
