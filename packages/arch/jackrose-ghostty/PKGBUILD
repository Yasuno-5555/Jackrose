# Maintainer: Yasuno <yasuno@example.invalid>

pkgname=jackrose-ghostty
pkgver=1.3.1
pkgrel=3
pkgdesc='Jackrose-packaged Ghostty terminal build target for controlled ALARM validation'
url='https://github.com/ghostty-org/ghostty'
arch=('aarch64' 'x86_64')
license=('MIT')
depends=(
  'fontconfig'
  'freetype2'
  'glib2'
  'gtk4'
  'harfbuzz'
  'libpng'
  'ncurses'
  'libxkbcommon'
  'oniguruma'
  'wayland'
)
makedepends=('git' 'pkgconf' 'zig')
provides=('ghostty')
conflicts=('ghostty')
source=("https://release.files.ghostty.org/${pkgver}/ghostty-${pkgver}.tar.gz")
sha256sums=('3349d25600ffbda281197a18314f7d18791969cffe9474f0ff16a45a9ebfccdb')

_repo_root="${startdir}/../../.."

prepare() {
  cd "${srcdir}/ghostty-${pkgver}"
}

build() {
  cd "${srcdir}/ghostty-${pkgver}"
  export ZIG_GLOBAL_CACHE_DIR="${srcdir}/ghostty-zig-cache"
  local -a ghostty_build_args=(
    '--prefix' "${srcdir}/ghostty-stage"
    '--system' "${ZIG_GLOBAL_CACHE_DIR}/p"
    '-Doptimize=ReleaseFast'
    '-Dcpu=baseline'
  )

  mkdir -p "${ZIG_GLOBAL_CACHE_DIR}"
  while IFS= read -r url; do
    echo "Prefetching Zig dependency: $url"
    zig fetch "$url" >/dev/null
  done < build.zig.zon.txt

  zig build "${ghostty_build_args[@]}"
}

package() {
  cd "${srcdir}/ghostty-${pkgver}"
  export ZIG_GLOBAL_CACHE_DIR="${srcdir}/ghostty-zig-cache"
  local -a ghostty_build_args=(
    '--prefix' '/usr'
    '--system' "${ZIG_GLOBAL_CACHE_DIR}/p"
    '-Doptimize=ReleaseFast'
    '-Dcpu=baseline'
  )
  DESTDIR="${pkgdir}" zig build install "${ghostty_build_args[@]}"

  rm -f "${pkgdir}/usr/share/terminfo/g/ghostty"
  rm -f "${pkgdir}/usr/share/lib/terminfo/g/ghostty"

  if [ -f LICENSE ]; then
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi

  if [ -f dist/linux/ghostty_dolphin.desktop ]; then
    install -Dm644 \
      dist/linux/ghostty_dolphin.desktop \
      "${pkgdir}/usr/share/kio/servicemenus/ghostty_dolphin.desktop"
  fi

  install -Dm644 \
    "${_repo_root}/resources/ghostty/ghostty.desktop" \
    "${pkgdir}/usr/share/applications/ghostty.desktop"

  if [ -f images/gnome/256.png ]; then
    install -Dm644 \
      images/gnome/256.png \
      "${pkgdir}/usr/share/icons/hicolor/256x256/apps/ghostty.png"
  fi
}
