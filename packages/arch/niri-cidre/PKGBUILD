# Maintainer: Yasuno <yasuno@example.invalid>

pkgname=niri-cidre
pkgver=26.4.0
pkgrel=1
pkgdesc='Cidre desktop compositor component based on niri'
url='https://github.com/Yasuno-5555/Cidre'
arch=('aarch64')
license=('GPL-3.0-or-later')
depends=(
  'libdisplay-info'
  'libinput'
  'libxkbcommon'
  'pango'
  'cairo'
  'pipewire'
  'dbus'
  'systemd'
  'mesa'
  'seatd'
)
optdepends=(
  'xwayland-satellite: on-demand X11 compatibility bridge'
  'power-profiles-daemon: desktop power profile integration'
)
makedepends=(
  'cargo'
  'rust'
  'git'
  'clang'
  'llvm'
  'pkgconf'
)
source=("git+https://github.com/Yasuno-5555/niri-cidre.git")
sha256sums=('SKIP')

build() {
  cd "niri-cidre"
  cargo build --release --locked --bin niri-cidre
}

package() {
  cd "niri-cidre"
  install -Dm755 "target/release/niri-cidre" "${pkgdir}/usr/bin/niri-cidre"
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
