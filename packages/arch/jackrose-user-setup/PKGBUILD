source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to jackrose-packages.
_repo_root="${startdir}/../../.."

package() {
  install -Dm755 "${_repo_root}/components/config/bin/jackrose-user-setup" "${pkgdir}/usr/bin/jackrose-user-setup"
}
