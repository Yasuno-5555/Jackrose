pkgname=jackrose-user-setup
pkgver=1.0.0
pkgrel=2
pkgdesc='Jackrose user environment setup tool'
url='https://github.com/Yasuno-5555/Jackrose'
arch=('any')
license=('custom')
depends=('bash')
provides=('cidre-user-setup')
conflicts=('cidre-user-setup')
