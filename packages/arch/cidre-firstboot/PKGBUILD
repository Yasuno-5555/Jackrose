# Maintainer: Yasuno <yasuno@example.invalid>

pkgname=cidre-firstboot
pkgver=1.0.0
pkgrel=1
pkgdesc='Cidre environment first-boot OOBE systemd service and triggers'
url='https://github.com/Yasuno-5555/Cidre'
arch=('any')
license=('custom')
depends=('bash')
source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to cidre-packages.
_repo_root="${startdir}/../../.."

package() {
  # Install the systemd service file
  install -Dm644 "${_repo_root}/components/firstboot/systemd/cidre-firstboot.service" \
    "${pkgdir}/usr/lib/systemd/system/cidre-firstboot.service"
  install -Dm644 "${_repo_root}/components/firstboot/systemd/cidre-firstboot-prep.service" \
    "${pkgdir}/usr/lib/systemd/system/cidre-firstboot-prep.service"

  # Install the finish script
  install -Dm755 "${_repo_root}/components/firstboot/bin/cidre-firstboot-finish" \
    "${pkgdir}/usr/bin/cidre-firstboot-finish"
  install -Dm755 "${_repo_root}/components/firstboot/bin/cidre-firstboot-prep" \
    "${pkgdir}/usr/bin/cidre-firstboot-prep"
}

