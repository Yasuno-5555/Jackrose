# Maintainer: Yasuno <yasuno@example.invalid>

pkgname=jackrose-config
pkgver=1.0.0
pkgrel=2
pkgdesc='Jackrose default configuration assets'
url='https://github.com/Yasuno-5555/Jackrose'
arch=('any')
license=('custom')
depends=()
provides=('cidre-config')
conflicts=('cidre-config')
replaces=('cidre-config')

source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to jackrose-packages.
_repo_root="${startdir}/../../.."

package() {
  install -d "${pkgdir}/usr/share/jackrose/defaults"
  cp -a "${_repo_root}/components/config/defaults/." "${pkgdir}/usr/share/jackrose/defaults/"
}
