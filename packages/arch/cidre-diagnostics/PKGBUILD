pkgname=cidre-diagnostics
pkgver=1.0.0
pkgrel=1
pkgdesc='Cidre environment diagnostic tools'
url='https://github.com/Yasuno-5555/Cidre'
arch=('any')
license=('custom')
depends=('bash')
source=()
sha256sums=()

# Monorepo-local packaging path.
# This will be replaced by source=() when packages move to cidre-packages.
_repo_root="${startdir}/../../.."

package() {
  install -Dm755 "${_repo_root}/scripts/cidre-doctor" "${pkgdir}/usr/bin/cidre-doctor"
}

