#!/bin/bash
# compare-installer-metadata-shape: Compares Cidre, Asahi-like adapter output, and upstream formats
set -euo pipefail

CIDRE=""
ASAHI_LIKE=""
UPSTREAM=""

usage() {
  echo "Usage: $0 --cidre <path> [--asahi-like <path>] --upstream <path>"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --cidre)
      if [ $# -lt 2 ]; then
        echo "ERROR: --cidre requires a path." >&2
        exit 1
      fi
      CIDRE="$2"
      shift 2
      ;;
    --asahi-like)
      if [ $# -lt 2 ]; then
        echo "ERROR: --asahi-like requires a path." >&2
        exit 1
      fi
      ASAHI_LIKE="$2"
      shift 2
      ;;
    --upstream)
      if [ $# -lt 2 ]; then
        echo "ERROR: --upstream requires a path." >&2
        exit 1
      fi
      UPSTREAM="$2"
      shift 2
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$CIDRE" ] || [ -z "$UPSTREAM" ]; then
  echo "ERROR: Both --cidre and --upstream are required." >&2
  usage
fi

if [ ! -f "$CIDRE" ] || [ ! -f "$UPSTREAM" ]; then
  echo "ERROR: Input target files must exist." >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq is required." >&2
  exit 1
fi

echo "=== Installer Metadata Shape Comparison Report ==="
echo ""
echo "Cidre Input:     $CIDRE"
if [ -n "$ASAHI_LIKE" ]; then
  echo "Adapter Output:  $ASAHI_LIKE"
fi
echo "Upstream Input:  $UPSTREAM"
echo ""

# Extract keys from structures
cidre_keys=$(jq -r '.images[0] | keys | .[]' "$CIDRE" 2>/dev/null || echo "")
upstream_keys=$(jq -r '.os_list[0] | keys | .[]' "$UPSTREAM" 2>/dev/null || echo "")

if [ -z "$cidre_keys" ] || [ -z "$upstream_keys" ]; then
  echo "ERROR: Unable to parse keys. Ensure both files contain valid array objects." >&2
  exit 1
fi

echo "Field Mapping Analysis:"
echo ""

# 1. Compatible Mappings
echo "Compatible (Direct Mapping):"
for ck in $cidre_keys; do
  for uk in $upstream_keys; do
    if [ "$ck" = "$uk" ]; then
      echo "  - cidre: .images[].$ck  ==>  upstream: .os_list[].$uk"
    fi
  done
done
echo "  - cidre: .images[].label  ==>  upstream: .os_list[].name (human OS label)"
echo ""

# 2. Transform Required
echo "Transform Required:"
echo "  - cidre: .images[].url  ==>  upstream: .os_list[].package (path conversion needed)"
echo ""

if [ -n "$ASAHI_LIKE" ] && [ -f "$ASAHI_LIKE" ]; then
  echo "Adapter Generated Field Mapping Check:"
  adapt_keys=$(jq -r '.os_list[0] | keys | .[]' "$ASAHI_LIKE" 2>/dev/null || echo "")
  for ak in $adapt_keys; do
    # check if maps directly to upstream
    matched=0
    for uk in $upstream_keys; do
      if [ "$ak" = "$uk" ]; then
        matched=1
        echo "  - [MATCHED] adapter: .os_list[].$ak  ==>  upstream: .os_list[].$uk"
      fi
    done
    if [ "$ak" = "name" ] && jq -r '.os_list[0].name' "$ASAHI_LIKE" >/dev/null; then
      matched=1
      echo "  - [MATCHED] adapter: .os_list[].name  ==>  upstream: .os_list[].name"
    fi
    if [ $matched -eq 0 ]; then
      echo "  - [EXTENSION] adapter: .os_list[].$ak"
    fi
  done
  echo ""
fi

# 3. Cidre only variables
echo "Cidre-only (Likely ignored upstream):"
for ck in $cidre_keys; do
  matched=0
  for uk in $upstream_keys; do
    if [ "$ck" = "$uk" ]; then
      matched=1
    fi
  done
  # Special mapping ignores
  if [ "$ck" = "label" ] || [ "$ck" = "url" ] || [ "$ck" = "welcome_command" ] || [ "$ck" = "first_boot_mode" ]; then
    matched=1
  fi
  if [ $matched -eq 0 ]; then
    echo "  - .images[].$ck"
  fi
done
echo ""

echo "Unknown / Study Required:"
for uk in $upstream_keys; do
  matched=0
  for ck in $cidre_keys; do
    if [ "$ck" = "$uk" ]; then
      matched=1
    fi
  done
  if [ "$uk" = "name" ] || [ "$uk" = "package" ] || [ "$uk" = "checksum" ] || [ "$uk" = "size" ]; then
    matched=1
  fi
  if [ $matched -eq 0 ]; then
    echo "  - .os_list[].$uk"
  fi
done
echo ""
echo "Comparison completed."
exit 0
