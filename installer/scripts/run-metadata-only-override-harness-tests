#!/bin/bash
# run-metadata-only-override-harness-tests: Phase 24 override harness tests runner
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

TEST_TMPDIR="${CIDRE_TEST_TMPDIR:-/tmp/cidre-metadata-only-override-harness-tests}"
rm -rf "$TEST_TMPDIR"
mkdir -p "$TEST_TMPDIR/generated"

echo "=== Running Metadata-only Override Harness Tests ==="

SAFE_FIXTURE="$REPO_ROOT/installer/bootstrap/fixtures/minimal-bootstrap-sample.sh"
DANGER_FIXTURE="$REPO_ROOT/installer/bootstrap/fixtures/dangerous-bootstrap-sample.sh"

FIXTURE_DATA="$REPO_ROOT/installer/fixtures/cidre-seed-v0.integration.json"
LOCAL_LAYOUT="$REPO_ROOT/installer/release/cidre-release-layout.localhost.json"

# Stage required inputs
"$REPO_ROOT/installer/scripts/export-installer-metadata" \
  --metadata "$FIXTURE_DATA" \
  --output "$TEST_TMPDIR/local-facing.json" \
  --channel local

"$REPO_ROOT/installer/scripts/prepare-dev-release-assets" \
  --layout "$LOCAL_LAYOUT" \
  --metadata "$TEST_TMPDIR/local-facing.json" \
  --output "$TEST_TMPDIR/dev-facing.json"

# Test 1: Positive harness execution on safe bootstrap snapshot
echo "Test 1: Running harness on safe bootstrap..."
harness_out=$( "$REPO_ROOT/installer/scripts/metadata-only-installer-override-harness" \
  --cidre-metadata "$TEST_TMPDIR/dev-facing.json" \
  --repo-base "http://127.0.0.1:8762" \
  --port 8762 \
  --bootstrap-snapshot "$SAFE_FIXTURE" \
  --output-env "$TEST_TMPDIR/generated/override-env.env" \
  --result-output "$TEST_TMPDIR/generated/harness-result.md" )

# Verify override env printed in stdout
if ! echo "$harness_out" | grep -q "CIDRE_METADATA_ONLY_OVERRIDE_READY=\"1\""; then
  echo "ERROR: Expected CIDRE_METADATA_ONLY_OVERRIDE_READY variable to be printed, but missing." >&2
  exit 1
fi

# Verify generated files
if [ ! -f "$TEST_TMPDIR/generated/override-env.env" ] || [ ! -f "$TEST_TMPDIR/generated/harness-result.md" ]; then
  echo "ERROR: Target files not generated by harness." >&2
  exit 1
fi

echo "  [OK] Safe override harness execution verified."

# --- Negative Tests Section ---
echo "=== Running Negative Harness Tests ==="

# Neg 1: Dangerous bootstrap snapshot (expect B decision, non-zero return, no env generated)
echo "Neg 1: Dangerous bootstrap snapshot checks..."
if harness_out_danger=$( "$REPO_ROOT/installer/scripts/metadata-only-installer-override-harness" \
  --cidre-metadata "$TEST_TMPDIR/dev-facing.json" \
  --repo-base "http://127.0.0.1:8762" \
  --port 8762 \
  --bootstrap-snapshot "$DANGER_FIXTURE" \
  --output-env "$TEST_TMPDIR/generated/override-danger.env" \
  --result-output "$TEST_TMPDIR/generated/harness-danger.md" 2>/dev/null ); then
  
  echo "ERROR: Expected harness to fail on dangerous bootstrap snapshot, but passed." >&2
  exit 1
fi

if [ -f "$TEST_TMPDIR/generated/override-danger.env" ]; then
  echo "ERROR: Environment file generated for dangerous snapshot." >&2
  exit 1
fi
echo "  [PASSED] Dangerous bootstrap blocked and failed correctly."

# Neg 2: Missing manifest (expect C decision, non-zero return, no env generated)
echo "Neg 2: Missing manifest layout check..."
# Prepare bad input (missing manifest link)
jq 'del(.images[0].manifest)' "$TEST_TMPDIR/dev-facing.json" > "$TEST_TMPDIR/bad-facing.json"
if harness_out_bad=$( "$REPO_ROOT/installer/scripts/metadata-only-installer-override-harness" \
  --cidre-metadata "$TEST_TMPDIR/bad-facing.json" \
  --repo-base "http://127.0.0.1:8762" \
  --port 8762 \
  --bootstrap-snapshot "$SAFE_FIXTURE" \
  --output-env "$TEST_TMPDIR/generated/override-bad.env" 2>/dev/null ); then
  
  echo "ERROR: Expected harness to fail on bad layout, but passed." >&2
  exit 1
fi

if [ -f "$TEST_TMPDIR/generated/override-bad.env" ]; then
  echo "ERROR: Environment file generated for bad layout." >&2
  exit 1
fi
echo "  [PASSED] Bad layout blocked and failed correctly."

echo "All Metadata-only Override Harness Tests completed successfully!"
rm -rf "$TEST_TMPDIR"
exit 0
