#!/bin/bash
# run-cidre-installer-mvp-tests: Phase 34 full MVP pipeline testing suite
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

TEST_TMPDIR="${CIDRE_TEST_TMPDIR:-/tmp/cidre-installer-mvp-tests}"
rm -rf "$TEST_TMPDIR"
mkdir -p "$TEST_TMPDIR/fixtures"
mkdir -p "$TEST_TMPDIR/rootfs/usr/bin"
mkdir -p "$TEST_TMPDIR/rootfs/etc"
mkdir -p "$TEST_TMPDIR/rootfs/var"
mkdir -p "$TEST_TMPDIR/rootfs/usr/share/cidre/defaults"
mkdir -p "$TEST_TMPDIR/output"

# Write core scripts to mock rootfs
touch "$TEST_TMPDIR/rootfs/usr/bin/cidre-welcome"
touch "$TEST_TMPDIR/rootfs/usr/bin/cidre-doctor"
touch "$TEST_TMPDIR/rootfs/usr/bin/cidre-session"

echo "=== Running Cidre Installer MVP Tests ==="

# Write mock contract & plan JSON structures
cat <<EOF > "$TEST_TMPDIR/fixtures/contract.valid.json"
{
  "contract_version": "0.1",
  "phase": "33",
  "contract_kind": "final-non-mutating-install-contract",
  "rootfs": {
    "selected_id": "cidre-seed-aarch64",
    "rootfs_dir": "$TEST_TMPDIR/rootfs",
    "rootfs_valid": true
  },
  "target": {
    "target_id": "nvme0n1p7",
    "path": "/dev/nvme0n1p7",
    "parent": "/dev/nvme0n1",
    "type": "part",
    "size_bytes": 53687091200,
    "classification": "safe_candidate",
    "eligible": true
  },
  "confirmation": {
    "target_selection_confirmed": true,
    "confirmation_string": "SELECT CIDRE TARGET ONLY - NO INSTALL"
  },
  "permissions": {
    "mount_allowed": false,
    "format_allowed": false,
    "target_mutation_allowed": false,
    "staging_allowed": false,
    "boot_policy_mutation_allowed": false,
    "install_allowed": false
  },
  "blocked_operations": [],
  "reason": "MOCK"
}
EOF

cat <<EOF > "$TEST_TMPDIR/fixtures/dryrun.valid.json"
{
  "dryrun_version": "0.1",
  "phase": "33",
  "source_contract": "MOCK",
  "dryrun_only": true,
  "rootfs_dir": "$TEST_TMPDIR/rootfs",
  "target_path": "/dev/nvme0n1p7",
  "planned_steps": [
    {
      "step": 1,
      "name": "mock",
      "action": "mock",
      "execution_allowed": false
    }
  ],
  "blocked_commands": [],
  "mount_allowed": false,
  "format_allowed": false,
  "staging_allowed": false,
  "target_mutation_allowed": false,
  "boot_policy_mutation_allowed": false,
  "install_allowed": false,
  "reason": "MOCK"
}
EOF

# Test 1: Full positive staging, validation, handoff, and freeze pipeline
echo "Test 1: Testing full MVP pipeline..."
"$REPO_ROOT/installer/scripts/cidre-wrapper-stage-target" \
  --contract "$TEST_TMPDIR/fixtures/contract.valid.json" \
  --dryrun-plan "$TEST_TMPDIR/fixtures/dryrun.valid.json" \
  --confirm "APPLY CIDRE STAGING TO SELECTED TARGET" \
  --output "$TEST_TMPDIR/output/staging-result.json" \
  --apply \
  --fixture-mode \
  --mount-root "$TEST_TMPDIR/output"

# Run staged target validation (using fixture-mode which references the mock output staging directory)
"$REPO_ROOT/installer/scripts/validate-cidre-staged-target" \
  --staging-result "$TEST_TMPDIR/output/staging-result.json" \
  --output "$TEST_TMPDIR/output/staged-validation.json" \
  --fixture-mode \
  --mount-root "$TEST_TMPDIR/output"

# Generate boot handoff
"$REPO_ROOT/installer/scripts/generate-cidre-firstboot-handoff" \
  --staged-validation "$TEST_TMPDIR/output/staged-validation.json" \
  --output "$TEST_TMPDIR/output/firstboot-handoff.json"

# Freeze installer MVP
"$REPO_ROOT/installer/scripts/freeze-cidre-installer-mvp" \
  --staging-result "$TEST_TMPDIR/output/staging-result.json" \
  --staged-validation "$TEST_TMPDIR/output/staged-validation.json" \
  --firstboot-handoff "$TEST_TMPDIR/output/firstboot-handoff.json" \
  --output "$TEST_TMPDIR/output/installer-mvp-freeze.json"

# Validate freeze results
mvp_ok=$(jq -r '.installer_mvp_complete' "$TEST_TMPDIR/output/installer-mvp-freeze.json")
if [ "$mvp_ok" != "true" ]; then
  echo "ERROR: Expected installer_mvp_complete=true but got '$mvp_ok'." >&2
  exit 1
fi
echo "  [OK] Valid MVP pipeline successfully completed."

# --- Negative Tests Section ---
echo "=== Running Negative MVP Tests ==="

# Neg 1: Missing apply flag
echo "Neg 1: Testing missing apply flag..."
if "$REPO_ROOT/installer/scripts/cidre-wrapper-stage-target" \
  --contract "$TEST_TMPDIR/fixtures/contract.valid.json" \
  --dryrun-plan "$TEST_TMPDIR/fixtures/dryrun.valid.json" \
  --confirm "APPLY CIDRE STAGING TO SELECTED TARGET" \
  --output "$TEST_TMPDIR/output/staging-bad.json" \
  --fixture-mode \
  --mount-root "$TEST_TMPDIR/output" >/dev/null 2>&1; then
  
  echo "ERROR: Expected staging to fail without --apply, but passed." >&2
  exit 1
fi
echo "  [PASSED] Staging apply gate requirement verified."

# Neg 2: Bad confirmation string
echo "Neg 2: Testing incorrect confirmation string..."
if "$REPO_ROOT/installer/scripts/cidre-wrapper-stage-target" \
  --contract "$TEST_TMPDIR/fixtures/contract.valid.json" \
  --dryrun-plan "$TEST_TMPDIR/fixtures/dryrun.valid.json" \
  --confirm "BAD_CONFIRMATION_STRING" \
  --output "$TEST_TMPDIR/output/staging-bad.json" \
  --apply \
  --fixture-mode \
  --mount-root "$TEST_TMPDIR/output" >/dev/null 2>&1; then
  
  echo "ERROR: Expected staging to fail on bad confirmation, but passed." >&2
  exit 1
fi
echo "  [PASSED] Bad confirmation string successfully blocked."

# Neg 3: Validation failure on missing core scripts
echo "Neg 3: Testing validation on missing components..."
# Create a staging mock result pointing at an empty folder
cat <<EOF > "$TEST_TMPDIR/output/staging-empty.json"
{
  "staging_version": "0.1",
  "phase": "34",
  "staging_complete": true,
  "boot_policy_mutation_performed": false,
  "default_boot_changed": false,
  "installer_executed": false,
  "target": { "path": "/dev/nvme0n1p7" },
  "mount": { "mountpoint": "$TEST_TMPDIR/fixtures" }
}
EOF

if "$REPO_ROOT/installer/scripts/validate-cidre-staged-target" \
  --staging-result "$TEST_TMPDIR/output/staging-empty.json" \
  --output "$TEST_TMPDIR/output/validation-empty.json" \
  --fixture-mode >/dev/null 2>&1; then
  
  echo "ERROR: Expected validation to fail on empty rootfs layout, but passed." >&2
  exit 1
fi
echo "  [PASSED] Staged target validation failure check verified."

# Neg 4: Rejection of policy mutation flags in freeze
echo "Neg 4: Rejection of policy mutation flags in freeze..."
cat <<EOF > "$TEST_TMPDIR/output/staging-tampered.json"
{
  "staging_version": "0.1",
  "phase": "34",
  "staging_complete": true,
  "boot_policy_mutation_performed": true,
  "default_boot_changed": true,
  "installer_executed": true
}
EOF

if "$REPO_ROOT/installer/scripts/freeze-cidre-installer-mvp" \
  --staging-result "$TEST_TMPDIR/output/staging-tampered.json" \
  --staged-validation "$TEST_TMPDIR/output/staged-validation.json" \
  --firstboot-handoff "$TEST_TMPDIR/output/firstboot-handoff.json" \
  --output "$TEST_TMPDIR/output/freeze-bad.json" >/dev/null 2>&1; then
  
  echo "ERROR: Expected freeze to fail on tampered staging result, but passed." >&2
  exit 1
fi
echo "  [PASSED] Tampered pipeline parameters successfully rejected in freeze."

# Safety Tests: Confirms forbidden commands are matched inside guard zones
echo "Safety: Verifying safety guard blocks..."
FORBIDDEN=(installer-bootstrap.sh alx.sh install.sh "curl | sh" diskutil "diskutil erase" "diskutil partition" "diskutil apfs" bless nvram gpt fdisk dd mkfs parted chroot "pacman --root")
for cmd in "${FORBIDDEN[@]}"; do
  if "$REPO_ROOT/installer/scripts/guard-installer-danger-zone" --command "$cmd" >/dev/null 2>&1; then
    echo "ERROR: Safety guard failed to block forbidden command '$cmd'." >&2
    exit 1
  fi
done
echo "  [PASSED] All forbidden command blocks verified."

echo "All Cidre Installer MVP Tests completed successfully!"
rm -rf "$TEST_TMPDIR"
exit 0
