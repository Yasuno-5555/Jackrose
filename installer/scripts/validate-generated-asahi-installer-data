#!/bin/bash
# validate-generated-asahi-installer-data: Validator for Cidre-generated Asahi-like metadata files
set -euo pipefail

FILE=""
STRICT=0

usage() {
  echo "Usage: $0 [--strict] <generated-asahi-data.json>"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --strict)
      STRICT=1
      shift
      ;;
    -*)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
    *)
      if [ -n "$FILE" ]; then
        echo "ERROR: Multiple target files specified." >&2
        exit 1
      fi
      FILE="$1"
      shift
      ;;
  esac
done

if [ -z "$FILE" ]; then
  echo "ERROR: File path is required." >&2
  usage
fi

if [ ! -f "$FILE" ]; then
  echo "ERROR: File not found at $FILE" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq is required." >&2
  exit 1
fi

# Ensure valid JSON formatting
if ! jq . "$FILE" >/dev/null 2>&1; then
  echo "ERROR: Invalid JSON structure in $FILE" >&2
  exit 1
fi

echo "Validating generated Asahi-like metadata files..."

# Check prototype warning label
warning_val=$(jq -r '._warning' "$FILE")
if [ "$warning_val" = "null" ] || [ -z "$warning_val" ]; then
  echo "ERROR: Missing required '_warning' prototype descriptor label." >&2
  exit 1
fi

os_list_exists=$(jq -r '.os_list | type' "$FILE")
if [ "$os_list_exists" != "array" ]; then
  echo "ERROR: os_list must be an array." >&2
  exit 1
fi

os_count=$(jq '.os_list | length' "$FILE")
if [ "$os_count" -eq 0 ]; then
  echo "ERROR: os_list array is empty." >&2
  exit 1
fi

errors=0
for ((i=0; i<os_count; i++)); do
  os_id=$(jq -r ".os_list[$i].id" "$FILE")
  os_name=$(jq -r ".os_list[$i].name" "$FILE")
  os_pkg=$(jq -r ".os_list[$i].package" "$FILE")
  os_url=$(jq -r ".os_list[$i].url" "$FILE")
  os_sha=$(jq -r ".os_list[$i].sha256" "$FILE")
  os_arch=$(jq -r ".os_list[$i].arch" "$FILE")
  os_platform=$(jq -r ".os_list[$i].platform" "$FILE")
  os_first_boot=$(jq -r ".os_list[$i].first_boot_mode" "$FILE")

  echo "Inspecting generated entry: $os_id ($os_name)..."

  # Basic existence
  if [ "$os_id" = "null" ] || [ "$os_name" = "null" ] || [ "$os_arch" = "null" ] || [ "$os_platform" = "null" ]; then
    echo "  [FAIL] Missing basic metadata keys (id, name, arch, platform)." >&2
    errors=$((errors + 1))
    continue
  fi

  if [ "$os_pkg" = "null" ] && [ "$os_url" = "null" ]; then
    echo "  [FAIL] Missing target package location or url path." >&2
    errors=$((errors + 1))
  fi

  # Values assertions
  if [ "$os_arch" != "aarch64" ]; then
    echo "  [FAIL] Invalid architecture '$os_arch' (expected: aarch64)." >&2
    errors=$((errors + 1))
  fi

  if [ "$os_platform" != "apple-silicon" ]; then
    echo "  [FAIL] Invalid platform '$os_platform' (expected: apple-silicon)." >&2
    errors=$((errors + 1))
  fi

  if [ "$os_first_boot" != "desktop-welcome" ]; then
    echo "  [FAIL] Invalid first_boot_mode '$os_first_boot' (expected: desktop-welcome)." >&2
    errors=$((errors + 1))
  fi

  # Warnings
  if [[ "$os_pkg" =~ \.tar\.zst$ ]]; then
    echo "  [WARN] package format is .tar.zst. Upstream installer might enforce package.zip layers."
  fi

  # Strict rules
  if [ "$STRICT" -eq 1 ]; then
    if [ "$os_sha" = "PLACEHOLDER_SHA256" ]; then
      echo "  [FAIL] Strict validation fail: PLACEHOLDER_SHA256 checksum detected in entry: $os_id" >&2
      errors=$((errors + 1))
    fi
    if [[ ! "$os_url" =~ ^https:// && ! "$os_url" =~ ^http://127.0.0.1 && ! "$os_url" =~ ^http://localhost ]]; then
      echo "  [FAIL] Strict validation fail: url '$os_url' is not secure HTTPS or local HTTP mocks path." >&2
      errors=$((errors + 1))
    fi
  fi
done

if [ $errors -gt 0 ]; then
  echo "Validation failed with $errors error(s)." >&2
  exit 2
fi

echo "Prototype validation successful."
exit 0
