#!/bin/bash
# freeze-cidre-installer-mvp: Finalizes and freezes the installer MVP pipeline validation metadata
set -euo pipefail

RESULT=""
VALIDATION=""
HANDOFF=""
OUTPUT=""

usage() {
  echo "Usage: $0 --staging-result <path> --staged-validation <path> --firstboot-handoff <path> --output <path>"
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    --staging-result)
      if [ $# -lt 2 ]; then
        echo "ERROR: --staging-result requires a path." >&2
        exit 1
      fi
      RESULT="$2"
      shift 2
      ;;
    --staged-validation)
      if [ $# -lt 2 ]; then
        echo "ERROR: --staged-validation requires a path." >&2
        exit 1
      fi
      VALIDATION="$2"
      shift 2
      ;;
    --firstboot-handoff)
      if [ $# -lt 2 ]; then
        echo "ERROR: --firstboot-handoff requires a path." >&2
        exit 1
      fi
      HANDOFF="$2"
      shift 2
      ;;
    --output)
      if [ $# -lt 2 ]; then
        echo "ERROR: --output requires a path." >&2
        exit 1
      fi
      OUTPUT="$2"
      shift 2
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      ;;
  esac
done

if [ -z "$RESULT" ] || [ -z "$VALIDATION" ] || [ -z "$HANDOFF" ] || [ -z "$OUTPUT" ]; then
  echo "ERROR: --staging-result, --staged-validation, --firstboot-handoff, and --output are required." >&2
  usage
fi

if [ ! -f "$RESULT" ] || [ ! -f "$VALIDATION" ] || [ ! -f "$HANDOFF" ]; then
  echo "ERROR: Input files do not exist." >&2
  exit 1
fi

# Load validation checks
r_phase=$(jq -r '.phase' "$RESULT")
r_st_complete=$(jq -r '.staging_complete' "$RESULT")
r_bp=$(jq -r '.boot_policy_mutation_performed' "$RESULT")
r_db=$(jq -r '.default_boot_changed' "$RESULT")
r_inst=$(jq -r '.installer_executed' "$RESULT")

v_phase=$(jq -r '.phase' "$VALIDATION")
v_st_valid=$(jq -r '.staged_target_valid' "$VALIDATION")

h_phase=$(jq -r '.phase' "$HANDOFF")
h_hand_complete=$(jq -r '.firstboot_handoff_complete' "$HANDOFF")
h_bp_perf=$(jq -r '.boot_policy_mutation_performed' "$HANDOFF")
h_db_chg=$(jq -r '.default_boot_changed' "$HANDOFF")

if [ "$r_phase" != "34" ] || [ "$r_st_complete" != "true" ] || [ "$r_bp" != "false" ] || [ "$r_db" != "false" ] || [ "$r_inst" != "false" ] || \
   [ "$v_phase" != "34" ] || [ "$v_st_valid" != "true" ] || \
   [ "$h_phase" != "34" ] || [ "$h_hand_complete" != "true" ] || [ "$h_bp_perf" != "false" ] || [ "$h_db_chg" != "false" ]; then
  echo "ERROR: Pipeline validation mismatch. Staging or validation locks indicate errors." >&2
  exit 1
fi

# Build installer-mvp-freeze JSON
freeze_json=$(jq -n \
  --arg phase "34" \
  --arg reason "Cidre Installer MVP is complete: controlled staging, validation, first boot handoff, and recovery contract are implemented." \
  '{
    mvp_version: "0.1",
    phase: $phase,
    installer_mvp_complete: true,
    pipeline: {
      metadata_selection_complete: true,
      artifact_verification_complete: true,
      sandbox_extraction_complete: true,
      rootfs_validation_complete: true,
      target_discovery_complete: true,
      target_selection_complete: true,
      final_contract_complete: true,
      controlled_staging_complete: true,
      post_staging_validation_complete: true,
      firstboot_handoff_complete: true
    },
    safety: {
      upstream_installer_executed: false,
      boot_policy_mutation_performed: false,
      default_boot_changed: false,
      automatic_reboot_performed: false,
      partition_table_modified: false
    },
    mvp_scope: {
      gui_installer: false,
      automatic_default_boot: false,
      partition_creation: false,
      partition_resize: false,
      multi_machine_validation: false
    },
    next_work: [
      "live hardware validation",
      "GUI wrapper",
      "error UX",
      "recovery polish",
      "multi-target test matrix"
    ],
    reason: $reason
  }'
)

mkdir -p "$(dirname "$OUTPUT")"
echo "$freeze_json" > "$OUTPUT"

echo "Installer MVP pipeline freeze complete." >&2
echo "$freeze_json"
exit 0
